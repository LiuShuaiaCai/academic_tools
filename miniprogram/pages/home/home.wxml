<!--pages/home/home.wxml-->
<view class="home-page">
  <!-- 顶部 Header -->
  <view class="home-header">
    <view class="header-left">
      <view class="header-title">学术管理</view>
    </view>
    <view class="header-right">
      <view class="header-btn" bindtap="showSearch">
        <text>🔍</text>
      </view>
      <view class="header-btn" bindtap="showNotifications">
        <text>🔔</text>
        <view class="notif-badge" wx:if="{{notifCount > 0}}">{{notifCount}}</view>
      </view>
    </view>
  </view>

  <!-- 签到弹窗 -->
  <view class="signin-modal-mask" wx:if="{{showSigninModal}}" bindtap="closeSigninModal">
    <view class="signin-modal" catchtap="">
      <view class="signin-modal-emoji">🌟</view>
      <view class="signin-modal-title">每日签到</view>
      <view class="signin-modal-points">
        <text class="points-num">+10</text>
        <text class="points-unit">积分</text>
      </view>
      <view class="signin-modal-streak" wx:if="{{continuousDays > 0}}">
        已连续签到 {{continuousDays}} 天
      </view>
      <view class="signin-modal-desc" wx:if="{{continuousDays < 7}}">坚持签到，积攒积分解锁更多功能</view>
      <view class="signin-modal-desc highlight" wx:if="{{continuousDays >= 7}}">连续签到满7天，最高可获 +40 积分！</view>
      <view class="signin-modal-btn" catchtap="doSignin">立即签到</view>
      <view class="signin-modal-skip" catchtap="closeSigninModal">稍后再说</view>
    </view>
  </view>

  <!-- 统计卡片（动态生成） -->
  <view class="stats-frame">
    <view class="stats-frame-title">
      <text>📊</text>
      <text>工作台</text>
      <view class="more-link" wx:if="{{enabledTools.length > 4 && !loading}}" bindtap="goToToolbox">
        <text>更多工具</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 加载骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton-grid">
      <view class="skeleton-card" wx:for="{{4}}" wx:key="*this">
        <view class="skeleton-icon skeleton-pulse"></view>
        <view class="skeleton-line skeleton-pulse" style="width:60%"></view>
        <view class="skeleton-line skeleton-pulse" style="width:40%;height:20rpx"></view>
      </view>
    </view>

    <!-- 空状态：没有启用任何工具 -->
    <view wx:elif="{{enabledTools.length === 0}}" class="empty-tools" bindtap="goToToolManager">
      <text class="empty-tools-icon">🧰</text>
      <text class="empty-tools-text">你还没有添加工具</text>
      <text class="empty-tools-sub">去工具管理开启需要的工具吧</text>
    </view>

    <!-- 工具网格 -->
    <view wx:elif="{{enabledTools.length > 0}}" class="stats-grid" id="statsGrid">
      <view
        class="stats-card {{item.color}}-accent"
        wx:for="{{displayTools}}"
        wx:key="id"
        bindtap="goToTool"
        data-page="{{item.pagePath}}"
      >
        <view class="card-icon {{item.color}}-bg">{{item.iconEmoji}}</view>
        <view class="card-info">
          <view class="card-title">{{item.name}}</view>
          <view class="card-desc">{{item.desc}}</view>
        </view>
        <view class="card-stats" wx:if="{{item.id === 'specialIssue'}}">
          <text>{{item.count}} 个特刊</text>
        </view>
        <view class="card-stats" wx:elif="{{item.isTaskType}}">
          <image class="card-stats-icon" src="/images/icon-task.png" />
          <text>{{item.count}} 任务待完成</text>
        </view>
        <view class="card-stats" wx:elif="{{item.id === 'archive'}}">
          <text>{{item.count}} 份资料</text>
        </view>
        <view class="card-stats" wx:elif="{{item.id === 'citation'}}">
          <text>{{item.count}} 篇文献</text>
        </view>
        <view class="card-urgent-badge" wx:if="{{item.urgent > 0}}">{{item.urgent}}</view>
      </view>
    </view>
  </view>

  <!-- 即将到来 -->
  <view class="upcoming-frame">
    <view class="section-title">
      <text>近期截止</text>
      <view class="more-link" wx:if="{{!loading}}" bindtap="goToCalendar">
        <text>查看日历</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 加载骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton-list">
      <view class="skeleton-item" wx:for="{{3}}" wx:key="*this">
        <view class="skeleton-circle skeleton-pulse"></view>
        <view class="skeleton-content">
          <view class="skeleton-line skeleton-pulse" style="width:70%"></view>
          <view class="skeleton-line skeleton-pulse" style="width:50%;height:20rpx"></view>
        </view>
      </view>
    </view>

    <view wx:elif="{{upcomingItems.length === 0}}" class="empty-hint">
      <text>🎉 暂无即将到期的事项</text>
    </view>

    <view wx:else>
      <view
        class="upcoming-item {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : 'type-green'}} {{item.urgent ? 'urgent' : ''}}"
        wx:for="{{upcomingItems}}"
        wx:key="_id"
        bindtap="goToItem"
        data-page="{{item.pagePath}}"
        data-id="{{item._id}}"
        data-title="{{item.title}}"
      >
        <view class="upcoming-icon">{{item.iconEmoji}}</view>
        <view class="upcoming-info">
          <view class="upcoming-title">
            <text class="type-label">{{item.typeLabel}}</text>
            <text>{{item.title}}</text>
          </view>
          <view class="upcoming-meta">
            <text class="date">{{item.deadlineLabel}}</text>
            <text class="countdown {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
