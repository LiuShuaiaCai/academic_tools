/* pages/home/home.wxss */
page { background: #F6F6F6; }

.home-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ========== Header ========== */
.home-header {
  position: relative;
  min-height: 340rpx;
  overflow: visible;
  z-index: 2;
}

/* 轮播容器 */
.header-swiper-container {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}
.header-swiper {
  width: 100%;
  height: 100%;
}
.header-banner-img {
  width: 100%;
  height: 100%;
  display: block;
}
.header-banner-text {
  position: absolute;
  bottom: 60rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.header-banner-title {
  font-size: 50rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.4);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.header-banner-subtitle {
  font-size: 35rpx;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 默认渐变背景（无 banner 时） */
.header-default-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
}

/* 内容覆盖层（始终在最上层） */
.header-overlay {
  position: relative;
  z-index: 2;
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(180deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.05) 60%, transparent 100%);
}

.header-left { display: flex; flex-direction: column; gap: 4rpx; }

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.header-right {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.header-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  position: relative;
}

.notif-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* ========== Banner 分享按钮 ========== */
.header-share-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  margin: 0;
  z-index: 3;
  box-sizing: border-box;
  line-height: 1;
}

/* 去除 button 默认边框 */
.header-share-overlay::after {
  border: none;
  border-radius: 0;
}

.share-hover {
  background: rgba(255, 255, 255, 0.08) !important;
}

.header-share-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
  pointer-events: none;
}

.share-icon {
  font-size: 26rpx;
  color: #fff;
  line-height: 1;
}

.share-label {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1;
}

/* ========== Stats Frame ========== */
.stats-frame {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: -20rpx 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 10;
}

.stats-frame-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stats-frame-title .more-link {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 500;
  color: #2563eb;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #DBEAFE;
}

.stats-frame-title .arrow { font-size: 20rpx; }

/* ========== Stats Grid ========== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stats-card {
  background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0,0,0,0.04);
}

/* 顶部彩色条 */
.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

.stats-card.blue-accent::before { background: #2563eb; }
.stats-card.red-accent::before { background: #EF4444; }
.stats-card.green-accent::before { background: #10B981; }
.stats-card.orange-accent::before { background: #F59E0B; }

.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.card-icon.blue-bg { background: #DBEAFE; color: #2563eb; }
.card-icon.red-bg { background: #FEE2E2; color: #EF4444; }
.card-icon.green-bg { background: #D1FAE5; color: #10B981; }
.card-icon.orange-bg { background: #FEF3C7; color: #F59E0B; }

/* 空工具状态 */
.empty-tools {
  text-align: center;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-tools-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.empty-tools-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.empty-tools-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 更多工具卡片 */
.more-card {
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  border: 1rpx solid #BFDBFE;
  cursor: pointer;
}

.more-bg {
  background: #BFDBFE;
  color: #2563eb;
}

.total-count {
  font-size: 22rpx;
  font-weight: 600;
  color: #2563eb;
}

/* 更多工具卡片 - 红点/数量徽章 */
.red-dot {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

.card-info { }

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-stats-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.card-urgent-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 50%;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

/* ========== Upcoming Frame ========== */
.upcoming-frame {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title .more-link {
  font-size: 24rpx;
  font-weight: 500;
  color: #2563eb;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* ========== Upcoming Items ========== */
.upcoming-item {
  background: linear-gradient(135deg, #fff 0%, #fafbfc 100%);
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 2rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
  position: relative;
  overflow: hidden;
}

.upcoming-item:last-child { margin-bottom: 0; }

/* 左侧彩色条 */
.upcoming-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 10rpx 0 0 10rpx;
}

.upcoming-item.type-blue::before { background: #2563eb; }
.upcoming-item.type-red::before { background: #EF4444; }
.upcoming-item.type-green::before { background: #10B981; }
.upcoming-item.type-purple::before { background: #8B5CF6; }

.upcoming-item.urgent { }

.upcoming-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

/* 投稿 - 蓝色 */
.upcoming-item.type-blue .upcoming-icon {
  background: #DBEAFE;
}

/* 审稿 - 红色 */
.upcoming-item.type-red .upcoming-icon {
  background: #FEE2E2;
}

/* 会议 - 绿色 */
.upcoming-item.type-green .upcoming-icon {
  background: #D1FAE5;
}

/* 任务 - 紫色 */
.upcoming-item.type-purple .upcoming-icon {
  background: #EDE9FE;
}

.upcoming-info {
  flex: 1;
  min-width: 0;
}

.upcoming-title {
  font-weight: 500;
  font-size: 28rpx;
  color: #111827;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.type-label {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: #F3F4F6;
  color: #6B7280;
  flex-shrink: 0;
}

.upcoming-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.upcoming-meta .date {
  color: #6B7280;
}

.upcoming-meta .countdown {
  font-weight: 600;
}

.upcoming-meta .countdown.urgent { color: #EF4444; }
.upcoming-meta .countdown.normal { color: #10B981; }

/* ========== 空状态 ========== */
.empty-hint {
  text-align: center;
  padding: 60rpx 40rpx;
  font-size: 28rpx;
  color: #6B7280;
  background: #fff;
  border-radius: 16rpx;
}

/* ========== 签到弹窗 ========== */
.signin-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 80rpx;
}

.signin-modal {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx 48rpx;
  text-align: center;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}

.signin-modal-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.signin-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.signin-modal-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.7;
  margin-bottom: 36rpx;
}

.signin-modal-points {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.points-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #F59E0B;
}

.points-unit {
  font-size: 28rpx;
  color: #F59E0B;
  margin-left: 8rpx;
}

.signin-modal-streak {
  font-size: 24rpx;
  color: #10B981;
  background: #D1FAE5;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  display: inline-block;
}

.signin-modal-desc.highlight {
  color: #10B981;
  font-weight: 500;
}

.signin-modal-btn {
  display: inline-block;
  background: linear-gradient(135deg, #FBBF24, #F59E0B);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 80rpx;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(245,158,11,0.35);
}
.signin-modal-btn:active { opacity: 0.85; transform: scale(0.97); }

.signin-modal-skip {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}
.signin-modal-skip:active { color: #6B7280; }

/* ========== 骨架屏 ========== */
.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.skeleton-card {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.skeleton-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #E5E7EB;
  margin-bottom: 16rpx;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-bottom: 10rpx;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border-radius: 10rpx;
}

.skeleton-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E5E7EB;
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
}

.skeleton-pulse {
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}
