/* pages/specialIssue/detail/detail.wxss V5 */

/* ========== 主题色变量 ========== */
page {
  --primary-color: #10B981;
  --primary-dark: #059669;
  --primary-light: #ECFDF5;
  --primary-shadow: rgba(16, 185, 129, 0.4);
}

/* ========== 基础布局 ========== */
.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* ========== 卡片通用 ========== */
.result-card {
  margin: 0 24rpx 24rpx;
  background: #FFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  flex: 1;
}

.topic-heat-badge {
  margin-left: auto;
  margin-right: 12rpx;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  color: #92400E;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 20rpx;
}

.editor-count, .article-count {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 4rpx;
}

/* ========== 语言切换 ========== */
.lang-toggle {
  display: flex;
  align-items: center;
  background: #F3F4F6;
  border-radius: 20rpx;
  padding: 4rpx;
  margin-right: 0;
}

.lang-opt {
  font-size: 22rpx;
  color: #6B7280;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.lang-opt.lang-on {
  background: var(--primary-color);
  color: #FFF;
  font-weight: 600;
}

.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin-top: 24rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid var(--primary-color);
  padding-left: 14rpx;
}

/* ========== 话题卡片 ========== */
.topic-title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.topic-summary-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.7;
  text-align: justify;
}

.keywords-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  padding: 8rpx 20rpx;
  background: #EEF2FF;
  color: #4F46E5;
  font-size: 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid #C7D2FE;
}

/* ========== 来源文章 ========== */
.article-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.article-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.article-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #F3F4F6;
  color: #6B7280;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.article-info {
  flex: 1;
  min-width: 0;
}

.article-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  font-size: 22rpx;
  color: #374151;
  line-height: 1.6;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.meta-item {
  color: #374151;
}

.meta-sep {
  margin: 0 8rpx;
  color: #D1D5DB;
}

/* ========== 客编卡片 ========== */
.editor-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.editor-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.editor-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.editor-avatar {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.editor-main {
  flex: 1;
}

.editor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.editor-institution {
  font-size: 24rpx;
  color: #6B7280;
}

.editor-expertise {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.expertise-tag {
  font-size: 22rpx;
  color: #4F46E5;
  background: #EEF2FF;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.editor-metrics {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.metric-item {
  flex: 1;
  text-align: center;
}

.metric-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.metric-label {
  font-size: 20rpx;
  color: #9CA3AF;
}

.editor-chart-section {
  margin-top: 16rpx;
}

.chart-subtitle {
  font-size: 24rpx;
  font-weight: 600;
  color: #6B7280;
  margin-bottom: 8rpx;
  padding-left: 4rpx;
}

.chart-wrap {
  width: 100%;
  height: 380rpx;
}

.chart-wrap-sm {
  height: 340rpx;
}

/* ========== 操作卡片 ========== */
.action-card {
  text-align: center;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: #FFF;
  flex-direction: column;
}

.action-hint {
  display: block;
  font-size: 20rpx;
  font-weight: 400;
  margin-top: 4rpx;
  opacity: 0.8;
}

.action-btn.outline {
  background: #FFF;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.history-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
}

.history-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.history-link {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* ========== 加载/错误状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #EF4444;
  margin-bottom: 24rpx;
  text-align: center;
}

.error-retry {
  padding: 16rpx 48rpx;
  background: var(--primary-color);
  color: #FFF;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* ========== 来源文章 DOI / 被引可点击 ========== */
.meta-cite {
  color: #3B82F6;
  font-weight: 600;
}
.meta-doi {
  color: #3B82F6;
  font-size: 22rpx;
}

/* ========== 引用统计弹窗 ========== */
.cite-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.cite-modal-content {
  width: 80%;
  max-width: 640rpx;
  background: #FFF;
  border-radius: 20rpx;
  overflow: hidden;
}

.cite-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.cite-modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.cite-modal-close {
  font-size: 40rpx;
  color: #9CA3AF;
  padding: 0 8rpx;
}

.cite-modal-body {
  padding: 32rpx;
}

.cite-chart {
  height: 320rpx;
}

.cite-chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 260rpx;
  padding: 0 8rpx;
}

.cite-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.cite-bar-track {
  width: 40rpx;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  background: #F3F4F6;
  border-radius: 8rpx 8rpx 0 0;
  overflow: hidden;
}

.cite-bar {
  width: 100%;
  background: linear-gradient(180deg, var(--primary-color), var(--primary-dark));
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s ease;
}

.cite-bar-label {
  font-size: 20rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

.cite-bar-value {
  font-size: 20rpx;
  color: #1F2937;
  font-weight: 600;
  margin-top: 2rpx;
}

.cite-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* ========== 方向选择面板 ========== */
.direction-panel {
  padding: 24rpx;
}

.direction-header {
  margin-bottom: 32rpx;
  text-align: center;
  padding: 28rpx 0 16rpx;
}

.direction-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.direction-subtitle {
  font-size: 26rpx;
  color: #6B7280;
  background: linear-gradient(90deg, #EEF2FF, #F3F4F6);
  display: inline-block;
  padding: 10rpx 32rpx;
  border-radius: 40rpx;
}

/* ---- 趋势对比图表 ---- */
.compare-section {
  background: #FFF;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.compare-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.compare-chart {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.compare-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.compare-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #374151;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compare-bar-wrap {
  flex: 1;
  height: 28rpx;
  background: #F3F4F6;
  border-radius: 14rpx;
  overflow: hidden;
}

.compare-bar {
  height: 100%;
  border-radius: 14rpx;
  transition: width 0.4s ease;
}

.compare-bar-0 { background: linear-gradient(90deg, #DC2626, #EF4444); }
.compare-bar-1 { background: linear-gradient(90deg, #EA580C, #F97316); }
.compare-bar-2 { background: linear-gradient(90deg, #CA8A04, #EAB308); }
.compare-bar-3 { background: linear-gradient(90deg, #2563EB, #3B82F6); }
.compare-bar-4 { background: linear-gradient(90deg, #7C3AED, #8B5CF6); }

.compare-value {
  width: 140rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}

.compare-heat {
  font-size: 22rpx;
  font-weight: 600;
  color: #DC2626;
}

.heat-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 40rpx;
  background: #FEF3C7;
  color: #D97706;
  font-size: 26rpx;
  font-weight: 700;
}

.compare-papers {
  font-size: 20rpx;
  color: #059669;
}

.direction-list {
  margin-bottom: 24rpx;
}

.direction-card {
  background: #FFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  transition: all 0.2s;
}

.direction-card-main {
  padding: 30rpx 24rpx;
}

.direction-card-header {
  display: flex;
  align-items: flex-start;
}

.direction-heat-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 88rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
}

/* 紧凑指标行 */
.direction-metrics-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: nowrap;
}

.direction-heat-badge-sm {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 2rpx 12rpx 2rpx 8rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.heat-num-sm {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFF;
  line-height: 1;
}

.heat-label-sm {
  font-size: 18rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  background: #F3F4F6;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #374151;
  white-space: nowrap;
  flex-shrink: 0;
}

.meta-pill-icon {
  margin-right: 2rpx;
  font-style: normal;
}

.meta-cite-pill {
  background: #FEF2F2;
  color: #DC2626;
}

.meta-fwci-pill {
  background: #EFF6FF;
  color: #2563EB;
}

.heat-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFF;
  line-height: 1.2;
}

.heat-label {
  display: block;
  font-size: 18rpx;
  color: rgba(255,255,255,0.85);
}

.direction-info {
  flex: 1;
  min-width: 0;
}

.direction-name {
  font-size: 29rpx;
  font-weight: 600;
  color: #1F2937;
  display: flex;
  align-items: center;
  line-height: 1.3;
}

.topic-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFF;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.direction-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6B7280;
  align-items: center;
}

.meta-papers {
  color: #059669;
  font-weight: 500;
}

.meta-cite {
  color: #DC2626;
  font-weight: 500;
}

.meta-fwci {
  color: #2563EB;
  font-weight: 500;
}

.meta-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 20rpx;
}

.kw-tag {
  display: inline-block;
  padding: 2rpx 14rpx;
  background: #F0F0FF;
  color: #4338CA;
  border-radius: 16rpx;
  font-size: 20rpx;
  line-height: 1.6;
}

.direction-select-btn {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: #FFF;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-left: 12rpx;
}

/* 方向按钮通用 */
.direction-btn {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-left: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

/* 生成中按钮 */
.direction-btn-generating {
  background: #FEF3C7;
  color: #92400E;
  padding: 8rpx 14rpx;
}

.inner-mini-bar {
  width: 100%;
  height: 8rpx;
  background: #FDE68A;
  border-radius: 4rpx;
  margin-bottom: 4rpx;
  overflow: hidden;
}

.inner-mini-fill {
  height: 100%;
  background: #F59E0B;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.inner-mini-label {
  font-size: 20rpx;
}

/* 已完成按钮 */
.direction-btn-completed {
  background: #D1FAE5;
  color: #059669;
}

/* 失败按钮 */
.direction-btn-failed {
  background: #FEE2E2;
  color: #DC2626;
}

/* ========== 进度弹窗（复用列表页样式） ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  max-height: 80vh;
  background: #FFF;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.modal-close {
  font-size: 36rpx;
  color: #9CA3AF;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  overflow-y: auto;
  flex: 1;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.step-item:last-child {
  border-bottom: none;
}

.step-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.step-label {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
}

.step-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.step-status.done {
  background: #D1FAE5;
  color: #059669;
}

.step-status.running {
  background: #FEF3C7;
  color: #92400E;
}

.step-status.failed {
  background: #FEE2E2;
  color: #DC2626;
}

.step-status.pending {
  background: #F3F4F6;
  color: #9CA3AF;
}

.modal-footer {
  padding: 16rpx 32rpx 32rpx;
  border-top: 1rpx solid #F3F4F6;
}

.modal-btn.cancel.full {
  width: 100%;
  padding: 20rpx;
  text-align: center;
  background: #F3F4F6;
  color: #374151;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

/* 展开详情 */
.direction-detail {
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F3F4F6;
}

.detail-section {
  margin-bottom: 36rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.6;
}

.detail-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 22rpx 0;
}

.detail-keyword-tag {
  padding: 6rpx 16rpx;
  background: #EEF2FF;
  color: #4F46E5;
  font-size: 22rpx;
  border-radius: 40rpx;
}

.detail-papers {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 16rpx;
}

.detail-paper-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #E5E7EB;
}

.detail-paper-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-paper-title {
  flex: 1;
  font-size: 24rpx;
  color: #1F2937;
  line-height: 1.4;
  margin-right: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.detail-paper-cite {
  font-size: 22rpx;
  color: #DC2626;
  font-weight: 500;
  flex-shrink: 0;
}

/* ========== 多维指标对比表 ========== */
.metrics-table {
  margin-top: 24rpx;
  background: #F9FAFB;
  border-radius: 14rpx;
  padding: 20rpx 20rpx 16rpx;
}

.metrics-table-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 18rpx;
}

.metrics-table-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #E5E7EB;
}

.metrics-table-row:last-child {
  border-bottom: none;
}

.metrics-table-head {
  font-weight: 700;
  color: #6B7280;
  font-size: 22rpx;
  background: #F3F4F6;
  border-radius: 6rpx;
  padding: 8rpx 0;
  margin-bottom: 4rpx;
}

.metrics-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

.metrics-cell-label {
  flex: 1.2;
  text-align: left;
  color: #6B7280;
  font-weight: 600;
  padding-left: 8rpx;
}

/* ========== 趋势指标网格 ========== */
.trend-metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  overflow: hidden;
}

.trend-metric-card {
  flex: 1;
  min-width: calc(50% - 6rpx);
  max-width: 100%;
  text-align: center;
  padding: 18rpx 10rpx;
  background: linear-gradient(135deg, #F9FAFB, #FFF);
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.trend-metric-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.trend-metric-name {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ========== 逐年趋势柱状图 ========== */
.trend-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 260rpx;
  padding: 16rpx 8rpx 0;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.trend-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.trend-bar-val {
  font-size: 20rpx;
  color: #6B7280;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.trend-bar-track {
  width: 36rpx;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
  background: #F3F4F6;
  border-radius: 4rpx 4rpx 0 0;
  overflow: hidden;
}

.trend-bar-fill {
  width: 100%;
  background: linear-gradient(180deg, var(--primary-color), var(--primary-dark));
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.4s ease;
  min-height: 4rpx;
}

.trend-bar-year {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.direction-footer {
  margin-top: 16rpx;
}

/* ========== 方向详情弹窗 ========== */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.detail-modal-content {
  width: 100%;
  max-height: 85vh;
  background: #F5F7FA;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.detail-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #FFF;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
  box-sizing: border-box;
}

.detail-modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.detail-modal-close {
  font-size: 44rpx;
  color: #9CA3AF;
  padding: 0 8rpx;
  line-height: 1;
}

.detail-modal-body {
  width: 100%;
  box-sizing: border-box;
  flex: 1;
  padding: 24rpx 20rpx 32rpx;
  overflow-y: auto;
  overflow-x: hidden;
}

.detail-modal-footer {
  padding: 20rpx 32rpx;
  background: #FFF;
  border-top: 1rpx solid #F0F0F0;
  flex-shrink: 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.detail-modal-footer .action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== V6: 方案操作按钮区 ========== */
.scheme-action-area {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F3F4F6;
}

.scheme-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.scheme-btn-generate {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: #FFF;
  box-shadow: 0 4rpx 14rpx var(--primary-shadow);
}

.scheme-btn-generate:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.scheme-btn-progress {
  background: #FFF7ED;
  border: 1rpx solid #FED7AA;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 28rpx;
}

.scheme-progress-bar-wrap {
  width: 100%;
  height: 8rpx;
  background: #FED7AA;
  border-radius: 4rpx;
  overflow: hidden;
}

.scheme-progress-bar {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #F97316, #EA580C);
}

.scheme-progress-anim {
  width: 70%;
  animation: schemeBarPulse 2s ease-in-out infinite;
}

@keyframes schemeBarPulse {
  0%, 100% { width: 20%; }
  50% { width: 80%; }
}

.scheme-progress-text {
  font-size: 22rpx;
  color: #EA580C;
  font-weight: 500;
}

.scheme-btn-row {
  display: flex;
  gap: 12rpx;
}

.scheme-btn-done {
  flex: 1;
  background: linear-gradient(135deg, #10B981, #059669);
  color: #FFF;
  box-shadow: 0 4rpx 14rpx rgba(16, 185, 129, 0.3);
}

.scheme-btn-done:active {
  opacity: 0.85;
}

.scheme-btn-new {
  background: #FFF;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  padding: 18rpx 20rpx;
}

.scheme-btn-new:active {
  background: var(--primary-light);
}

.scheme-btn-retry {
  background: #FFF;
  color: #DC2626;
  border: 2rpx solid #FECACA;
  box-shadow: 0 2rpx 10rpx rgba(220, 38, 38, 0.1);
}

.scheme-btn-retry:active {
  background: #FEF2F2;
}

/* 已生成方案列表项 */
.scheme-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.scheme-list-item:last-child {
  border-bottom: none;
}

.scheme-list-title {
  flex: 1;
  font-size: 24rpx;
  color: #1F2937;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scheme-list-status {
  flex-shrink: 0;
  font-size: 28rpx;
}

/* ========== V6: 机构履历 ========== */
.editor-affiliations {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  border: 1rpx solid #E2E8F0;
}

.affiliations-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.affiliation-item {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #E2E8F0;
}

.affiliation-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.affiliation-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #334155;
}

.affiliation-years {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
}

.aff-year-tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  background: #DBEAFE;
  color: #1D4ED8;
  font-size: 18rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.affiliation-meta {
  display: flex;
  gap: 8rpx;
  margin-left: auto;
}

.aff-country {
  font-size: 18rpx;
  color: #64748B;
  padding: 2rpx 8rpx;
  background: #F1F5F9;
  border-radius: 4rpx;
}

.aff-type {
  font-size: 18rpx;
  color: #059669;
  padding: 2rpx 8rpx;
  background: #ECFDF5;
  border-radius: 4rpx;
}

/* ========== V6: 客编图表双栏 ========== */
.editor-mini-charts {
  display: flex;
  gap: 16rpx;
}

.mini-chart-item {
  flex: 1;
  min-width: 0;
}

.no-data {
  font-size: 24rpx;
  color: #9CA3AF;
}
