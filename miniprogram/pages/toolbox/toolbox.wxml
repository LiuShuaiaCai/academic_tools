<!--pages/toolbox/toolbox.wxml-->
<view class="home-page">
  <!-- 顶部 Header -->
  <view class="home-header">
    <view class="header-left">
      <view class="header-title">工具箱</view>
      <view class="header-subtitle">已开启 {{enabledCount}} 个工具</view>
    </view>
    <view class="header-right">
      <view class="header-btn" bindtap="goToToolManager">
        <text>⚙️</text>
      </view>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="stats-overview" wx:if="{{!loading && tools.length > 0}}">
    <view class="overview-item">
      <view class="overview-num">{{totalCount}}</view>
      <view class="overview-label">总任务数</view>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <view class="overview-num urgent">{{totalUrgent}}</view>
      <view class="overview-label">紧急待办</view>
    </view>
  </view>

  <!-- 统计概览骨架屏 -->
  <view class="stats-overview skeleton-overview" wx:if="{{loading}}">
    <view class="overview-item">
      <view class="skeleton-num skeleton-pulse"></view>
      <view class="skeleton-label skeleton-pulse"></view>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <view class="skeleton-num skeleton-pulse"></view>
      <view class="skeleton-label skeleton-pulse"></view>
    </view>
  </view>

  <!-- 工作台 -->
  <view class="stats-frame">
    <view class="stats-frame-title" wx:if="{{!loading}}">
      <text>🧰</text>
      <text>我的工具</text>
    </view>
    <view class="stats-frame-title skeleton-title" wx:if="{{loading}}">
      <view class="skeleton-title-text skeleton-pulse"></view>
    </view>

    <!-- 加载骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton-grid">
      <view class="skeleton-card" wx:for="{{4}}" wx:key="*this">
        <view class="skeleton-icon skeleton-pulse"></view>
        <view class="skeleton-line skeleton-pulse" style="width:60%"></view>
        <view class="skeleton-line skeleton-pulse" style="width:40%;height:20rpx"></view>
      </view>
    </view>

    <!-- 空状态：没有启用任何工具 -->
    <view wx:elif="{{tools.length === 0}}" class="empty-tools" bindtap="goToToolManager">
      <text class="empty-tools-icon">🧰</text>
      <text class="empty-tools-text">你还没有添加工具</text>
      <text class="empty-tools-sub">去工具管理开启需要的工具吧</text>
    </view>

    <!-- 工具网格 -->
    <view wx:else class="stats-grid" id="statsGrid">
      <view
        class="stats-card {{item.color}}-accent"
        wx:for="{{tools}}"
        wx:key="id"
        bindtap="goToTool"
        data-page="{{item.pagePath}}"
      >
        <view class="card-icon {{item.color}}-bg">{{item.iconEmoji}}</view>
        <view class="card-info">
          <view class="card-title">{{item.name}}</view>
          <view class="card-desc">{{item.desc}}</view>
        </view>
        <view class="card-stats" wx:if="{{item.isTaskType}}">
          <text>{{item.count}} 任务待完成</text>
        </view>
        <view class="card-stats" wx:elif="{{item.id === 'archive'}}">
          <text>{{item.count}} 份资料</text>
        </view>
        <view class="card-urgent-badge" wx:if="{{item.urgent > 0}}">{{item.urgent}}</view>
      </view>
    </view>
  </view>
</view>
