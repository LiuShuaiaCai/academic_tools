/* pages/toolbox/toolbox.wxss - 与首页一致的样式 */
page { background: #F6F6F6; }

.home-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ========== Header ========== */
.home-header {
  background: linear-gradient(160deg, #3b82f6 0%, #2563eb 40%, #1d4ed8 100%);
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: visible;
  z-index: 2;
}
.home-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.home-header::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.header-right {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.header-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  position: relative;
}

/* ========== Stats Frame ========== */
.stats-frame {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: -20rpx 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.stats-frame-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* ========== Stats Grid ========== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stats-card {
  background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0,0,0,0.04);
}

/* 顶部彩色条（颜色由 inline style 动态注入） */
.card-accent-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

/* 图标颜色由 inline style 动态注入 */
.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}


.card-info { }

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-urgent-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 50%;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

/* 空工具状态 */
.empty-tools {
  text-align: center;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-tools-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.empty-tools-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.empty-tools-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ========== 统计概览 ========== */
.stats-overview {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: -30rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 10;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 4rpx;
}

.overview-num.urgent {
  color: #EF4444;
}

.overview-label {
  font-size: 24rpx;
  color: #6B7280;
}

.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E7EB;
}

/* ========== 骨架屏 ========== */
.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.skeleton-card {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.skeleton-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #E5E7EB;
  margin-bottom: 16rpx;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-bottom: 10rpx;
}

.skeleton-pulse {
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}

/* 统计概览骨架 */
.skeleton-overview .skeleton-num {
  width: 60rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: #E5E7EB;
  margin: 0 auto 8rpx;
}

.skeleton-overview .skeleton-label {
  width: 80rpx;
  height: 24rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin: 0 auto;
}

/* 标题骨架 */
.skeleton-title-text {
  width: 140rpx;
  height: 28rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
}
