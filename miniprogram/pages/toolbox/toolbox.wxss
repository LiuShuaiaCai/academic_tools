/* pages/toolbox/toolbox.wxss - 与首页一致的样式 */
page { background: #F6F6F6; }

.home-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ========== Header ========== */
.home-header {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.header-right {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.header-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  position: relative;
}

/* ========== Stats Frame ========== */
.stats-frame {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: -20rpx 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.stats-frame-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* ========== Stats Grid ========== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stats-card {
  background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0,0,0,0.04);
}

/* 顶部彩色条 */
.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

.stats-card.blue-accent::before { background: #2563eb; }
.stats-card.red-accent::before { background: #EF4444; }
.stats-card.green-accent::before { background: #10B981; }
.stats-card.orange-accent::before { background: #F59E0B; }
.stats-card.purple-accent::before { background: #7C3AED; }

.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.card-icon.blue-bg { background: #DBEAFE; color: #2563eb; }
.card-icon.red-bg { background: #FEE2E2; color: #EF4444; }
.card-icon.green-bg { background: #D1FAE5; color: #10B981; }
.card-icon.orange-bg { background: #FEF3C7; color: #F59E0B; }
.card-icon.purple-bg { background: #EDE9FE; color: #7C3AED; }

.card-info { }

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-urgent-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 50%;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

/* 空工具状态 */
.empty-tools {
  text-align: center;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-tools-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.empty-tools-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.empty-tools-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ========== 统计概览 ========== */
.stats-overview {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 4rpx;
}

.overview-num.urgent {
  color: #EF4444;
}

.overview-label {
  font-size: 24rpx;
  color: #6B7280;
}

.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E7EB;
}

/* ========== 骨架屏 ========== */
.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.skeleton-card {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.skeleton-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #E5E7EB;
  margin-bottom: 16rpx;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-bottom: 10rpx;
}

.skeleton-pulse {
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}
