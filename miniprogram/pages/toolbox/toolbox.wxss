/* pages/toolbox/toolbox.wxss */
page { background: #F6F6F6; }
.toolbox-page { padding: 0 0 120rpx 0; }

.toolbox-header {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbox-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.toolbox-meta {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 16rpx;
}

.count { color: #fff; font-weight: 600; }

.count { color: #2563eb; font-weight: 600; }

.manage-btn {
  font-size: 26rpx;
  color: #fff;
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 20rpx;
  background: rgba(255,255,255,0.2);
}

.tool-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx;
}

.tool-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
}

.tool-card.disabled {
  opacity: 0.5;
}

.tool-card.coming-soon {
  opacity: 0.7;
}

.tool-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.tool-card-icon.blue { background: #DBEAFE; color: #2563eb; }
.tool-card-icon.red { background: #FEE2E2; color: #EF4444; }
.tool-card-icon.green { background: #D1FAE5; color: #10B981; }
.tool-card-icon.orange { background: #FEF3C7; color: #F59E0B; }
.tool-card-icon.purple { background: #EDE9FE; color: #7C3AED; }

.tool-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.tool-card-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 6rpx;
}

.tool-card-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.soon-tag {
  position: absolute;
  top: 20rpx;
  right: 0;
  background: #FEF3C7;
  color: #F59E0B;
  font-size: 18rpx;
  padding: 4rpx 16rpx 4rpx 12rpx;
  border-radius: 20rpx 0 0 20rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #9CA3AF;
  font-size: 28rpx;
}

.empty-box {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #374151;
  display: block;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
}
