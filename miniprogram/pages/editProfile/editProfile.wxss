/* pages/editProfile/editProfile.wxss */
.edit-profile-page { padding-bottom: 120rpx; background: #F6F6F6; }

/* 头像区域 */
.avatar-section {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  padding: 60rpx 0 80rpx;
  text-align: center;
}

.avatar-wrapper {
  position: relative;
  display: inline-block;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-emoji {
  font-size: 80rpx;
  line-height: 160rpx;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #F59E0B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 3rpx solid #fff;
}

.avatar-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.form-input {
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1F2937;
  width: 100%;
  box-sizing: border-box;
  min-height: 75rpx;
  line-height: 75rpx;
}

.form-input:focus {
  border-color: #2563eb;
  background: #fff;
}

.form-input::placeholder {
  color: #9CA3AF;
}

.form-picker {
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1F2937;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 75rpx;
  line-height: 75rpx;
}

.picker-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

/* 提交区域 */
.submit-section {
  padding: 32rpx 24rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #9CA3AF;
}

.submit-tip {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #F59E0B;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tip-icon {
  font-size: 28rpx;
}
