<!--pages/editProfile/editProfile.wxml-->
<view class="edit-profile-page">
  <!-- 头像区域 -->
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="chooseAvatar">
      <image class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{isWechatAvatar}}"></image>
      <text class="avatar-emoji" wx:else>{{avatarUrl}}</text>
      <view class="avatar-edit-icon">📷</view>
    </view>
    <view class="avatar-tip">点击更换头像</view>
  </view>

  <!-- 资料表单 -->
  <view class="form-section">
    <view class="form-title">基本信息</view>
    
    <view class="form-item">
      <view class="form-label">昵称</view>
      <input class="form-input" value="{{profile.nickname}}" placeholder="请输入昵称" bindinput="onInput" data-field="nickname"/>
    </view>

    <view class="form-item">
      <view class="form-label">邮箱</view>
      <input class="form-input" type="text" value="{{profile.email}}" placeholder="your@email.com" bindinput="onInput" data-field="email"/>
    </view>

    <view class="form-item">
      <view class="form-label">ORCID</view>
      <input class="form-input" value="{{profile.orcid}}" placeholder="0000-0000-0000-0000" bindinput="onInput" data-field="orcid"/>
    </view>

    <view class="form-item">
      <view class="form-label">H-index</view>
      <input class="form-input" type="number" value="{{profile.hIndex}}" placeholder="请输入H-index" bindinput="onInput" data-field="hIndex"/>
    </view>

    <view class="form-item">
      <view class="form-label">H-index URL</view>
      <input class="form-input" value="{{profile.hIndexUrl}}" placeholder="https://scholar.google.com/..." bindinput="onInput" data-field="hIndexUrl"/>
    </view>

    <view class="form-item">
      <view class="form-label">个人主页</view>
      <input class="form-input" value="{{profile.homepage}}" placeholder="https://..." bindinput="onInput" data-field="homepage"/>
    </view>
  </view>

  <view class="form-section">
    <view class="form-title">学术信息</view>
    
    <view class="form-item">
      <view class="form-label">职称</view>
      <picker mode="selector" range="{{titleOptions}}" bindchange="onPickerChange" data-field="title">
        <view class="form-picker">
          <text>{{profile.title || '请选择职称'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">研究领域</view>
      <input class="form-input" value="{{profile.researchField}}" placeholder="如：计算机科学、人工智能" bindinput="onInput" data-field="researchField"/>
    </view>
  </view>

  <view class="form-section">
    <view class="form-title">机构信息</view>
    
    <view class="form-item">
      <view class="form-label">机构名称</view>
      <input class="form-input" value="{{profile.institution}}" placeholder="请输入您的机构名称" bindinput="onInput" data-field="institution"/>
    </view>

    <view class="form-item">
      <view class="form-label">所在地</view>
      <picker mode="region" bindchange="onRegionChange" value="{{region}}">
        <view class="form-picker">
          <text>{{regionText || '请选择省/市/区'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="submit-section">
    <button class="submit-btn {{saving ? 'disabled' : ''}}" bindtap="saveProfile" disabled="{{saving}}">
      <text wx:if="{{saving}}">保存中...</text>
      <text wx:else>保存资料</text>
    </button>
    <view class="submit-tip" wx:if="{{!profile.profileCompleted}}">
      <text class="tip-icon">🎁</text>
      <text>首次完善资料可获得50积分奖励</text>
    </view>
  </view>
</view>
