/* pages/credits/credits.wxss */
page { background: #F6F6F6; }
.credits-page { padding-bottom: 40rpx; }

/* ========== 顶部积分卡片 ========== */
.credits-header {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  color: #fff;
}

.credits-balance { text-align: center; margin-bottom: 24rpx; }
.balance-label { font-size: 26rpx; opacity: 0.85; }
.balance-num { font-size: 72rpx; font-weight: 700; margin: 8rpx 0; }
.balance-hint { font-size: 22rpx; opacity: 0.7; }

.signin-area { display: flex; align-items: center; justify-content: center; gap: 20rpx; }

.signin-btn {
  padding: 12rpx 40rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  backdrop-filter: blur(4px);
}
.signin-btn.disabled { opacity: 0.5; }
.signin-btn:active { opacity: 0.8; }

.signin-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  opacity: 0.9;
}
.signin-icon { font-size: 28rpx; }

.signin-streak { font-size: 22rpx; opacity: 0.8; }

/* ========== 积分规则 ========== */
.rules-section {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.rules-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}
.rules-title { font-size: 28rpx; font-weight: 600; color: #374151; }
.rules-arrow { font-size: 32rpx; color: #9CA3AF; transition: transform 0.3s; }
.rules-arrow.open { transform: rotate(90deg); }

.rules-content { padding: 0 28rpx 24rpx; }

.rule-group { margin-bottom: 16rpx; }
.rule-group:last-child { margin-bottom: 0; }
.rule-group-title {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.rule-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}
.rule-label { font-size: 26rpx; color: #374151; }
.rule-points { font-size: 26rpx; font-weight: 600; }
.rule-points.earn { color: #10B981; }
.rule-points.spend { color: #EF4444; }

/* ========== 积分明细 ========== */
.records-section { margin: 0 24rpx; }

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.records-loading, .records-empty {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #9CA3AF;
}

.empty-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; }

.records-list { display: flex; flex-direction: column; gap: 1rpx; }

.record-item {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.record-item:first-child { border-radius: 16rpx 16rpx 0 0; }
.record-item:last-child { border-radius: 0 0 16rpx 16rpx; }
.record-item:only-child { border-radius: 16rpx; }

.record-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }

.record-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}
.record-icon.earn { background: #D1FAE5; color: #10B981; }
.record-icon.spend { background: #FEE2E2; color: #EF4444; }

.record-info { flex: 1; min-width: 0; }
.record-desc {
  font-size: 28rpx;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.record-time { font-size: 22rpx; color: #9CA3AF; margin-top: 4rpx; }

.record-points { font-size: 32rpx; font-weight: 700; flex-shrink: 0; margin-left: 16rpx; }
.record-points.earn { color: #10B981; }
.record-points.spend { color: #EF4444; }

/* ========== 加载更多 ========== */
.load-more, .no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #9CA3AF;
}
.load-more text { padding: 12rpx 32rpx; }