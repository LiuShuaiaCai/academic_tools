/* pages/toolManager/toolManager.wxss */
page { background: #F6F6F6; }
.tm-page { padding: 24rpx; }
.tm-desc { font-size: 26rpx; color: #6B7280; margin-bottom: 24rpx; }
.tool-group { background: #fff; border-radius: 20rpx; overflow: hidden; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.group-title { font-size: 26rpx; font-weight: 600; color: #374151; padding: 24rpx; border-bottom: 1rpx solid #F3F4F6; background: #FAFAFA; }
.tool-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #F3F4F6; }
.tool-item:last-child { border-bottom: none; }
.tool-item-icon { width: 72rpx; height: 72rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin-right: 20rpx; flex-shrink: 0; background: #F3F4F6; }
.tool-item-info { flex: 1; }
.tool-item-name { font-size: 28rpx; font-weight: 500; color: #111827; }
.tool-item-desc { font-size: 22rpx; color: #6B7280; margin-top: 4rpx; }
.coming-soon-tag { display: inline-block; margin-top: 4rpx; font-size: 20rpx; color: #F59E0B; background: #FEF3C7; padding: 2rpx 12rpx; border-radius: 20rpx; }
