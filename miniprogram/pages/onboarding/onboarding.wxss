/* pages/onboarding/onboarding.wxss */
page { background: #F6F6F6; min-height: 100vh; }

/* Loading 屏幕 */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #F6F6F6;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #E5E7EB;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #9CA3AF;
}

.onboarding-container {
  padding: 120rpx 0 40rpx 0;
}

.step-panel {
  padding: 0 32rpx;
}

/* 顶部引导信息 */
.onboarding-header {
  text-align: center;
  padding: 80rpx 0 32rpx;
}

.onboarding-logo {
  width: 140rpx;
  height: 140rpx;
  background: #DBEAFE;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto 32rpx;
}

.onboarding-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.onboarding-desc {
  font-size: 28rpx;
  color: #6B7280;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 0 32rpx;
}

.step-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #D1D5DB;
  transition: all 0.3s;
}

.step-dot.active {
  background: #2563eb;
  width: 40rpx;
  border-radius: 6rpx;
}

/* 角色卡片 */
.role-list {
  margin-top: 16rpx;
}

.role-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s;
}

.role-card.selected {
  border-color: #2563eb;
  background: #EFF6FF;
}

.role-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.role-icon.blue { background: #DBEAFE; }
.role-icon.green { background: #D1FAE5; }
.role-icon.orange { background: #FEF3C7; }

.role-info { flex: 1; }

.role-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.role-desc {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

.role-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
  font-size: 24rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.role-card.selected .role-check {
  background: #2563eb;
  border-color: #2563eb;
  color: #fff;
}

/* 工具预览区（步骤2，只读） */
.tool-preview {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 0 0 24rpx;
  border: 1rpx solid #E5E7EB;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
}

.preview-subtitle {
  font-size: 24rpx;
  font-weight: 500;
  color: #9CA3AF;
  margin-bottom: 12rpx;
}

.preview-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #4B5563;
}

.preview-item.disabled {
  color: #9CA3AF;
}

.preview-item.disabled .preview-icon {
  opacity: 0.5;
}

.preview-icon {
  width: 36rpx;
  text-align: center;
  font-size: 28rpx;
}

.preview-name {
  font-size: 28rpx;
}

.preview-divider {
  border-top: 1rpx solid #F3F4F6;
  margin: 20rpx 0;
}

.preview-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  padding: 0 32rpx;
}

/* 底部按钮区 */
.onboarding-footer {
  margin-top: 60rpx;
  padding: 0 0 48rpx;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  font-weight: 500;
  border: none;
}

.btn-primary[disabled] {
  background: #D1D5DB;
  color: #9CA3AF;
}

.btn-block { width: 100%; }

.skip-link {
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #9CA3AF;
}
