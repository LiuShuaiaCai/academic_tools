/* pages/profile/profile.wxss */
.profile-page { padding-bottom: 120rpx; background: #F6F6F6; }

/* 头部：渐变色卡片 */
.profile-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

/* 头像区域：view容器 + 透明按钮覆盖层，避开button默认样式干扰 */
.avatar-area {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
}
.avatar-btn-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 110rpx;
  height: 110rpx;
  opacity: 0;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  z-index: 2;
}
.avatar-btn-overlay::after { border: none; }
.avatar-btn-overlay[plain] { border: none; }
.profile-avatar {
  font-size: 110rpx;
  display: block;
}
.profile-avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}
.avatar-edit-icon {
  position: absolute;
  right: -6rpx;
  bottom: -6rpx;
  width: 28rpx;
  height: 28rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}

.profile-info {
  margin-left: 30rpx;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.nickname-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: transparent;
  border: none;
  width: 100%;
  line-height: 1.2;
}
.nickname-input::placeholder {
  color: rgba(255,255,255,0.5);
}

.profile-role-tag {
  display: inline-block;
  margin-top: 12rpx;
  padding: 0;
  background: transparent;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 积分 & 统计合并卡片 */
.credits-stats-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  overflow: hidden;
}
.stats-divider {
  height: 1rpx;
  background: #E5E7EB;
  margin: 0 28rpx;
}

/* ========== 积分条 ========== */
.credits-bar {
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
}

.credits-bar-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.credits-bar-icon { font-size: 28rpx; }
.credits-bar-num { font-size: 36rpx; font-weight: 700; color: #F59E0B; }
.credits-bar-label { font-size: 22rpx; color: #6B7280; }

.credits-bar-divider { width: 1rpx; height: 60rpx; background: #E5E7EB; }

.signin-btn-bar {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #F59E0B, #D97706);
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}
.signin-btn-bar.signed {
  background: #E5E7EB;
  color: #9CA3AF;
}
.signin-btn-bar:active { opacity: 0.8; }

.profile-stats {
  padding: 24rpx 0;
  display: flex;
  align-items: center;
}

.pstat-item { flex: 1; text-align: center; padding: 8rpx 0; }
.pstat-item-active { opacity: 0.6; }
.pstat-divider { width: 1rpx; height: 60rpx; background: #E5E7EB; }
.pstat-num { font-size: 48rpx; font-weight: 700; }
.pstat-num.blue { color: #2563eb; }
.pstat-num.red { color: #EF4444; }
.pstat-num.green { color: #10B981; }
.pstat-num.orange { color: #F59E0B; }
.pstat-num.purple { color: #7C3AED; }
.pstat-num.yellow { color: #EAB308; }
.pstat-num.cyan { color: #06B6D4; }
.pstat-num.pink { color: #EC4899; }
.pstat-num.gray { color: #6B7280; }
.pstat-label { font-size: 22rpx; color: #6B7280; margin-top: 4rpx; }

.menu-group {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.menu-group + .menu-group {
  margin-top: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 34rpx 28rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.profile-badge {
  margin-left: auto;
  margin-right: 16rpx;
  font-size: 22rpx;
  color: #F59E0B;
  background: #FEF3C7;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.menu-badge {
  margin-left: auto;
  margin-right: 16rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 32rpx; margin-right: 16rpx; }
.menu-icon-svg { width: 40rpx; height: 40rpx; margin-right: 16rpx; flex-shrink: 0; }

/* 图标色块 */
.menu-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-size: 34rpx 34rpx;
  background-position: center;
  background-repeat: no-repeat;
}

/* 图标色块底色 */
.icon-blue   { background-color: #DBEAFE; }
.icon-cyan   { background-color: #CFFAFE; }
.icon-yellow { background-color: #FEF3C7; }
.icon-orange { background-color: #FFEDD5; }
.icon-red    { background-color: #FEE2E2; }
.icon-gray   { background-color: #E5E7EB; }

