.menu-text { flex: 1; font-size: 28rpx; color: #374151; }
.menu-arrow { font-size: 32rpx; color: #9CA3AF; }

/* 退出登录按钮 */
.logout-btn {
  margin: 32rpx 24rpx 0;
  text-align: center;
  padding: 28rpx;
  font-size: 28rpx;
  color: #EF4444;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}


