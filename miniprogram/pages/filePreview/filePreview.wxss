.container {
  height: 100vh;
  width: 100%;
  background: #f5f5f5;
}

.zoom-wrapper {
  width: 100%;
  height: 100vh;
}

.zoom-area {
  width: 100%;
  height: 100%;
}

.zoom-view {
  width: 100%;
  height: 100%;
  background: #fff;
  padding: 40rpx;
  box-sizing: border-box;
}

.md-preview {
  height: 100vh;
  padding: 30rpx;
  background: #fff;
}

.md-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}

.md-content h1 {
  font-size: 40rpx;
  font-weight: bold;
  margin: 30rpx 0 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #eee;
}

.md-content h2 {
  font-size: 36rpx;
  font-weight: bold;
  margin: 25rpx 0 15rpx;
}

.md-content h3 {
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0 10rpx;
}

.md-content p {
  margin: 15rpx 0;
}

.md-content code {
  background: #f5f5f5;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.md-content pre {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  overflow-x: auto;
  margin: 15rpx 0;
  white-space: pre-wrap;
  word-break: break-all;
}

.md-content pre code {
  background: transparent;
  padding: 0;
}

.md-content ul, .md-content ol {
  padding-left: 40rpx;
  margin: 15rpx 0;
}

.md-content li {
  margin: 8rpx 0;
}

.md-content blockquote {
  border-left: 6rpx solid #ddd;
  padding-left: 20rpx;
  color: #666;
  margin: 15rpx 0;
}

.md-content table {
  border-collapse: collapse;
  width: 100%;
  margin: 15rpx 0;
}

.md-content th, .md-content td {
  border: 1px solid #ddd;
  padding: 12rpx;
  text-align: left;
}

.md-content th {
  background: #f5f5f5;
  font-weight: bold;
}

.md-content a {
  color: #576b95;
}

.md-content img {
  max-width: 100%;
}
