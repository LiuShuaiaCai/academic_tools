<!--pages/settings/settings.wxml-->
<view class="settings-page">
  <!-- 顶部导航 -->
  <view class="settings-header">
    <view class="header-btn" bindtap="goBack">
      <text>←</text>
    </view>
    <view class="header-title">系统设置</view>
    <view class="header-placeholder"></view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-list">
    <view
      class="setting-item"
      wx:for="{{settings}}"
      wx:key="key"
    >
      <view class="setting-label">
        <view class="setting-title">{{item.title}}</view>
        <view class="setting-desc">{{item.desc}}</view>
      </view>
      <view
        class="toggle {{item.value ? 'active' : ''}}"
        data-idx="{{index}}"
        bindtap="toggleSetting"
      >
        <view class="toggle-dot"></view>
      </view>
    </view>
  </view>

  <!-- 提醒额度 -->
  <view class="quota-section" wx:if="{{settings[0].value}}">
    <view class="quota-header">
      <view class="quota-title">订阅消息额度</view>
      <view class="quota-desc">每次授权可补充 1 次发送额度</view>
    </view>
    <view class="quota-card">
      <view class="quota-info">
        <view class="quota-value">{{reminderQuota > 0 ? reminderQuota : 0}}</view>
        <view class="quota-unit">次</view>
      </view>
      <view class="quota-btn {{loadingQuota ? 'loading' : ''}}" bindtap="requestSubscribeAuth">
        {{loadingQuota ? '请求中...' : '补充额度'}}
      </view>
    </view>
  </view>
</view>
