/* pages/settings/settings.wxss */
page { background: #F6F6F6; }

.settings-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ========== Header ========== */
.settings-header {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.header-placeholder {
  width: 64rpx;
}

/* ========== Settings List ========== */
.settings-list {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  margin-right: 20rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
}

.setting-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ========== Toggle Switch ========== */
.toggle {
  width: 96rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #D1D5DB;
  position: relative;
  transition: all 0.3s;
  flex-shrink: 0;
}

.toggle.active {
  background: #2563eb;
}

.toggle-dot {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  transition: all 0.3s;
}

.toggle.active .toggle-dot {
  left: 44rpx;
}

/* ========== Quota Section ========== */
.quota-section {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.quota-header {
  margin-bottom: 24rpx;
}

.quota-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.quota-desc {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.quota-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 16rpx;
  padding: 32rpx;
}

.quota-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.quota-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.quota-unit {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.quota-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.quota-btn.loading {
  opacity: 0.6;
}
