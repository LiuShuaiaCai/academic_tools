<!--pages/conferences/conferences.wxml-->
<view class="sub-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索会议名称、地点..." bindinput="onSearch" value="{{searchKeyword}}"/>
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</view>
    </view>
  </view>

  <!-- 快速筛选 -->
  <view class="filter-tips">
    <view class="tip-btn tip-all {{quickFilter === 'all' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="all">全部 {{totalCount}}</view>
    <view class="tip-btn tip-active {{quickFilter === 'active' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="active">进行中 {{activeCount}}</view>
    <view class="tip-btn tip-urgent {{quickFilter === 'urgent' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="urgent">急需处理 {{urgentCount}}</view>
    <view class="adv-toggle {{showAdvanced ? 'active' : ''}}" bindtap="toggleAdvanced">
      <text>高级筛选</text>
      <text class="adv-arrow">{{showAdvanced ? '▲' : '▼'}}</text>
    </view>
  </view>

  <!-- 高级筛选面板 -->
  <view class="adv-panel" wx:if="{{showAdvanced}}">
    <!-- 会议类型 -->
    <view class="adv-row">
      <text class="adv-label">会议类型</text>
      <view class="adv-field-wrap">
        <picker mode="selector" range="{{advConferenceTypeOptions}}" range-key="label" value="{{advConferenceTypeIndex}}" bindchange="onAdvConferenceTypeChange">
          <view class="adv-picker-text {{advConferenceType ? '' : 'placeholder'}}">{{advConferenceTypeLabel || '请选择'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advConferenceType}}" bindtap="clearAdvConferenceType">✕</view>
      </view>
    </view>
    <!-- 会议地点 -->
    <view class="adv-row">
      <text class="adv-label">会议地点</text>
      <view class="adv-field-wrap">
        <input class="adv-input" placeholder="输入地点关键词" value="{{advLocation}}" bindinput="onAdvLocationInput" bindconfirm="onAdvLocationConfirm"/>
        <view class="adv-clear" wx:if="{{advLocation}}" bindtap="clearAdvLocation">✕</view>
      </view>
    </view>
    <!-- 会议开始日期 -->
    <view class="adv-row">
      <text class="adv-label">会议开始日期</text>
      <view class="adv-date-wrap">
        <view class="adv-date-item">
          <picker mode="date" value="{{advStartDateFrom}}" bindchange="onAdvStartDateFromChange">
            <view class="adv-picker-text {{advStartDateFrom ? '' : 'placeholder'}}">{{advStartDateFrom || '起始日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advStartDateFrom}}" bindtap="clearAdvStartDateFrom">✕</view>
        </view>
        <text class="adv-sep">~</text>
        <view class="adv-date-item">
          <picker mode="date" value="{{advStartDateTo}}" bindchange="onAdvStartDateToChange">
            <view class="adv-picker-text {{advStartDateTo ? '' : 'placeholder'}}">{{advStartDateTo || '截止日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advStartDateTo}}" bindtap="clearAdvStartDateTo">✕</view>
        </view>
      </view>
    </view>
    <!-- 会议截止日期 -->
    <view class="adv-row">
      <text class="adv-label">会议截止日期</text>
      <view class="adv-date-wrap">
        <view class="adv-date-item">
          <picker mode="date" value="{{advEndDateFrom}}" bindchange="onAdvEndDateFromChange">
            <view class="adv-picker-text {{advEndDateFrom ? '' : 'placeholder'}}">{{advEndDateFrom || '起始日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advEndDateFrom}}" bindtap="clearAdvEndDateFrom">✕</view>
        </view>
        <text class="adv-sep">~</text>
        <view class="adv-date-item">
          <picker mode="date" value="{{advEndDateTo}}" bindchange="onAdvEndDateToChange">
            <view class="adv-picker-text {{advEndDateTo ? '' : 'placeholder'}}">{{advEndDateTo || '截止日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advEndDateTo}}" bindtap="clearAdvEndDateTo">✕</view>
        </view>
      </view>
    </view>
    <!-- 会议截稿日期 -->
    <view class="adv-row">
      <text class="adv-label">会议截稿日期</text>
      <view class="adv-date-wrap">
        <view class="adv-date-item">
          <picker mode="date" value="{{advDeadlineFrom}}" bindchange="onAdvDeadlineFromChange">
            <view class="adv-picker-text {{advDeadlineFrom ? '' : 'placeholder'}}">{{advDeadlineFrom || '起始日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advDeadlineFrom}}" bindtap="clearAdvDeadlineFrom">✕</view>
        </view>
        <text class="adv-sep">~</text>
        <view class="adv-date-item">
          <picker mode="date" value="{{advDeadlineTo}}" bindchange="onAdvDeadlineToChange">
            <view class="adv-picker-text {{advDeadlineTo ? '' : 'placeholder'}}">{{advDeadlineTo || '截止日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advDeadlineTo}}" bindtap="clearAdvDeadlineTo">✕</view>
        </view>
      </view>
    </view>
    <!-- 参会状态 -->
    <view class="adv-row">
      <text class="adv-label">参会状态</text>
      <view class="adv-field-wrap">
        <picker mode="selector" range="{{advStatusOptions}}" range-key="label" value="{{advStatusIndex}}" bindchange="onAdvStatusChange">
          <view class="adv-picker-text {{advStatus ? '' : 'placeholder'}}">{{advStatusLabel || '请选择'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advStatus}}" bindtap="clearAdvStatus">✕</view>
      </view>
    </view>
    <!-- 会议等级 -->
    <view class="adv-row">
      <text class="adv-label">会议等级</text>
      <view class="adv-field-wrap">
        <picker mode="selector" range="{{advRankOptions}}" value="{{advRankIndex}}" bindchange="onAdvRankChange">
          <view class="adv-picker-text {{advRank ? '' : 'placeholder'}}">{{advRank || '请选择'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advRank}}" bindtap="clearAdvRank">✕</view>
      </view>
    </view>
    <!-- 举办单位 -->
    <view class="adv-row">
      <text class="adv-label">举办单位</text>
      <view class="adv-field-wrap">
        <input class="adv-input" placeholder="输入举办单位关键词" value="{{advOrganizer}}" bindinput="onAdvOrganizerInput" bindconfirm="onAdvOrganizerConfirm"/>
        <view class="adv-clear" wx:if="{{advOrganizer}}" bindtap="clearAdvOrganizer">✕</view>
      </view>
    </view>
    <!-- 操作按钮 -->
    <view class="adv-actions">
      <view class="adv-btn-reset" bindtap="resetAdvanced">重置全部</view>
    </view>
  </view>

  <!-- 列表 -->
  <view class="sub-list">
    <view wx:if="{{!filteredList.length && !searchLoading}}" class="empty-box">
      <text class="empty-icon">🎤</text>
      <text class="empty-text">暂无会议记录</text>
    </view>

    <view
      class="conf-card {{item.urgent ? 'urgent' : ''}} {{item.critical ? 'critical' : ''}}"
      wx:for="{{filteredList}}"
      wx:key="_id"
      bindtap="showEditForm"
      data-id="{{item._id}}"
    >
      <!-- 顶部彩色状态条 -->
      <view class="card-topbar" style="background:{{item.daysLeft < 0 ? '#10B981' : item.daysLeft <= 3 ? '#EF4444' : item.daysLeft <= 14 ? '#F59E0B' : '#3B82F6'}}"></view>

      <view class="card-body">
        <!-- 名称 -->
        <view class="card-title-row">
          <text class="card-title" user-select="true">{{item.name}}</text>
        </view>

        <!-- 地点 + 标签 + 状态 -->
        <view class="card-info-row">
          <text class="card-location" wx:if="{{item.location}}" user-select="true">📍 {{item.location}}</text>
          <text wx:if="{{item.conferenceType}}" class="card-tag">{{item.conferenceType === 'online' ? '线上' : '线下'}}</text>
          <text wx:if="{{item.rank}}" class="card-tag card-tag-rank">{{item.rank}}</text>
          <text wx:if="{{item.statusLabel}}" class="card-tag card-tag-status">{{item.statusLabel}}</text>
        </view>

        <!-- 举办单位 -->
        <view class="card-info-row" wx:if="{{item.organizer}}">
          <text class="card-location">🏛 {{item.organizer}}</text>
        </view>

        <!-- 重要日期 -->
        <view class="card-dates-row" wx:if="{{item.deadlineLabel || item.dateRangeLabel}}">
          <view class="card-date-item {{item.daysLeft !== null && item.daysLeft >= 0 && item.daysLeft <= 3 ? 'urgent' : ''}}" wx:if="{{item.deadlineLabel}}">
            📄 截稿 {{item.deadlineLabel}}{{item.daysLeft !== null ? (item.daysLeft >= 0 ? ' (' + item.daysLeft + '天)' : ' (已过期)') : ''}}
          </view>
          <view class="card-date-item" wx:if="{{item.dateRangeLabel}}">
            📅 会议时间 {{item.dateRangeLabel}}
            <view class="card-timeline-status {{item.timelineStatusLabel === '进行中' ? 'timeline-active' : item.timelineStatusLabel === '已结束' ? 'timeline-ended' : 'timeline-upcoming'}}" wx:if="{{item.timelineStatusLabel}}">{{item.timelineStatusLabel}}</view>
          </view>
        </view>

        <!-- 卡片底部操作 -->
        <view class="card-footer" catchtap="doNothing">
          <view class="footer-edit footer-btn" wx:if="{{item.url}}" catchtap="onOpenConfUrl" data-url="{{item.url}}">🔗 打开官网</view>
          <view class="footer-del footer-btn" catchtap="deleteItem" data-id="{{item._id}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more" wx:if="{{filteredList.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{!searchKeyword && !hasMore}}">— 没有更多了 —</text>
  </view>

  <!-- 搜索 loading 浮动遮罩 -->
  <view class="search-loading-mask" wx:if="{{searchLoading}}" catchtouchmove="true">
    <view class="search-loading-box">
      <view class="search-loading-spinner"></view>
      <text class="search-loading-text">搜索中...</text>
    </view>
  </view>

  <!-- FAB 悬浮按钮 -->
  <view class="fab" bindtap="showAddForm">+</view>

  <!-- 表单组件 -->
  <conference-form
    id="conferenceForm"
    show="{{showForm}}"
    is-edit="{{isEdit}}"
    edit-id="{{editId}}"
    bind:save="onFormSave"
    bind:cancel="onFormCancel"
  />
</view>
