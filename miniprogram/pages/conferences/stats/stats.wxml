<!-- pages/conferences/stats/stats.wxml -->
<view class="stats-page">
  <view class="stats-loading" wx:if="{{!loaded}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{loaded}}">
    <!-- 概览卡片 -->
    <view class="stats-overview">
      <view class="overview-card total">
        <text class="overview-num">{{total}}</text>
        <text class="overview-label">总会议数</text>
      </view>
      <view class="overview-card active">
        <text class="overview-num">{{active}}</text>
        <text class="overview-label">进行中</text>
      </view>
      <view class="overview-card past">
        <text class="overview-num">{{past}}</text>
        <text class="overview-label">已结束</text>
      </view>
      <view class="overview-card warn">
        <text class="overview-num">{{urgent}}</text>
        <text class="overview-label">急需处理</text>
      </view>
    </view>

    <!-- 参会状态分布 -->
    <view class="stats-section" wx:if="{{statusList.length > 0}}">
      <view class="section-header">
        <text class="section-title">📋 参会状态</text>
      </view>
      <view class="status-list">
        <block wx:for="{{statusList}}" wx:key="name">
          <view class="status-row">
            <view class="status-label-row">
              <text class="status-label">{{item.label}}</text>
              <text class="status-count">{{item.count}}</text>
            </view>
            <view class="status-bar-wrap">
              <view class="status-bar-fill" style="width: {{item.pct}}%; background: {{item.color}};"></view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 会议类型 -->
    <view class="stats-section" wx:if="{{typeList.length > 0}}">
      <view class="section-header">
        <text class="section-title">🏷️ 会议类型</text>
      </view>
      <view class="tag-list">
        <block wx:for="{{typeList}}" wx:key="name">
          <view class="tag-item" style="background: {{item.color}}15; color: {{item.color}};">
            <text>{{item.label}}</text>
            <text class="tag-count">{{item.count}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 会议等级 -->
    <view class="stats-section" wx:if="{{rankList.length > 0}}">
      <view class="section-header">
        <text class="section-title">⭐ 会议等级</text>
      </view>
      <view class="status-list">
        <block wx:for="{{rankList}}" wx:key="name">
          <view class="status-row">
            <view class="status-label-row">
              <text class="status-label">{{item.label}}</text>
              <text class="status-count">{{item.count}}</text>
            </view>
            <view class="status-bar-wrap">
              <view class="status-bar-fill" style="width: {{item.pct}}%; background: {{item.color}};"></view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 查看全部 -->
    <view class="goto-section">
      <view class="goto-btn" bindtap="goToList">
        <text>查看全部会议记录</text>
        <text class="goto-arrow">›</text>
      </view>
    </view>
  </block>
</view>
