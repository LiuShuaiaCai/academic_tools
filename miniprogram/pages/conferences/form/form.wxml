<!--pages/conferences/form/form.wxml-->
<!-- 编辑表单弹层 -->
<view class="form-overlay {{show ? 'active' : ''}}" bindtap="closeForm">
  <view class="form-sheet" catchtap="doNothing">
    <view class="form-header">
      <view class="form-title">{{isEdit ? '编辑会议' : '添加会议'}}</view>
      <view class="form-close" bindtap="closeForm">✕</view>
    </view>
    <scroll-view scroll-y class="form-body">

      <!-- 1. 会议名称 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">📋</text> 会议名称 <text class="required">*</text></view>
        <input class="form-input" placeholder="例：International Conference on..." bindinput="onFormInput" data-field="name" value="{{form.name}}"/>
      </view>

      <!-- 2. 会议官网 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">🔗</text> 会议官网 <text class="required">*</text></view>
        <input class="form-input" placeholder="https://..." bindinput="onFormInput" data-field="url" value="{{form.url}}"/>
      </view>

      <!-- 3. 会议类型 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">📡</text> 会议类型 <text class="required">*</text></view>
        <picker mode="selector" range="{{conferenceTypeLabels}}" bindchange="onConferenceTypeChange">
          <view class="form-picker {{form.conferenceType ? '' : 'placeholder'}}">
            <text style="flex:1">{{form.conferenceTypeLabel || '请选择会议类型'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 4. 会议地点 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">📍</text> 会议地点 <text class="required">*</text></view>
        <input class="form-input" placeholder="城市，国家" bindinput="onFormInput" data-field="location" value="{{form.location}}"/>
      </view>

      <!-- 5. 会议开始日期 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">🎤</text> 会议开始日期 <text class="required">*</text></view>
        <picker mode="date" value="{{form.startDate}}" bindchange="onStartChange">
          <view class="form-picker {{form.startDate ? '' : 'placeholder'}}">
            <text style="flex:1">{{form.startDate || '请选择会议日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 6. 会议截止日期 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">🏁</text> 会议截止日期</view>
        <picker mode="date" value="{{form.endDate}}" bindchange="onEndChange">
          <view class="form-picker {{form.endDate ? '' : 'placeholder'}}">
            <text style="flex:1">{{form.endDate || '请选择截止日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 7. 会议截稿日期 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">📄</text> 会议截稿日期</view>
        <picker mode="date" value="{{form.deadline}}" bindchange="onDeadlineChange">
          <view class="form-picker {{form.deadline ? '' : 'placeholder'}}">
            <text style="flex:1">{{form.deadline || '请选择截稿日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 8. 参会状态 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">🏷</text> 参会状态</view>
        <picker mode="selector" range="{{statusLabels}}" bindchange="onStatusChange">
          <view class="form-picker {{form.status ? '' : 'placeholder'}}">
            <text style="flex:1">{{form.statusLabel || '请选择参会状态'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 9. 会议等级 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">🏆</text> 会议等级</view>
        <view class="radio-group">
          <view class="radio-item {{form.rank === 'CCF-A' ? 'active' : ''}}" bindtap="onSelectRank" data-rank="CCF-A">CCF-A</view>
          <view class="radio-item {{form.rank === 'CCF-B' ? 'active' : ''}}" bindtap="onSelectRank" data-rank="CCF-B">CCF-B</view>
          <view class="radio-item {{form.rank === 'CCF-C' ? 'active' : ''}}" bindtap="onSelectRank" data-rank="CCF-C">CCF-C</view>
          <view class="radio-item {{form.rank === 'SCI' ? 'active' : ''}}" bindtap="onSelectRank" data-rank="SCI">SCI</view>
          <view class="radio-item {{form.rank === 'EI' ? 'active' : ''}}" bindtap="onSelectRank" data-rank="EI">EI</view>
        </view>
      </view>

      <!-- 10. 举办单位 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">🏛</text> 举办单位</view>
        <input class="form-input" placeholder="大学、学会、机构..." bindinput="onFormInput" data-field="organizer" value="{{form.organizer}}"/>
      </view>

      <!-- 11. 备注 -->
      <view class="form-group">
        <view class="form-label"><text class="form-label-icon">📝</text> 备注</view>
        <textarea class="form-textarea" placeholder="备注信息..." bindinput="onFormInput" data-field="note" value="{{form.note}}"></textarea>
      </view>

    </scroll-view>
    <view class="form-footer">
      <button class="btn-cancel" bindtap="closeForm">取消</button>
      <button class="btn-confirm" bindtap="saveForm">保存</button>
    </view>
  </view>
</view>

<reminder-quota-tip show="{{showQuotaTip}}" bind:cancel="onQuotaTipCancel" bind:confirm="onQuotaTipConfirm" />
