/* pages/conferences/conferences.wxss */
page { background: #F6F6F6; }
.sub-page { padding-bottom: 120rpx; }

/* ========== 搜索栏 ========== */
.search-bar {
  background: #fff; padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB; box-sizing: border-box;
}
.search-input-wrap {
  display: flex; align-items: center; background: #F3F4F6;
  border-radius: 40rpx; padding: 12rpx 20rpx; flex: 1;
  height: 72rpx; box-sizing: border-box;
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; color: #9CA3AF; }
.search-input { flex: 1; font-size: 28rpx; color: #111827; height: 72rpx; }
.search-clear {
  font-size: 26rpx; color: #9CA3AF; padding: 8rpx 12rpx;
  flex-shrink: 0; line-height: 1;
}

/* ========== 提示栏 + 高级筛选 ========== */
.filter-tips {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 24rpx; background: #fff;
  border-bottom: 1rpx solid #F3F4F6; box-sizing: border-box;
  flex-wrap: nowrap; overflow-x: auto;
}
.tip-btn {
  font-size: 24rpx; padding: 8rpx 14rpx; border-radius: 8rpx;
  flex-shrink: 0; font-weight: 500; white-space: nowrap;
}
.tip-all        { color: #065F46; background: transparent; border: 1rpx solid #6EE7B7; }
.tip-active     { color: #1E3A8A; background: transparent; border: 1rpx solid #93C5FD; }
.tip-urgent     { color: #991B1B; background: transparent; border: 1rpx solid #FCA5A5; }
.tip-all.active        { background: #ECFDF5; border-color: #059669; color: #064E3B; font-weight: 700; }
.tip-active.active     { background: #DBEAFE; border-color: #2563EB; color: #1E3A8A; font-weight: 700; }
.tip-urgent.active     { background: #FEE2E2; border-color: #DC2626; color: #7F1D1D; font-weight: 700; }

.filter-tips .adv-toggle {
  font-size: 24rpx; padding: 8rpx 14rpx; border-radius: 8rpx;
  background: transparent; color: #374151; flex-shrink: 0; white-space: nowrap;
  display: flex; align-items: center; gap: 4rpx;
  border: 1rpx solid #D1D5DB;
}
.filter-tips .adv-toggle.active { background: #E5E7EB; border-color: #6B7280; color: #111827; font-weight: 700; }
.filter-tips .adv-arrow { font-size: 20rpx; }

/* ========== 高级筛选 ========== */
.adv-panel {
  background: #fff; padding: 16rpx 24rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB;
}
.adv-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.adv-label { font-size: 26rpx; color: #374151; width: 150rpx; flex-shrink: 0; }
.adv-field-wrap { flex: 1; display: flex; align-items: center; gap: 8rpx; }
.adv-field-wrap .adv-picker-wrap { flex: 1; }
.adv-picker-text { font-size: 26rpx; color: #374151; flex: 1; padding: 8rpx 0; }
.adv-picker-text.placeholder { color: #9CA3AF; }
.adv-sep { font-size: 24rpx; color: #9CA3AF; flex-shrink: 0; }
.adv-input { flex: 1; font-size: 26rpx; color: #374151; padding: 8rpx 0; height: 52rpx; line-height: 52rpx; }
.adv-input::placeholder { color: #9CA3AF; font-size: 26rpx; }
.adv-date-wrap { flex: 1; display: flex; align-items: center; gap: 8rpx; }
.adv-date-item { flex: 1; display: flex; align-items: center; gap: 8rpx; }
.adv-date-item .adv-picker-wrap { flex: 1; }
.adv-clear {
  font-size: 26rpx; color: #9CA3AF; padding: 8rpx;
  flex-shrink: 0; line-height: 1;
}
.adv-clear:active { color: #EF4444; }
.adv-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.adv-btn-reset {
  flex: 1; text-align: center; padding: 16rpx 0;
  background: #F3F4F6; color: #374151; border-radius: 12rpx; font-size: 26rpx;
}

/* ========== 列表 ========== */
.sub-list { padding: 16rpx 24rpx; }
.conf-card {
  background: #fff; border-radius: 16rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08); overflow: hidden; position: relative;
}
.card-topbar { height: 8rpx; width: 100%; }
.card-body { padding: 16rpx 24rpx; }

.card-title { font-size: 30rpx; font-weight: 600; color: #111827; line-height: 1.5; }
.card-title-row { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 12rpx; }
.card-title-row .card-title { flex: 1; margin-bottom: 0; }
.card-short { font-size: 20rpx; color: #10B981; background: #D1FAE5; padding: 4rpx 12rpx; border-radius: 12rpx; font-weight: 500; flex-shrink: 0; white-space: nowrap; }

.card-info-row { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.card-location { font-size: 24rpx; color: #6B7280; flex: 1; }
.card-tag { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 10rpx; background: #E0E7FF; color: #4338CA; flex-shrink: 0; }
.card-tag-rank { background: #EDE9FE; color: #7C3AED; }
.card-tag-status { background: #DBEAFE; color: #1E40AF; }
.card-status { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 500; flex-shrink: 0; }
.status-pending { background: #FEF3C7; color: #92400E; }
.status-registered { background: #D1FAE5; color: #065F46; }
.status-future { background: #DBEAFE; color: #1E40AF; }

.card-dates-row { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.card-date-item { font-size: 22rpx; color: #9CA3AF; display: flex; align-items: center; gap: 6rpx; line-height: 36rpx; }
.card-date-item.urgent { color: #EF4444; font-weight: 600; }
.card-timeline-status { font-size: 22rpx; padding: 0 8rpx; border-radius: 6rpx; line-height: 30rpx; }
.timeline-upcoming { background: #DBEAFE; color: #1E40AF; }
.timeline-active { background: #D1FAE5; color: #065F46; }
.timeline-ended { background: #F3F4F6; color: #6B7280; }
.card-footer { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-top: 1rpx solid #F3F4F6; }
.footer-btn { font-size: 24rpx; color: #2563eb; padding: 8rpx 0; }
.footer-edit { color: #2563eb; }
.footer-del { font-size: 24rpx; color: #EF4444; padding: 8rpx 0; }

/* ========== 空状态 ========== */
.empty-box { text-align: center; padding: 100rpx 40rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #9CA3AF; }

/* ========== 加载更多 ========== */
.load-more {
  text-align: center; padding: 32rpx 0 48rpx;
  font-size: 24rpx; color: #9CA3AF;
}

/* ========== 搜索 loading 浮动遮罩 ========== */
.search-loading-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.6); z-index: 500;
  display: flex; align-items: center; justify-content: center;
}
.search-loading-box {
  display: flex; flex-direction: column; align-items: center;
  background: rgba(0,0,0,0.7); border-radius: 16rpx;
  padding: 40rpx 60rpx;
}
.search-loading-spinner {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3); border-top-color: #fff;
  animation: spin 0.6s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.search-loading-text {
  font-size: 24rpx; color: rgba(255,255,255,0.9); margin-top: 20rpx;
}

/* ========== FAB ========== */
.fab {
  position: fixed; right: 40rpx; bottom: 160rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #10B981; color: #fff; font-size: 60rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(16,185,129,0.4); z-index: 100;
}

.doNothing {}
