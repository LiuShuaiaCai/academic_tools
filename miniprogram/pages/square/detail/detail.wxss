/* pages/square/detail/detail.wxss - 动态详情样式 */
page { background: #F3F4F6; }

.detail-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 动态区域 ========== */
.post-section {
  background: #fff;
  padding: 32rpx 32rpx 24rpx;
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.post-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.15);
}

.post-avatar-img {
  width: 100%;
  height: 100%;
}

.post-avatar-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #2563EB;
  line-height: 1;
}

.post-meta {
  flex: 1;
  min-width: 0;
}

.post-author {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.2;
}

.post-time {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

.post-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}

.post-call-type {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.post-body {
  margin-bottom: 20rpx;
}

.post-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
  line-height: 1.45;
}

.post-content {
  font-size: 30rpx;
  color: #4B5563;
  line-height: 1.85;
  white-space: pre-wrap;
  word-break: break-all;
  padding: 4rpx 0;
}

/* 图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.post-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  border: 1rpx solid #E5E7EB;
}

.post-images .post-image:first-child:nth-last-child(1) {
  width: 100%;
  height: 400rpx;
}

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.post-tag {
  font-size: 24rpx;
  color: #2563eb;
  background: #EFF6FF;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  border: 1rpx solid #DBEAFE;
}

/* 操作栏 */
.post-actions {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 24rpx;
  padding-bottom: 4rpx;
  border-top: 1rpx solid #F3F4F6;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 27rpx;
  color: #6B7280;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.15s;
  font-weight: 500;
}

.action-btn:active {
  background: #F3F4F6;
}

.action-btn.liked {
  color: #EF4444;
}

.action-btn.favorited {
  color: #2563eb;
}

/* Lucide SVG 图标 */
.action-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

/* ========== 学术互助信息 ========== */
.help-info-section {
  background: #FAFBFC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  border: 1rpx solid #E5E7EB;
}

.help-status-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.help-status-badge {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.help-remaining {
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 500;
}

.remaining-text {
  font-weight: 600;
}

.help-detail-card,
.help-reward-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid #F3F4F6;
}

.help-detail-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E5E7EB;
}

.help-detail-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
  font-size: 27rpx;
  line-height: 1.7;
}

.help-detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  flex-shrink: 0;
  color: #6B7280;
  font-weight: 600;
  font-size: 26rpx;
  min-width: 120rpx;
}

.detail-value {
  flex: 1;
  color: #1F2937;
  font-weight: 500;
  word-break: break-all;
  font-size: 27rpx;
}

.detail-value.link {
  color: #2563eb;
  font-weight: 500;
}

.detail-value.reward {
  color: #F59E0B;
  font-weight: 700;
  font-size: 30rpx;
}

/* ========= 附件列表 ========= */
.help-attachments-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid #F3F4F6;
}

.help-attachments-card .attachment-list {
  margin-top: 16rpx;
}

.help-attachments-card .attachment-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.help-attachments-card .attachment-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.help-attachments-card .attachment-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  background: #F3F4F6;
  border-radius: 10rpx;
}

.help-attachments-card .attachment-info {
  flex: 1;
  min-width: 0;
}

.help-attachments-card .attachment-name {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.help-attachments-card .attachment-meta {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.help-attachments-card .attachment-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  flex-shrink: 0;
  width: 44rpx;
  text-align: center;
}

/* ========= 应助列表 ========= */
.help-responses-section {
  background: #fff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid #F3F4F6;
}

.help-responses-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E5E7EB;
}

.responses-count {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
}

.response-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #F3F4F6;
}

.response-item:last-child {
  margin-bottom: 0;
}

.response-user {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.response-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.response-avatar image {
  width: 100%;
  height: 100%;
}

.response-avatar-text {
  font-size: 26rpx;
  color: #2563EB;
  font-weight: 700;
}

.response-nickname {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
  flex: 1;
}

.response-accepted-tag {
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  background: #D1FAE5;
  border-radius: 20rpx;
}

/* 非发布者自己的应助 */
.own-response {
  border: 2rpx solid #BFDBFE;
  background: #F0F7FF;
}

.own-resp-badge {
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  background: #DBEAFE;
  color: #2563EB;
  border-radius: 20rpx;
}

/* 应助空状态 */
.help-responses-empty {
  text-align: center;
  padding: 40rpx 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #9CA3AF;
}

.response-content {
  font-size: 27rpx;
  color: #4B5563;
  line-height: 1.7;
  padding-left: 62rpx;
}

.response-file {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  background: #EFF6FF;
  border-radius: 10rpx;
  margin-left: 62rpx;
  width: fit-content;
  border: 1rpx solid #BFDBFE;
}

.response-file-icon {
  width: 32rpx;
  height: 32rpx;
}

.response-file-name {
  font-size: 25rpx;
  color: #2563EB;
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.response-accept-btn {
  align-self: flex-end;
  margin-top: 6rpx;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  color: #fff;
  font-size: 25rpx;
  border-radius: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.response-accept-btn:active {
  background: #1D4ED8;
  transform: scale(0.96);
}

/* ========= 应助弹窗 ========= */
.respond-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.respond-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 650rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.respond-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.respond-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.respond-modal-close {
  font-size: 36rpx;
  color: #9CA3AF;
  padding: 8rpx;
}

.respond-modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.respond-help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.respond-help-reward {
  font-size: 24rpx;
  color: #F43F5E;
  margin-bottom: 20rpx;
}

.respond-input-section {
  margin-bottom: 24rpx;
}

.respond-input-label,
.respond-file-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.respond-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1F2937;
  box-sizing: border-box;
}

.respond-char-count {
  text-align: right;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

.respond-file-section {
  margin-bottom: 20rpx;
}

.respond-file-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 32rpx;
  background: #F9FAFB;
  border: 2rpx dashed #D1D5DB;
  border-radius: 12rpx;
}

.respond-file-plus {
  font-size: 44rpx;
  color: #9CA3AF;
  font-weight: 300;
}

.respond-file-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

.respond-file-selected {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #EFF6FF;
  border-radius: 12rpx;
}

.respond-file-selected .respond-file-icon {
  width: 36rpx;
  height: 36rpx;
}

.respond-file-selected .respond-file-name {
  flex: 1;
  font-size: 24rpx;
  color: #2563EB;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.respond-file-remove {
  font-size: 28rpx;
  color: #EF4444;
  padding: 8rpx;
  font-weight: 600;
}

.respond-modal-hint {
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #EF4444;
}

.respond-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 28rpx;
  border-top: 1rpx solid #F3F4F6;
}

.respond-cancel-btn {
  flex: 1;
  padding: 20rpx 0;
  background: #F3F4F6;
  color: #6B7280;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  text-align: center;
}

.respond-submit-btn {
  flex: 2;
  padding: 20rpx 0;
  background: #2563EB;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  text-align: center;
}

.respond-submit-btn[disabled] {
  background: #93C5FD;
}

/* ========= 操作按钮 ========= */
.help-actions {
  padding: 20rpx 0 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-btn {
  width: 100%;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 14rpx;
  border: none;
  transition: all 0.2s;
  gap: 10rpx;
}

.respond-btn {
  background: linear-gradient(135deg, #F59E0B, #FBBF24);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(245, 158, 11, 0.35);
}

.respond-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(245, 158, 11, 0.25);
}

.download-btn {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
  gap: 10rpx;
}

.download-btn:active {
  background: #DBEAFE;
  transform: scale(0.98);
}

.download-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.download-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #2563EB;
}

.download-filename {
  font-size: 26rpx;
  font-weight: 500;
  color: #4B5563;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.extend-btn {
  background: linear-gradient(135deg, #F0FDF4, #D1FAE5);
  color: #059669;
  border: 2rpx solid #A7F3D0;
}

.extend-btn:active {
  background: #D1FAE5;
  transform: scale(0.98);
}

/* ========== 评论区 ========== */
.comments-section {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.comments-header {
  margin-bottom: 24rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.comments-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-avatar-img {
  width: 100%;
  height: 100%;
}

.comment-avatar-text {
  font-size: 40rpx;
  line-height: 1;
}


.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.comment-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.comment-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 评论中的图片 */
.comment-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
  background: #F3F4F6;
}

/* 评论操作栏 */
.comment-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
}

.comment-action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #6B7280;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.15s;
}

.comment-action-btn:active {
  background: #F3F4F6;
}

.comment-action-btn.liked {
  color: #EF4444;
}

.action-icon-small {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

/* 删除按钮 */
.delete-btn {
  color: #EF4444;
  margin-left: auto;
}

.delete-btn:active {
  background: #FEE2E2;
}

/* ===== 嵌套回复样式 ===== */
.comment-replies {
  margin-left: 80rpx;
  border-left: 3rpx solid #E5E7EB;
  padding-left: 0;
}

/* 展开/收起按钮 */
.replies-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 500;
}

.toggle-arrow {
  font-size: 20rpx;
  color: #2563eb;
}

/* 回复项 */
.reply-item {
  display: flex;
  padding: 16rpx 16rpx;
  border-top: 1rpx solid #F3F4F6;
}

.reply-item:first-child {
  border-top: none;
}

/* 回复头像（较小） */
.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-avatar-img {
  width: 100%;
  height: 100%;
}

.reply-avatar-text {
  font-size: 30rpx;
  line-height: 1;
}

/* 回复主体 */
.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-author {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.reply-time {
  font-size: 20rpx;
  color: #9CA3AF;
}

.reply-to-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.reply-to-name {
  color: #2563eb;
  font-weight: 500;
}

.reply-content {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
  word-break: break-all;
  white-space: pre-wrap;
}

.reply-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
  margin-top: 8rpx;
  background: #F3F4F6;
}

.reply-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
  padding-top: 4rpx;
}

/* 小型操作按钮 */
.comment-action-btn.small {
  font-size: 22rpx;
  padding: 4rpx 8rpx;
  gap: 4rpx;
}

.action-icon-tiny {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 空评论 */
.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.load-more.no-more {
  color: #D1D5DB;
}

/* 页面加载 */
.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* ========== 底部评论输入 ========== */
.comment-input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: -1;
}

.input-bar {
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.input-reply-hint {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  background: #F9FAFB;
  border-radius: 8rpx;
}

.cancel-reply {
  color: #2563eb;
  font-weight: 500;
  margin-left: auto;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #111827;
}

.input-placeholder {
  color: #9CA3AF;
}

.input-row-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 底部工具栏 */
.input-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-tool-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F3F4F6;
  flex-shrink: 0;
}

.tool-icon {
  width: 36rpx;
  height: 36rpx;
}

.send-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  height: 56rpx;
  font-size: 24rpx;
  line-height: 1;
  border-radius: 28rpx;
  border: 2rpx solid #D1D5DB;
  background: #fff;
  color: #9CA3AF;
  flex-shrink: 0;
}

.send-btn.send-active {
  background: #EF4444;
  color: #fff;
  border-color: #EF4444;
}

/* 已选图片预览 */
.comment-image-preview {
  position: relative;
  display: inline-block;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}

.comment-image-preview .preview-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.remove-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #EF4444;
  color: #fff;
  font-size: 24rpx;
}

/* 表情包面板 */
.emoji-panel {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.emoji-item {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}
