/* pages/square/detail/detail.wxss - 动态详情样式 */
page { background: #F3F4F6; }

.detail-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 动态区域 ========== */
.post-section {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E7EB;
}

.post-meta {
  flex: 1;
}

.post-author {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.post-time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 2rpx;
}

.post-type-badge {
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.post-body {
  margin-bottom: 24rpx;
}

.post-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.post-content {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 20rpx;
}

.post-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
}

.post-images .post-image:first-child:nth-last-child(1) {
  width: 100%;
  height: 400rpx;
}

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.post-tag {
  font-size: 24rpx;
  color: #2563eb;
  background: #EFF6FF;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 操作栏 */
.post-actions {
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.15s;
}

.action-btn:active {
  background: #F3F4F6;
}

.action-btn.liked {
  color: #EF4444;
}

.action-btn.favorited {
  color: #2563eb;
}

/* ========== Lucide SVG 图标 ========== */
.action-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

/* ========== 评论区 ========== */
.comments-section {
  background: #fff;
  padding: 24rpx 32rpx;
}

.comments-header {
  margin-bottom: 24rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.comments-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E7EB;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.comment-time {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.comment-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  word-break: break-all;
}

.reply-hint {
  color: #9CA3AF;
}

.reply-target {
  color: #2563eb;
}

.comment-reply-btn {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 10rpx;
  padding: 4rpx 0;
}

/* 空评论 */
.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.load-more.no-more {
  color: #D1D5DB;
}

/* 页面加载 */
.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* ========== 底部评论输入 ========== */
.comment-input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 300;
}

.input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
}

.input-bar {
  position: relative;
  background: #fff;
  padding: 16rpx 32rpx 24rpx;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
}

.input-reply-hint {
  font-size: 24rpx;
  color: #2563eb;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cancel-reply {
  color: #9CA3AF;
  padding: 4rpx 8rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.input-placeholder {
  color: #D1D5DB;
}

.send-btn {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 32rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  line-height: 72rpx;
}

/* ========= 文献互助信息 ========= */
.help-info-section {
  margin-top: 20rpx;
  padding: 0 32rpx;
}

/* 求助状态 */
.help-status-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.help-status-badge {
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.help-remaining {
  flex: 1;
}

.remaining-text {
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 500;
}

/* 详情卡片 */
.help-detail-card,
.help-reward-card,
.help-helper-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.help-detail-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.help-detail-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.detail-label {
  flex-shrink: 0;
  color: #6B7280;
  font-weight: 500;
}

.detail-value {
  flex: 1;
  color: #374151;
  word-break: break-all;
}

.detail-value.link {
  color: #2563eb;
  text-decoration: underline;
}

.detail-value.reward {
  color: #f59e0b;
  font-weight: 600;
  font-size: 28rpx;
}

/* 应助者信息 */
.helper-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.helper-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E5E7EB;
  flex-shrink: 0;
}

.helper-meta {
  flex: 1;
}

.helper-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
}

.helper-time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

/* 操作按钮 */
.help-actions {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  transition: all 0.2s;
}

.respond-btn {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.3);
}

.respond-btn:active {
  transform: scale(0.98);
}

.download-btn {
  background: #EFF6FF;
  color: #3b82f6;
  border: 2rpx solid #BFDBFE;
}

.download-btn:active {
  background: #DBEAFE;
}

.extend-btn {
  background: #F0FDF4;
  color: #10b981;
  border: 2rpx solid #A7F3D0;
}

.extend-btn:active {
  background: #D1FAE5;
}
