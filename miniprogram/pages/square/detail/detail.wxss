/* pages/square/detail/detail.wxss - 动态详情样式 */
page { background: #F3F4F6; }

.detail-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 动态区域 ========== */
.post-section {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E7EB;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-avatar-img {
  width: 100%;
  height: 100%;
}

.post-avatar-text {
  font-size: 50rpx;
  line-height: 1;
}


.post-meta {
  flex: 1;
}

.post-author {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.post-time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 2rpx;
}

.post-type-badge {
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.post-call-type {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.post-body {
  margin-bottom: 24rpx;
}

.post-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.post-content {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 20rpx;
}

.post-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
}

.post-images .post-image:first-child:nth-last-child(1) {
  width: 100%;
  height: 400rpx;
}

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.post-tag {
  font-size: 24rpx;
  color: #2563eb;
  background: #EFF6FF;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 操作栏 */
.post-actions {
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.15s;
}

.action-btn:active {
  background: #F3F4F6;
}

.action-btn.liked {
  color: #EF4444;
}

.action-btn.favorited {
  color: #2563eb;
}

/* Lucide SVG 图标 */
.action-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

/* ========== 文献互助信息 ========== */
.help-info-section {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 20rpx;
}

.help-status-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.help-status-badge {
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.help-remaining {
  font-size: 24rpx;
  color: #EF4444;
}

.remaining-text {
  font-weight: 500;
}

.help-detail-card,
.help-reward-card,
.help-helper-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.help-detail-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.help-detail-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.detail-label {
  flex-shrink: 0;
  color: #6B7280;
  font-weight: 500;
}

.detail-value {
  flex: 1;
  color: #374151;
  word-break: break-all;
}

.detail-value.link {
  color: #2563eb;
  text-decoration: underline;
}

.detail-value.reward {
  color: #f59e0b;
  font-weight: 600;
  font-size: 28rpx;
}

.helper-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.helper-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.helper-avatar-img {
  width: 100%;
  height: 100%;
}

.helper-avatar-text {
  font-size: 40rpx;
  line-height: 1;
}


.helper-meta {
  flex: 1;
}

.helper-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
}

.helper-time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

/* 操作按钮 */
.help-actions {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  transition: all 0.2s;
}

.respond-btn {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.3);
}

.respond-btn:active {
  transform: scale(0.98);
}

.download-btn {
  background: #EFF6FF;
  color: #3b82f6;
  border: 2rpx solid #BFDBFE;
  gap: 10rpx;
}

.download-btn:active {
  background: #DBEAFE;
}

.download-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.download-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #3b82f6;
}

.download-filename {
  font-size: 26rpx;
  font-weight: 400;
  color: #6B7280;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.extend-btn {
  background: #F0FDF4;
  color: #10b981;
  border: 2rpx solid #A7F3D0;
}

.extend-btn:active {
  background: #D1FAE5;
}

/* ========== 评论区 ========== */
.comments-section {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.comments-header {
  margin-bottom: 24rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.comments-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-avatar-img {
  width: 100%;
  height: 100%;
}

.comment-avatar-text {
  font-size: 40rpx;
  line-height: 1;
}


.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.comment-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.comment-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 评论中的图片 */
.comment-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
  background: #F3F4F6;
}

/* 评论操作栏 */
.comment-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
}

.comment-action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #6B7280;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.15s;
}

.comment-action-btn:active {
  background: #F3F4F6;
}

.comment-action-btn.liked {
  color: #EF4444;
}

.action-icon-small {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

/* 删除按钮 */
.delete-btn {
  color: #EF4444;
  margin-left: auto;
}

.delete-btn:active {
  background: #FEE2E2;
}

/* ===== 嵌套回复样式 ===== */
.comment-replies {
  margin-left: 80rpx;
  border-left: 3rpx solid #E5E7EB;
  padding-left: 0;
}

/* 展开/收起按钮 */
.replies-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 500;
}

.toggle-arrow {
  font-size: 20rpx;
  color: #2563eb;
}

/* 回复项 */
.reply-item {
  display: flex;
  padding: 16rpx 16rpx;
  border-top: 1rpx solid #F3F4F6;
}

.reply-item:first-child {
  border-top: none;
}

/* 回复头像（较小） */
.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-avatar-img {
  width: 100%;
  height: 100%;
}

.reply-avatar-text {
  font-size: 30rpx;
  line-height: 1;
}

/* 回复主体 */
.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-author {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.reply-time {
  font-size: 20rpx;
  color: #9CA3AF;
}

.reply-to-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.reply-to-name {
  color: #2563eb;
  font-weight: 500;
}

.reply-content {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
  word-break: break-all;
  white-space: pre-wrap;
}

.reply-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
  margin-top: 8rpx;
  background: #F3F4F6;
}

.reply-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
  padding-top: 4rpx;
}

/* 小型操作按钮 */
.comment-action-btn.small {
  font-size: 22rpx;
  padding: 4rpx 8rpx;
  gap: 4rpx;
}

.action-icon-tiny {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 空评论 */
.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.load-more.no-more {
  color: #D1D5DB;
}

/* 页面加载 */
.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* ========== 底部评论输入 ========== */
.comment-input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: -1;
}

.input-bar {
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.input-reply-hint {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  background: #F9FAFB;
  border-radius: 8rpx;
}

.cancel-reply {
  color: #2563eb;
  font-weight: 500;
  margin-left: auto;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #111827;
}

.input-placeholder {
  color: #9CA3AF;
}

.input-row-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 底部工具栏 */
.input-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-tool-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F3F4F6;
  flex-shrink: 0;
}

.tool-icon {
  width: 36rpx;
  height: 36rpx;
}

.send-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  height: 56rpx;
  font-size: 24rpx;
  line-height: 1;
  border-radius: 28rpx;
  border: 2rpx solid #D1D5DB;
  background: #fff;
  color: #9CA3AF;
  flex-shrink: 0;
}

.send-btn.send-active {
  background: #EF4444;
  color: #fff;
  border-color: #EF4444;
}

/* 已选图片预览 */
.comment-image-preview {
  position: relative;
  display: inline-block;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}

.comment-image-preview .preview-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.remove-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #EF4444;
  color: #fff;
  font-size: 24rpx;
}

/* 表情包面板 */
.emoji-panel {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.emoji-item {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}
