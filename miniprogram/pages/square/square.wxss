/* pages/square/square.wxss - 学术动态样式 */
page { background: #F3F4F6; }

.square-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ========== 筛选区整体容器 ========== */
.filter-bar-wrap {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fff;
  padding: 16rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* ========== Tab Bar ========== */
.tab-bar {
  display: flex;
  background: #F3F4F6;
  padding: 6rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #6B7280;
  border-radius: 12rpx;
  transition: all 0.25s;
  position: relative;
}

.tab-item.active {
  color: #2563eb;
  background: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.tab-indicator {
  display: none;
}

/* ========== 分类过滤 ========== */

.type-filter {
  background: transparent;
  white-space: nowrap;
  padding: 0;
}

.type-list {
  display: flex;
  justify-content: flex-start;
  gap: 16rpx;
}

.type-item {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #6B7280;
  background: transparent;
  transition: all 0.2s;
}

.type-item.active {
  color: #2563eb;
  background: #EFF6FF;
  font-weight: 600;
  border-radius: 8rpx;
}


/* ========== 动态卡片 ========== */
.post-list {
  padding: 16rpx 24rpx;
}

.post-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  transition: box-shadow 0.2s;
}

.post-card:active {
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

/* 卡片头部 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-avatar-img {
  width: 100%;
  height: 100%;
}

.post-avatar-text {
  font-size: 45rpx;
  line-height: 1;
}


.post-meta {
  flex: 1;
  min-width: 0;
}

.post-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.4;
}

.post-time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 2rpx;
}

.post-type-badge {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 卡片内容 */
.post-body {
  margin-bottom: 20rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.post-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  word-break: break-all;
}

/* 图片九宫格 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.post-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
}

/* 单个图片 - 大图 */
.post-images .post-image:first-child:nth-last-child(1) {
  width: 100%;
  height: 360rpx;
}

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.post-tag {
  font-size: 22rpx;
  color: #2563eb;
  background: #EFF6FF;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

/* 卡片底部 */
.post-footer {
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F3F4F6;
}

.footer-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #6B7280;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.15s;
}

.footer-action:active {
  background: #F3F4F6;
}

.footer-action.liked .action-text {
  color: #EF4444;
}

.footer-action.favorited .action-text {
  color: #2563eb;
}

.action-text {
  font-size: 24rpx;
}

/* ========== Lucide SVG 图标 ========== */
.action-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.load-more.no-more {
  color: #D1D5DB;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2563eb;
  animation: dot-pulse 1s ease-in-out infinite;
}

@keyframes dot-pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ========== 骨架屏 ========== */
.skeleton-list {
  padding: 16rpx 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.sk-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.sk-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E5E7EB;
  margin-right: 16rpx;
}

.sk-meta {
  flex: 1;
}

.sk-line {
  height: 24rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-bottom: 10rpx;
}

.sk-line.short { width: 120rpx; }
.sk-line.mini { width: 80rpx; }
.sk-line.medium { width: 300rpx; }
.sk-line.long { width: 100%; }

.skeleton-pulse {
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}

/* ========== 发布按钮（悬浮） ========== */
.publish-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  transition: transform 0.2s;
}

.publish-fab:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  line-height: 1;
}

/* ========= 征稿类型标签 ========= */
.post-call-type {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* ========= 求助状态标签 ========= */
.post-help-status {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* ========= 文献互助信息 ========= */
.post-help-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #F9FAFB;
  border-radius: 8rpx;
}

.help-reward {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 600;
}

.reward-icon {
  font-size: 28rpx;
}

.reward-text {
  font-size: 24rpx;
}

.help-deadline {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #EF4444;
}

.deadline-icon-img {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.deadline-text {
  font-size: 22rpx;
}

/* ========= 应助按钮（在类型标签旁） ========= */
.post-respond-btn {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 8rpx 24rpx;
  background: #10B981;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  line-height: 1.2;
}

.post-respond-btn:active {
  background: #059669;
  transform: scale(0.95);
}

/* ========= 截止时间行（含右对齐状态标签） ========= */
.help-deadline-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: auto;
}

.help-deadline-row .post-help-status {
  flex-shrink: 0;
}

/* ========== 评论预览区 ========== */
.comments-preview {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.comments-preview-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-comment {
  display: flex;
  gap: 12rpx;
}

.preview-comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-comment-avatar-img {
  width: 100%;
  height: 100%;
}

.preview-comment-avatar-text {
  font-size: 26rpx;
  line-height: 1;
}

.preview-comment-body {
  flex: 1;
  min-width: 0;
}

.preview-comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.preview-comment-author {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

.preview-comment-time {
  font-size: 20rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.preview-comment-content {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
  word-break: break-all;
}

.comments-preview-empty {
  padding: 20rpx 0;
  text-align: center;
}

.preview-empty-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.comments-preview-more {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E5E7EB;
  text-align: center;
  font-size: 24rpx;
  color: #2563eb;
}

/* ===== 嵌套回复样式（广场页预览） ===== */
.comment-replies {
  margin-left: 60rpx;
  border-left: 3rpx solid #E5E7EB;
  padding-left: 0;
}

.replies-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 12rpx;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #2563eb;
  font-weight: 500;
}

.toggle-arrow {
  font-size: 18rpx;
  color: #2563eb;
}

.reply-item {
  display: flex;
  padding: 12rpx 12rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #E5E7EB;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-avatar-img {
  width: 100%;
  height: 100%;
}

.reply-avatar-text {
  font-size: 26rpx;
  line-height: 1;
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 2rpx;
}

.reply-nickname {
  font-size: 22rpx;
  font-weight: 600;
  color: #111827;
}

.reply-time {
  font-size: 18rpx;
  color: #9CA3AF;
}

.reply-to-hint {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-bottom: 2rpx;
}

.reply-to-name {
  color: #2563eb;
  font-weight: 500;
}

.reply-content {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.4;
  word-break: break-all;
  white-space: pre-wrap;
}

.reply-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-top: 6rpx;
  background: #F3F4F6;
}

/* ========== 底部评论输入框 ========== */
.comment-preview-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.input-row-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.input-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-tool-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F3F4F6;
  flex-shrink: 0;
}

.tool-icon {
  width: 36rpx;
  height: 36rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #111827;
}

.input-placeholder {
  color: #9CA3AF;
}

.send-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  height: 56rpx;
  font-size: 24rpx;
  line-height: 1;
  border-radius: 28rpx;
  border: 2rpx solid #D1D5DB;
  background: #fff;
  color: #9CA3AF;
  flex-shrink: 0;
}

.send-btn.send-active {
  background: #EF4444;
  color: #fff;
  border-color: #EF4444;
}

/* ========== 已选图片预览 ========== */
.comment-image-preview {
  position: relative;
  display: inline-block;
  margin-bottom: 16rpx;
}

.comment-image-preview .preview-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.remove-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #EF4444;
  color: #fff;
  font-size: 24rpx;
}

/* ========== 表情包面板 ========== */
.emoji-panel {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.emoji-item {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
}

/* ========== 评论中的图片 ========== */
.preview-comment-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-top: 8rpx;
  background: #F3F4F6;
}

/* ===== 预览评论操作栏（点赞、回复） ===== */
.preview-comment-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
}

.preview-action-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

.preview-action-btn:active {
  background: #F3F4F6;
}

.preview-action-btn.liked {
  color: #EF4444;
}

.preview-action-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.preview-action-btn.small {
  font-size: 20rpx;
  gap: 2rpx;
  padding: 2rpx 6rpx;
}

.preview-action-icon.tiny {
  width: 22rpx;
  height: 22rpx;
}

/* ===== 回复操作栏 ===== */
.reply-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 6rpx;
}

/* ===== 回复提示 ===== */
.input-reply-hint {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  padding: 10rpx 16rpx;
  background: #EFF6FF;
  border-radius: 8rpx;
}

.cancel-reply {
  color: #2563eb;
  font-weight: 500;
  margin-left: auto;
}
