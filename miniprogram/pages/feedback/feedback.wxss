/* pages/feedback/feedback.wxss */
.page {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #f6f6f6;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

/* ========== 类型选择 ========== */
.type-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.type-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  width: 48%;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.02);
  margin-bottom: 16rpx;
}

.type-card-active {
  background: #fff;
  border-color: #2563eb;
  box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.12);
}

.type-card-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eef0f4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-card-icon-active {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
}

.type-card-icon {
  font-size: 30rpx;
  line-height: 1;
}

.type-card-icon-active .type-card-icon {
  filter: brightness(0) invert(1);
}

.type-card-label {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}

.type-card-active .type-card-label {
  color: #2563eb;
  font-weight: 600;
}

.type-card-check {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 28rpx;
  height: 28rpx;
  background: #2563eb;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(37,99,235,0.3);
}

.type-card-check-icon {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
}

/* ========== 内容输入 ========== */
.content-input {
  width: 100%;
  height: 280rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
  box-sizing: border-box;
}

.placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

/* ========== 联系方式 ========== */
.contact-input {
  width: 100%;
  height: 88rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

/* ========== 图片上传 ========== */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #d1d5db;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f9fafb;
}

.image-add-icon {
  font-size: 48rpx;
  color: #9ca3af;
  line-height: 1;
}

.image-add-text {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ========== 提交按钮 ========== */
.submit-wrap {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  text-align: center;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.submitting {
  opacity: 0.7;
}

/* ========== Loading 弹窗 ========== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-dialog {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 56rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #374151;
}
