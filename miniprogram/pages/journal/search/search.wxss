/* ============================================
   pages/journal/search/search.wxss
   期刊搜索页 - 筛选+列表重构版 v3
   ============================================ */

/* ---- 容器 ---- */
.container {
  min-height: 100vh;
  background: #F5F6FA;
  padding-bottom: 40rpx;
}

/* ---- 搜索头部 ---- */
.search-header {
  background: #fff;
  padding: 20rpx 28rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.05);
}

.search-box {
  display: flex;
  align-items: center;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F1F3F8;
  border-radius: 48rpx;
  padding: 12rpx 24rpx;
  height: 72rpx;
  gap: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.search-input-wrap:focus-within {
  border-color: #3B6FF5;
  background: #F8FAFF;
  box-shadow: 0 0 0 6rpx rgba(59, 111, 245, 0.08);
}

.search-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A2E;
  height: 48rpx;
  line-height: 48rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #DDE1EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8893AA;
  flex-shrink: 0;
}

/* ---- 筛选面板 ---- */
.filter-panel {
  padding-top: 18rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 0;
}

.filter-row-bottom {
  padding-bottom: 18rpx;
  justify-content: space-between;
}

.filter-row-title {
  font-size: 24rpx;
  color: #8893AA;
  font-weight: 500;
  flex-shrink: 0;
  min-width: 56rpx;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
  display: flex;
}

/* ---- 筛选 Chip ---- */
.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  background: #F1F3F8;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5A6478;
  margin-right: 12rpx;
  flex-shrink: 0;
  font-weight: 500;
  transition: all 0.18s;
  border: 2rpx solid transparent;
}

.filter-chip.active {
  border-color: transparent;
  color: #fff;
  font-weight: 600;
}

.filter-chip.chip-blue.active    { background: linear-gradient(135deg, #3B6FF5, #5B8AF7); }
.filter-chip.chip-amber.active   { background: linear-gradient(135deg, #F59E0B, #F97316); }
.filter-chip.chip-green.active   { background: linear-gradient(135deg, #10B981, #059669); }
.filter-chip.chip-teal.active    { background: linear-gradient(135deg, #14B8A6, #0D9488); }

/* OA 非OA 特殊态 */
.filter-chip.chip-oa-off {
  background: linear-gradient(135deg, #F1F5F9, #E2E8F0);
  color: #EF4444;
  border-color: #FECACA;
  font-weight: 600;
}

/* ---- 排序按钮组 ---- */
.sort-group {
  display: flex;
  background: #F1F3F8;
  border-radius: 32rpx;
  padding: 4rpx;
  gap: 2rpx;
}

.sort-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
  transition: all 0.18s;
}

.sort-btn.sort-active {
  background: #fff;
  color: #3B6FF5;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.sort-arrow {
  margin-left: 4rpx;
  font-size: 20rpx;
}

/* ---- 对比入口 ---- */
.compare-entry {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  background: #F1F3F8;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5A6478;
  font-weight: 500;
  transition: all 0.18s;
}

.compare-entry.compare-on {
  background: linear-gradient(135deg, #3B6FF5, #5B8AF7);
  color: #fff;
  font-weight: 600;
}

.compare-num {
  background: rgba(255,255,255,0.35);
  color: inherit;
  border-radius: 50%;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

/* ---- 活跃筛选条 ---- */
.active-filters {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: #F8FAFF;
  flex-wrap: wrap;
  border-bottom: 1rpx solid #EEF1F9;
}

.af-label {
  font-size: 24rpx;
  color: #8893AA;
  flex-shrink: 0;
}

.af-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #E8EDFF;
  color: #3B6FF5;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.af-close {
  font-size: 18rpx;
  opacity: 0.7;
}

.af-clear-all {
  margin-left: auto;
  font-size: 22rpx;
  color: #EF4444;
  font-weight: 500;
  padding: 6rpx 16rpx;
}

/* ---- 对比浮层 ---- */
.compare-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -6rpx 24rpx rgba(0,0,0,0.08);
  z-index: 99;
}

.compare-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.compare-info {
  font-size: 28rpx;
  color: #1A1A2E;
  font-weight: 600;
}

.compare-num-highlight {
  color: #3B6FF5;
  font-size: 32rpx;
  margin: 0 4rpx;
}

.compare-actions {
  display: flex;
  gap: 14rpx;
}

.compare-btn {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #3B6FF5, #5B8AF7);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(59, 111, 245, 0.3);
}

.compare-cancel {
  padding: 16rpx 28rpx;
  background: #F1F3F8;
  color: #5A6478;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* ---- 结果区域 ---- */
.result-section {
  padding: 20rpx 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 4rpx 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #8893AA;
}

.result-num {
  color: #3B6FF5;
  font-weight: 700;
  font-size: 30rpx;
}

.result-sort {
  font-size: 22rpx;
  color: #BAC2D6;
  background: #F1F3F8;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* ---- 期刊列表 ---- */
.journal-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

/* ---- 期刊卡片 ---- */
.journal-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: stretch;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(0,0,0,0.04);
  transition: all 0.18s;
}

.journal-card:active {
  transform: scale(0.985);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.06);
}

.journal-card.compare-mode {
  padding-left: 88rpx;  /* 给左侧复选框留空间 */
}

.journal-card.selected {
  border: 2rpx solid #3B6FF5;
  box-shadow: 0 2rpx 20rpx rgba(59, 111, 245, 0.18);
}

/* 选中高亮遮罩 */
.card-selected-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(59, 111, 245, 0.07), rgba(139, 92, 246, 0.04));
  border-radius: 20rpx;
  pointer-events: none;
  z-index: 0;
}

/* ---- 左侧序号色条 ---- */
.card-rank-strip {
  width: 8rpx;
  flex-shrink: 0;
  border-radius: 4rpx;
  margin: 4rpx 0;
}

.strip-top {
  background: linear-gradient(180deg, #3B6FF5, #8B5CF6);
}

.strip-normal {
  background: #E5E9F2;
}

/* ---- 对比勾选框 ---- */
.compare-check {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
}

.checkbox {
  width: 52rpx;
  height: 52rpx;
  border: 3rpx solid #CFD7E6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  transition: all 0.22s ease;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06);
}

.checkbox.checked {
  background: linear-gradient(135deg, #3B6FF5, #6366F1);
  border-color: #3B6FF5;
  box-shadow: 0 2rpx 12rpx rgba(59, 111, 245, 0.35);
  transform: scale(1.05);
}

.check-icon {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

/* ---- 卡片主体 ---- */
.card-body {
  flex: 1;
  padding: 22rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

/* ---- 期刊标题行 ---- */
.card-title-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.journal-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.oa-badge {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #10B981, #059669);
  color: #fff;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

/* ---- 学科分类标签行（始终显示） ---- */
.card-subject-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.subject-tag {
  padding: 4rpx 14rpx;
  background: #E8EDFF;
  color: #3451C7;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- 出版社 + ISSN + 国家 ---- */
.card-meta-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #8893AA;
  overflow: hidden;
}

.meta-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-sep {
  flex-shrink: 0;
  color: #CFD7E6;
}

.meta-country {
  margin-left: auto;
  padding: 3rpx 12rpx;
  background: #F1F3F8;
  border-radius: 8rpx;
  font-weight: 500;
  color: #64748B;
  flex-shrink: 0;
}

/* ---- IF/JCR/CAS 徽章行 ---- */
.card-badge-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.badge-if {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #EBF0FF, #DCE4FF);
  border-radius: 8rpx;
  border: 1rpx solid #B8CBFF;
}

.badge-if-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #4865C7;
}

.badge-if-value {
  font-size: 24rpx;
  font-weight: 800;
  color: #2563EB;
  font-variant-numeric: tabular-nums;
}

.badge-jcr, .badge-cas {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.badge-jcr.q-Q1 { background: #059669; }
.badge-jcr.q-Q2 { background: #2563EB; }
.badge-jcr.q-Q3 { background: #F59E0B; }
.badge-jcr.q-Q4 { background: #EF4444; }

.badge-cas {
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  color: #fff;
}

/* ---- 指标网格（4列，始终显示） ---- */
.card-metrics-grid {
  display: flex;
  gap: 0;
  background: #F8FAFF;
  border-radius: 14rpx;
  overflow: hidden;
}

.metric-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 6rpx;
  gap: 4rpx;
  border-right: 1rpx solid #EEF1F9;
}

.metric-cell:last-child {
  border-right: 0;
}

.m-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E293B;
  font-variant-numeric: tabular-nums;
}

.m-value.m-accent-green { color: #059669; }
.m-value.m-accent-blue  { color: #2563EB; }
.m-value.m-accent-amber { color: #D97706; }

.m-label {
  font-size: 20rpx;
  color: #8893AA;
  font-weight: 500;
}

/* ---- 额外指标行（投稿信息） ---- */
.card-metrics-extra {
  display: flex;
  gap: 0;
  background: #FFF8E8;
  border-radius: 14rpx;
  overflow: hidden;
}

.card-metrics-extra .metric-cell {
  border-right-color: #FDE68A;
}

/* ---- 收录标签行 ---- */
.card-tags-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.card-tag {
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

.tag-blue  { background: #E8EDFF; color: #3451C7; }
.tag-amber { background: #FEF6E0; color: #B66A14; }
.tag-green { background: #E2F7EE; color: #0D6B47; }
.tag-red   { background: #FEEBEB; color: #B91C1C; }

/* ---- 右侧箭头 ---- */
.card-arrow {
  display: flex;
  align-items: center;
  padding: 0 20rpx 0 8rpx;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 42rpx;
  color: #CFD7E6;
  font-weight: 300;
}

/* ---- 加载 ---- */
.loading-more,
.no-more {
  text-align: center;
  padding: 42rpx 0;
  font-size: 26rpx;
  color: #BAC2D6;
}

/* ---- 空状态 ---- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 48rpx 80rpx;
  gap: 18rpx;
}

.empty-icon {
  font-size: 88rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #64748B;
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: #BAC2D6;
  text-align: center;
}
