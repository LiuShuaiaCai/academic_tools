<!--pages/journal/recommend/recommend.wxml-->
<!--智能选荐页-->
<view class="container">

  <!-- 筛选区 -->
  <view class="filter-card">
    <text class="card-title">选择你的需求</text>

    <!-- 学科方向 -->
    <view class="filter-group">
      <text class="filter-label">学科方向</text>
      <input class="filter-input" placeholder="输入学科，如: Medicine" value="{{subject}}" bindinput="onSubjectInput"/>
      
      <!-- 热门学科快捷选择 -->
      <view class="hot-tags">
        <view class="hot-tag {{subject === item ? 'active' : ''}}" 
          wx:for="{{hotSubjects}}" wx:key="*this" 
          bindtap="selectSubject" data-subject="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <!-- OA模式 -->
    <view class="filter-group">
      <text class="filter-label">出版模式</text>
      <view class="toggle-btns">
        <view class="toggle-btn {{is_oa === null ? 'active' : ''}}" bindtap="toggleOA">全部</view>
        <view class="toggle-btn {{is_oa === true ? 'active' : ''}}" bindtap="toggleOA">仅OA</view>
        <view class="toggle-btn {{is_oa === false ? 'active' : ''}}" bindtap="toggleOA">仅非OA</view>
      </view>
    </view>

    <!-- MEDLINE收录 -->
    <view class="filter-group">
      <text class="filter-label">MEDLINE收录</text>
      <view class="toggle-btns">
        <view class="toggle-btn {{is_medline === null ? 'active' : ''}}" bindtap="toggleMEDLINE">不限</view>
        <view class="toggle-btn {{is_medline === true ? 'active' : ''}}" bindtap="toggleMEDLINE">仅收录</view>
      </view>
    </view>

    <!-- PMC期刊 -->
    <view class="filter-group">
      <text class="filter-label">PMC期刊</text>
      <view class="toggle-btns">
        <view class="toggle-btn {{is_pmc_journal === null ? 'active' : ''}}" bindtap="togglePMCJournal">不限</view>
        <view class="toggle-btn {{is_pmc_journal === true ? 'active' : ''}}" bindtap="togglePMCJournal">仅收录</view>
      </view>
    </view>

    <!-- 最低发文量 -->
    <view class="filter-group">
      <text class="filter-label">最低发文量</text>
      <input class="filter-input" type="number" placeholder="如: 100" value="{{min_works}}" bindinput="onMinWorksInput"/>
    </view>

    <!-- 最低被引量 -->
    <view class="filter-group">
      <text class="filter-label">最低被引量</text>
      <input class="filter-input" type="number" placeholder="如: 1000" value="{{min_cited}}" bindinput="onMinCitedInput"/>
    </view>

    <!-- 操作按钮 -->
    <view class="btn-row">
      <view class="btn btn-primary" bindtap="getRecommend">获取推荐</view>
      <view class="btn btn-secondary" bindtap="resetFilters">重置</view>
    </view>
  </view>

  <!-- 推荐结果 -->
  <view class="result-section" wx:if="{{hasSearched}}">
    <text class="result-title">推荐期刊 ({{recommendList.length}})</text>

    <view class="journal-list" wx:if="{{recommendList.length > 0}}">
      <view class="journal-card" wx:for="{{recommendList}}" wx:key="_id" 
        bindtap="goToDetail" data-id="{{item._id}}">
        
        <view class="card-body">
          <view class="journal-title">
            <text>{{item.title}}</text>
            <view class="oa-badge" wx:if="{{item.is_open_access}}">OA</view>
          </view>

          <view class="journal-meta">
            <text wx:if="{{item.publisher}}">{{item.publisher}}</text>
            <text wx:if="{{item.publisher && item.issn_print}}"> · </text>
            <text wx:if="{{item.issn_print}}">ISSN: {{item.issn_print}}</text>
          </view>

          <view class="journal-metrics">
            <view class="metric-item" wx:if="{{item.works_count_latest}}">
              <text class="metric-value">{{item.works_count_latest}}</text>
              <text class="metric-label">发文</text>
            </view>
            <view class="metric-item" wx:if="{{item.cited_by_count_latest}}">
              <text class="metric-value">{{item.cited_by_count_latest}}</text>
              <text class="metric-label">被引</text>
            </view>
            <view class="metric-item" wx:if="{{item.h_index_latest}}">
              <text class="metric-value">{{item.h_index_latest}}</text>
              <text class="metric-label">h指数</text>
            </view>
          </view>

          <view class="tag-row">
            <view class="tag doaj" wx:if="{{item.is_in_doaj}}">DOAJ</view>
            <view class="tag medline" wx:if="{{item.is_medline_current}}">MEDLINE</view>
            <view class="tag pubmed" wx:if="{{item.pubmed_article_count > 0}}">PubMed:{{item.pubmed_article_count}}</view>
            <view class="tag pmc" wx:if="{{item.pmc_article_count > 0}}">PMC:{{item.pmc_article_count}}</view>
          </view>
        </view>

        <view class="card-arrow">
          <text>›</text>
        </view>
      </view>
    </view>

    <view class="empty-hint" wx:if="{{!loading && recommendList.length === 0}}">
      <text>未找到符合条件的期刊</text>
    </view>

    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 初始状态 -->
  <view class="initial-state" wx:if="{{!hasSearched}}">
    <text class="initial-icon">🎯</text>
    <text class="initial-text">设置筛选条件，获取智能推荐</text>
  </view>

</view>
