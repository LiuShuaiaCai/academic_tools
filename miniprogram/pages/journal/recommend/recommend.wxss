/* ============================================
   pages/journal/recommend/recommend.wxss
   智能选刊页 - 统一设计系统 v2
   ============================================ */

/* ---- 容器 ---- */
.container {
  padding: 20rpx 24rpx;
  padding-bottom: 80rpx;
  background: linear-gradient(180deg, #F0F4FF 0%, #F6F6F6 30%);
  min-height: 100vh;
}

/* ---- 筛选卡片 ---- */
.filter-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.filter-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #2563eb, #6366F1);
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-title::before {
  content: '🎯';
  font-size: 32rpx;
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
  margin-bottom: 14rpx;
  display: block;
}

.filter-input {
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #111827;
  transition: border-color 0.2s;
}

.filter-input:focus {
  border-color: #2563eb;
  background: #fff;
}

/* ---- 热门学科标签 ---- */
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.hot-tag {
  padding: 12rpx 22rpx;
  background: #F3F4F6;
  border-radius: 22rpx;
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.hot-tag.active {
  background: linear-gradient(135deg, #2563eb, #6366F1);
  color: #fff;
  border-color: #2563eb;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.25);
}

/* ---- 切换按钮 ---- */
.toggle-btns {
  display: flex;
  gap: 10rpx;
}

.toggle-btn {
  padding: 14rpx 28rpx;
  background: #F3F4F6;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.toggle-btn.active {
  background: linear-gradient(135deg, #2563eb, #6366F1);
  color: #fff;
  border-color: #2563eb;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.25);
}

/* ---- 按钮行 ---- */
.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.btn {
  flex: 1;
  padding: 22rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  transition: all 0.15s;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #6366F1);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(37, 99, 235, 0.35);
}

.btn-secondary {
  background: #F3F4F6;
  color: #6B7280;
  border: 2rpx solid #E5E7EB;
}

/* ---- 结果区 ---- */
.result-section {
  margin-top: 8rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.result-title::before {
  content: '';
  width: 6rpx;
  height: 26rpx;
  background: linear-gradient(180deg, #2563eb, #6366F1);
  border-radius: 3rpx;
}

/* ---- 期刊卡片 ---- */
.journal-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.journal-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-left: 4rpx solid transparent;
  transition: all 0.15s;
}

.journal-card:active {
  border-left-color: #2563eb;
  background: #F9FBFF;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.journal-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.oa-badge {
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, #10B981, #059669);
  color: #fff;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.journal-meta {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.journal-metrics {
  display: flex;
  gap: 28rpx;
  margin-bottom: 14rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
  font-variant-numeric: tabular-nums;
}

.metric-label {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* ---- 标签 ---- */
.tag-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag.doaj {
  background: #DBEAFE;
  color: #1E40AF;
}

.tag.medline {
  background: #FEF3C7;
  color: #92400E;
}

.tag.pubmed {
  background: #FEF3C7;
  color: #92400E;
}

.tag.pmc {
  background: #D1FAE5;
  color: #065F46;
}

.card-arrow {
  color: #D1D5DB;
  font-size: 36rpx;
  font-weight: 300;
}

/* ---- 状态 ---- */
.loading-more,
.empty-hint {
  text-align: center;
  padding: 60rpx;
  color: #9CA3AF;
  font-size: 26rpx;
}

.initial-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  gap: 20rpx;
}

.initial-icon {
  font-size: 88rpx;
}

.initial-text {
  font-size: 28rpx;
  color: #9CA3AF;
  text-align: center;
}
