/* pages/reviews/reviews.wxss */
page { background: #F6F6F6; }
.page-container { padding-bottom: 120rpx; }
.list-body { padding: 16rpx; }
.rev-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); border-left: 6rpx solid #E5E7EB; }
.rev-card.urgent { border-left-color: #EF4444; }
.rev-header { display: flex; justify-content: space-between; align-items: flex-start; }
.rev-title { flex: 1; font-size: 28rpx; font-weight: 600; color: #111827; }
.rev-days { font-size: 28rpx; font-weight: 700; color: #6B7280; }
.rev-days.red { color: #EF4444; }
.rev-journal { font-size: 24rpx; color: #6B7280; margin-top: 8rpx; }
.rev-deadline { font-size: 24rpx; color: #9CA3AF; margin-top: 4rpx; text-align: left; }
.rev-status { display: inline-block; margin-top: 12rpx; font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx; background: #FEF3C7; color: #F59E0B; }
.rev-status.submitted { background: #D1FAE5; color: #10B981; }
.rev-status.done { background: #F3F4F6; color: #6B7280; }
.rev-actions { display: flex; justify-content: flex-end; gap: 16rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #F3F4F6; }
.sub-edit-btn { font-size: 24rpx; color: #2563eb; padding: 8rpx 20rpx; }
.sub-del-btn { font-size: 24rpx; color: #EF4444; padding: 8rpx 20rpx; }
.fab { position: fixed; right: 40rpx; bottom: 160rpx; width: 96rpx; height: 96rpx; border-radius: 50%; background: #EF4444; color: #fff; font-size: 60rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(239,68,68,0.4); }
.empty-box { text-align: center; padding: 100rpx 40rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; background: #fff; border-radius: 16rpx; }
.empty-box text:first-child { font-size: 80rpx; }
.btn-add-first { margin-top: 20rpx; background: #EF4444; color: #fff; font-size: 28rpx; border-radius: 40rpx; padding: 16rpx 48rpx; }
.form-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: none; align-items: flex-end; }
.form-overlay.active { display: flex; }
.form-sheet { background: #fff; border-radius: 32rpx 32rpx 0 0; width: 100%; max-height: 90vh; display: flex; flex-direction: column; }
.form-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 32rpx 16rpx; border-bottom: 1rpx solid #E5E7EB; flex-shrink: 0; }
.form-title { font-size: 32rpx; font-weight: 700; color: #111827; }
.form-close { font-size: 36rpx; color: #6B7280; padding: 8rpx; }
.form-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; font-weight: 500; color: #374151; margin-bottom: 8rpx; display: block; }
.required { color: #EF4444; }
.form-input { width: 100%; padding: 20rpx; border: 1rpx solid #E5E7EB; border-radius: 12rpx; font-size: 28rpx; color: #111827; box-sizing: border-box; }
.form-picker { padding: 20rpx; border: 1rpx solid #E5E7EB; border-radius: 12rpx; font-size: 28rpx; color: #374151; display: flex; justify-content: space-between; }
.form-textarea { width: 100%; padding: 20rpx; border: 1rpx solid #E5E7EB; border-radius: 12rpx; font-size: 28rpx; color: #111827; min-height: 120rpx; box-sizing: border-box; }
.radio-group { display: flex; gap: 16rpx; flex-wrap: wrap; }
.radio-item { padding: 12rpx 24rpx; border: 1rpx solid #E5E7EB; border-radius: 40rpx; font-size: 26rpx; color: #6B7280; }
.radio-item.active { background: #DBEAFE; border-color: #2563eb; color: #2563eb; }
.form-footer { display: flex; gap: 16rpx; padding: 20rpx 32rpx 48rpx; border-top: 1rpx solid #E5E7EB; flex-shrink: 0; }
.btn-cancel { flex: 1; background: #F3F4F6; color: #374151; border-radius: 12rpx; font-size: 28rpx; padding: 24rpx 0; }
.btn-confirm { flex: 2; background: #2563eb; color: #fff; border-radius: 12rpx; font-size: 28rpx; padding: 24rpx 0; }

/* 审稿决定弹窗 */
.decision-sheet { padding-bottom: 48rpx; }
.decision-info { padding: 16rpx 0 24rpx; border-bottom: 1rpx solid #F3F4F6; margin-bottom: 24rpx; }
.decision-paper { font-size: 30rpx; font-weight: 600; color: #111827; margin-bottom: 8rpx; }
.decision-journal { font-size: 24rpx; color: #6B7280; }
.decision-options { display: flex; justify-content: space-between; gap: 16rpx; margin-bottom: 24rpx; }
.decision-btn { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24rpx 8rpx; border-radius: 16rpx; border: 2rpx solid #E5E7EB; background: #FFF; transition: all 0.2s; }
.decision-btn.selected { border-width: 3rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); }
.decision-btn.accept { color: #059669; }
.decision-btn.accept.selected { background: #ECFDF5; border-color: #059669; }
.decision-btn.minor { color: #D97706; }
.decision-btn.minor.selected { background: #FFFBEB; border-color: #D97706; }
.decision-btn.major { color: #DC2626; }
.decision-btn.major.selected { background: #FEF2F2; border-color: #DC2626; }
.decision-btn.reject { color: #6B7280; }
.decision-btn.reject.selected { background: #F3F4F6; border-color: #6B7280; }
.decision-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.sub-decision-btn { font-size: 24rpx; color: #2563eb; padding: 8rpx 20rpx; border-radius: 8rpx; background: #EFF6FF; }
