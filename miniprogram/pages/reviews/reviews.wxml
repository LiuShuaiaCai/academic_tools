<!--pages/reviews/reviews.wxml-->
<view class="sub-page" style="--primary-color:{{theme.primary}};--primary-dark:{{theme.primaryDark}};--primary-light:{{theme.primaryLight}};--primary-light-text:{{theme.primaryLightText}};--primary-shadow:{{theme.primaryShadow}}">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索论文标题、期刊..." bindinput="onSearch" value="{{searchKeyword}}"/>
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</view>
    </view>
  </view>

  <!-- 提示栏 + 高级筛选 -->
  <view class="filter-tips">
    <view class="tip-btn tip-all {{quickFilter === 'all' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="all">全部 {{totalCount}}</view>
    <view class="tip-btn tip-info {{quickFilter === 'incomplete' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="incomplete"> 未完成 {{incompleteCount}}</view>
    <view class="tip-btn tip-urgent {{quickFilter === 'near' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="near"> 急需处理 {{nearCount}}</view>
    <view class="tip-btn tip-warn {{quickFilter === 'urgent' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="urgent"> 特别紧急 {{urgentCount}}</view>
    <view class="adv-toggle {{showAdvanced ? 'active' : ''}}" bindtap="toggleAdvanced">
      <text>高级筛选</text>
      <text class="adv-arrow">{{showAdvanced ? '▲' : '▼'}}</text>
    </view>
  </view>

  <!-- 高级筛选面板 -->
  <view class="adv-panel" wx:if="{{showAdvanced}}">
    <!-- 状态 -->
    <view class="adv-row">
      <text class="adv-label">状态</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advStatusOptions}}" range-key="label" value="{{advStatusIndex}}" bindchange="onAdvStatusChange">
          <view class="adv-picker-text">{{advStatusLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advStatus}}" bindtap="clearAdvStatus">✕</view>
      </view>
    </view>
    <!-- 期刊 -->
    <view class="adv-row">
      <text class="adv-label">期刊</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advJournalOptions}}" range-key="label" value="{{advJournalIndex}}" bindchange="onAdvJournalChange">
          <view class="adv-picker-text">{{advJournalLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advJournal}}" bindtap="clearAdvJournal">✕</view>
      </view>
    </view>
    <!-- 截止时间区间 -->
    <view class="adv-row">
      <text class="adv-label">截止时间</text>
      <view class="adv-date-wrap">
        <view class="adv-date-item">
          <picker class="adv-picker-wrap" mode="date" value="{{advDeadlineFrom}}" bindchange="onAdvDeadlineFromChange">
            <view class="adv-picker-text">{{advDeadlineFrom || '起始日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advDeadlineFrom}}" bindtap="clearAdvDeadlineFrom">✕</view>
        </view>
        <text class="adv-sep">~</text>
        <view class="adv-date-item">
          <picker class="adv-picker-wrap" mode="date" value="{{advDeadlineTo}}" bindchange="onAdvDeadlineToChange">
            <view class="adv-picker-text">{{advDeadlineTo || '截止日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advDeadlineTo}}" bindtap="clearAdvDeadlineTo">✕</view>
        </view>
      </view>
    </view>
    <!-- 操作按钮 -->
    <view class="adv-actions">
      <view class="adv-btn-reset" bindtap="resetAdvanced">重置全部</view>
    </view>
  </view>

  <!-- 列表 -->
  <view class="sub-list">
    <view wx:if="{{!filteredList.length && !searchLoading}}" class="empty-box">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无审稿任务</text>
    </view>

    <view
      class="paper-card"
      wx:for="{{filteredList}}"
      wx:key="_id"
      bindtap="showEditForm"
      data-id="{{item._id}}"
    >
      <view class="card-body">
        <!-- 标题 -->
        <view class="card-title-row">
          <text class="card-title" user-select="true">{{item.paperTitle}}</text>
        </view>

        <!-- 期刊 -->
        <view class="card-journal-row">
          <text class="card-journal" user-select="true">{{item.journal || '未设置期刊'}}<text wx:if="{{item.reviewId}}"> #{{item.reviewId}}</text><text wx:if="{{item.roundLabel}}"> {{item.roundLabel}}</text></text>
        </view>

        <!-- 决定 + 状态 同一行 -->
        <view class="card-status-row">
          <text class="card-decision-label" user-select="true">{{item.decisionLabel}}</text>
          <view class="card-status-right">
            <text class="card-status-text {{item.overdueClass}}" wx:if="{{item.overdueLabel}}">{{item.overdueLabel}}</text>
            <view class="card-switch" catchtap="toggleComplete" data-id="{{item._id}}" data-completed="{{item.completed}}">
              <view class="card-switch-track {{item.completed ? 'on' : ''}}">
                <view class="card-switch-knob"></view>
              </view>
            </view>
          </view>
        </view>

        <!-- 系统链接 + 编辑邮箱 同行 -->
        <view class="card-link-row" wx:if="{{item.systemUrl || item.editorEmail}}">
          <view class="card-link-left" catchtap="onOpenSystemUrl" data-url="{{item.systemUrl}}" wx:if="{{item.systemUrl}}">
            <text class="card-link-text">🔗 打开审稿系统</text>
          </view>
          <view class="card-link-right" catchtap="onOpenEmail" data-email="{{item.editorEmail}}" wx:if="{{item.editorEmail}}">
            <text class="card-link-text">✉️ {{item.editorEmail}}</text>
          </view>
        </view>
      </view>

      <!-- 卡片底部操作 -->
      <view class="card-footer" catchtap="doNothing">
        <view class="footer-btn" catchtap="showDecision" data-id="{{item._id}}">✏️ 录入决定</view>
        <view class="footer-del footer-btn" catchtap="deleteItem" data-id="{{item._id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more" wx:if="{{filteredList.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{!searchKeyword && !hasMore}}">— 没有更多了 —</text>
  </view>

  <!-- 搜索 loading 浮动遮罩 -->
  <view class="search-loading-mask" wx:if="{{searchLoading}}" catchtouchmove="true">
    <view class="search-loading-box">
      <view class="search-loading-spinner"></view>
      <text class="search-loading-text">搜索中...</text>
    </view>
  </view>

  <!-- FAB 悬浮按钮 -->
  <view class="fab" bindtap="showAddForm">+</view>

  <!-- 链接复制弹窗 -->
  <view class="link-modal-mask" wx:if="{{showLinkModal}}" catchtouchmove="true">
    <view class="link-modal">
      <view class="link-modal-header">
        <text class="link-modal-title">🔗 打开审稿系统</text>
        <text class="link-modal-close" bindtap="onCloseLinkModal">✕</text>
      </view>
      <view class="link-modal-body">
        <text class="link-modal-desc">微信小程序无法直接打开外部链接，请复制后使用系统浏览器访问：</text>
        <view class="link-modal-url-box" selectable="true">
          <text class="link-modal-url">{{currentUrl}}</text>
        </view>
      </view>
      <view class="link-modal-footer">
        <button class="link-btn-copy" bindtap="onCopyLinkModal">📋 复制链接</button>
        <button class="link-btn-cancel" bindtap="onCloseLinkModal">取消</button>
      </view>
    </view>
  </view>

  <!-- 表单组件 -->
  <review-form
    id="reviewForm"
    show="{{showForm}}"
    is-edit="{{isEdit}}"
    edit-id="{{editId}}"
    bind:save="onFormSave"
    bind:cancel="onFormCancel"
    bind:decisionsubmit="onDecisionSubmit"
  />
</view>
