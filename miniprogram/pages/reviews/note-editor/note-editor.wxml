<!--pages/reviews/note-editor/note-editor.wxml-->
<view class="editor-page">
  <view class="editor-header">
    <view class="editor-cancel" bindtap="onCancel">取消</view>
    <view class="editor-title">审稿意见</view>
    <view class="editor-save" bindtap="onSave">保存</view>
  </view>
  <textarea
    class="editor-textarea"
    placeholder="输入审稿意见..."
    value="{{note}}"
    bindinput="onInput"
    focus="{{true}}"
    auto-height
    show-confirm-bar="{{false}}"
  ></textarea>
</view>
