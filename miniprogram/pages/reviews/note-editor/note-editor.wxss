/* pages/reviews/note-editor/note-editor.wxss */
.editor-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff;
}

.editor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #E5E7EB;
  background: #fff;
}

.editor-cancel {
  font-size: 28rpx;
  color: #6B7280;
  padding: 10rpx 20rpx;
}

.editor-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.editor-save {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 500;
  padding: 10rpx 20rpx;
}

.editor-textarea {
  flex: 1;
  width: 100%;
  padding: 30rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #1F2937;
  background: #fff;
  box-sizing: border-box;
}
