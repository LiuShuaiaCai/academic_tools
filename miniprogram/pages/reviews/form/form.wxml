<!--pages/reviews/form/form.wxml-->
<!-- 编辑表单弹层 -->
<view class="form-overlay {{show ? 'active' : ''}}" bindtap="closeForm">
  <view class="form-sheet" catchtap="doNothing">
    <view class="form-header">
      <view class="form-title">{{isEdit ? '编辑审稿' : '添加审稿'}}</view>
      <view class="form-close" bindtap="closeForm">✕</view>
    </view>
    <scroll-view scroll-y class="form-body">

      <!-- 基本信息区 -->
      <view class="form-section">
        <view class="section-label-row">
          <view class="section-label">基本信息</view>
          <view class="recognize-btn {{emailRecognizing ? 'recognizing' : ''}}" bindtap="recognizeEmail">
            <text class="recognize-icon">{{emailRecognizing ? '⏳' : '🔍'}}</text>
            <text class="recognize-text">{{emailRecognizing ? '识别中...' : '智能识别'}}</text>
          </view>
        </view>

        <!-- 1. 论文标题* -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">📝</text> 论文标题 <text class="required">*</text></view>
          <input class="form-input" placeholder="审稿论文标题" bindinput="onFormInput" data-field="paperTitle" value="{{form.paperTitle}}"/>
        </view>

        <!-- 2. 期刊/会议* -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">📚</text> 期刊/会议 <text class="required">*</text></view>
          <input class="form-input" placeholder="来稿期刊/会议" bindinput="onFormInput" data-field="journal" value="{{form.journal}}"/>
        </view>

        <!-- 3. 邀请时间* -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">📅</text> 邀请时间 <text class="required">*</text></view>
          <picker mode="date" value="{{form.invitedDate}}" bindchange="onInvitedDateChange">
            <view class="form-picker {{form.invitedDate ? '' : 'placeholder'}}">
              <text style="flex:1">{{form.invitedDate || '请选择邀请日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 4. 截止时间* -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">⏰</text> 截止时间 <text class="required">*</text></view>
          <picker mode="date" value="{{form.deadline}}" bindchange="onDeadlineChange">
            <view class="form-picker {{form.deadline ? '' : 'placeholder'}}">
              <text style="flex:1">{{form.deadline || '请选择截止日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 详细信息区 -->
      <view class="form-section">
        <view class="section-label">详细信息</view>

        <!-- 5. 审稿ID -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">🏷️</text> 审稿ID</view>
          <input class="form-input" placeholder="如 #XX-2026-01" bindinput="onFormInput" data-field="reviewId" value="{{form.reviewId}}"/>
        </view>

        <!-- 6. 轮次 -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">🔄</text> 轮次 <text class="label-hint">同一稿件第几轮</text></view>
          <picker mode="selector" range="{{roundOptions}}" range-key="label" value="{{form.roundIdx}}" bindchange="onRoundChange">
            <view class="form-picker {{form.roundIdx ? '' : 'placeholder'}}">
              <text style="flex:1">{{form.roundIdx ? roundOptions[form.roundIdx].label : '请选择轮次'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 7. 关联审稿 -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">🔗</text> 关联审稿 <text class="label-hint">同一稿件多轮审稿</text></view>
          <picker mode="selector" range="{{relatedReviewOptions}}" range-key="title" value="{{form.relatedReviewIdx}}" bindchange="onRelatedReviewChange">
            <view class="form-picker {{form.relatedReviewTitle ? '' : 'placeholder'}}">
              <text style="flex:1">{{form.relatedReviewTitle || '不关联'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 8. 审稿系统链接 -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">🌐</text> 审稿系统链接</view>
          <input class="form-input" placeholder="https://... 审稿系统地址" bindinput="onFormInput" data-field="systemUrl" value="{{form.systemUrl}}"/>
        </view>

        <!-- 9. 编辑联系邮箱 -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">✉️</text> 编辑联系邮箱</view>
          <input class="form-input" placeholder="编辑联系邮箱" bindinput="onFormInput" data-field="editorEmail" value="{{form.editorEmail}}"/>
        </view>
      </view>

      <!-- 决定与稿件区 -->
      <view class="form-section">
        <view class="section-label">决定与稿件</view>

        <!-- 10. 审稿决定 -->
        <view class="form-group">
          <view class="form-label"><text class="label-icon">✅</text> 审稿决定</view>
          <picker mode="selector" range="{{decisionOptions}}" range-key="label" value="{{form.decisionIdx}}" bindchange="onDecisionChange">
            <view class="form-picker {{form.decisionIdx >= 0 ? '' : 'placeholder'}}">
              <text style="flex:1">{{form.decisionIdx >= 0 ? decisionOptions[form.decisionIdx].label : '请选择决定'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 11. 上传稿件 -->
        <view class="form-group">
          <view class="form-label-row">
            <view class="form-label"><text class="label-icon">📎</text> 上传稿件 <text class="label-hint">PDF/Word，最大50MB</text></view>
          </view>
          <!-- 未上传时 -->
          <view wx:if="{{!form.manuscript || !form.manuscript.fileID}}" class="manuscript-upload-area" bindtap="chooseManuscript">
            <view class="manuscript-upload-icon">+</view>
            <view class="manuscript-upload-text">点击上传稿件文件</view>
            <view class="manuscript-upload-hint">支持 PDF / Word，最大 50MB</view>
          </view>
          <!-- 已上传时 -->
          <view wx:else class="manuscript-file-card" bindtap="previewManuscript">
            <view class="manuscript-file-info">
              <view class="manuscript-file-icon">{{form.manuscript.fileType === 'pdf' ? '📕' : '📘'}}</view>
              <view class="manuscript-file-detail">
                <view class="manuscript-file-name">{{form.manuscript.fileName}}</view>
                <view class="manuscript-file-meta">{{form.manuscript.fileSizeText}}<text wx:if="{{form.manuscript.uploadTime}}"> · {{form.manuscript.uploadTime}}</text></view>
              </view>
            </view>
            <view class="manuscript-file-actions">
              <view class="manuscript-action-btn" catchtap="previewManuscript">预览</view>
              <view class="manuscript-action-btn manuscript-action-del" catchtap="removeManuscript">删除</view>
            </view>
          </view>
          <!-- 上传进度 -->
          <view wx:if="{{manuscriptUploading}}" class="manuscript-progress">
            <progress percent="{{manuscriptUploadPercent}}" stroke-width="4" activeColor="#2563EB" backgroundColor="#E5E7EB"/>
            <text class="manuscript-progress-text">上传中 {{manuscriptUploadPercent}}%</text>
          </view>
        </view>
      </view>

      <!-- 审稿意见区 -->
      <view class="form-section">
        <view class="form-label-row">
          <view class="form-label"><text class="label-icon">💬</text> 审稿意见</view>
          <view class="decision-btns">
            <view class="template-btn ai-review-btn" bindtap="startAiReview" wx:if="{{!aiReviewLoading}}">
              <text class="template-btn-icon">🤖</text>
              <text class="template-btn-text">AI审稿</text>
            </view>
            <view class="template-btn" bindtap="showTemplateModal">
              <text class="template-btn-icon">📋</text>
              <text class="template-btn-text">模板</text>
            </view>
            <view class="template-btn view-note-btn" bindtap="showNotePreview">
              <text class="template-btn-icon">👁️</text>
              <text class="template-btn-text">全屏</text>
            </view>
            <view class="template-btn clear-note-btn" bindtap="clearNote">
              <text class="template-btn-icon">🗑️</text>
              <text class="template-btn-text">清空</text>
            </view>
          </view>
        </view>
        <!-- AI审稿进度 -->
        <view wx:if="{{aiReviewLoading}}" class="manuscript-progress">
          <view class="ai-review-loading">
            <view class="ai-review-spinner"></view>
            <text class="ai-review-loading-text">AI 正在分析稿件，请稍候...</text>
          </view>
        </view>
        <textarea class="form-textarea" placeholder="审稿意见和笔记..." bindinput="onFormInput" data-field="note" value="{{form.note}}" maxlength="-1"></textarea>
      </view>
      
      <!-- 处理时间线区 -->
      <view class="form-section">
        <view class="form-label"><text class="label-icon">📋</text> 处理时间线 <text class="label-hint">记录处理过程</text></view>

        <view class="tl-add-row">
          <picker class="tl-date-picker" mode="date" value="{{form.tlNewDate}}" data-field="tlNewDate" bindchange="onFormInput">
            <view class="tl-picker-box">
              <text class="tl-picker-text {{form.tlNewDate ? '' : 'tl-placeholder'}}">{{form.tlNewDate || '选择日期'}}</text>
              <text class="tl-picker-text tl-arrow">▼</text>
            </view>
          </picker>
          <picker class="tl-event-picker" range="{{tlEventOptions}}" range-key="label" value="{{form.tlNewEventIdx}}" data-field="tlNewEventIdx" bindchange="onFormInput">
            <view class="tl-picker-box">
              <text class="tl-picker-text {{form.tlNewEventIdx>=0 ? '' : 'tl-placeholder'}}">{{form.tlNewEventIdx>=0 ? tlEventOptions[form.tlNewEventIdx].label : '选择事件'}}</text>
              <text class="tl-picker-text tl-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="tl-remark-row">
          <input class="tl-remark-input" placeholder="备注（选填）" value="{{form.tlNewRemark}}" data-field="tlNewRemark" bindinput="onFormInput"/>
          <view class="tl-add-btn" bindtap="addTimelineItem">
            <text class="tl-add-text">添加</text>
          </view>
        </view>

        <!-- 已有时间线事件列表 -->
        <view class="tl-list" wx:if="{{form.timelineList.length > 0}}">
          <view class="tl-item-card" wx:for="{{form.timelineList}}" wx:key="index">
            <view class="tl-card-left">
              <view class="tl-card-dot" style="background:{{item.dotColor}}"></view>
            </view>
            <view class="tl-card-content">
              <view class="tl-card-top">
                <text class="tl-card-date">{{item.date}}</text>
                <text class="tl-card-event" style="color:{{item.dotColor}}">{{item.event}}</text>
              </view>
              <text class="tl-card-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
            </view>
            <view class="tl-card-del" data-i="{{index}}" catchtap="removeTimelineItem">
              <text>×</text>
            </view>
          </view>
        </view>
      </view>

    </scroll-view>
    <view class="form-footer">
      <button class="btn-cancel" bindtap="closeForm">取消</button>
      <button class="btn-confirm" bindtap="saveForm">保存</button>
    </view>
  </view>
</view>

<reminder-quota-tip show="{{showQuotaTip}}" bind:cancel="onQuotaTipCancel" bind:confirm="onQuotaTipConfirm" />

<!-- 审稿决定弹窗 -->
<view class="form-overlay {{showDecisionModal ? 'active' : ''}}">
  <view class="form-sheet decision-sheet" catchtap="doNothing">
    <view class="form-header">
      <view class="form-title">审稿决定</view>
      <view class="form-close" bindtap="closeDecision">✕</view>
    </view>
    <view class="form-body">
      <view class="form-group">
        <view class="form-label">审稿决定</view>
        <view class="decision-options decision-options-grid">
          <view
            class="decision-btn {{item.value}} {{decision === item.value ? 'selected' : ''}}"
            wx:for="{{decisionOptions}}"
            wx:key="value"
            bindtap="setDecision"
            data-decision="{{item.value}}">
            <text class="decision-icon">{{item.icon}}</text>
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 上传稿件 -->
      <view class="form-group">
        <view class="form-label-row">
          <view class="form-label"><text class="label-icon">📎</text> 上传稿件 <text class="label-hint">PDF/Word，最大50MB</text></view>
        </view>
        <!-- 未上传时 -->
        <view wx:if="{{!form.manuscript || !form.manuscript.fileID}}" class="manuscript-upload-area" bindtap="chooseManuscript">
          <view class="manuscript-upload-icon">+</view>
          <view class="manuscript-upload-text">点击上传稿件文件</view>
          <view class="manuscript-upload-hint">支持 PDF / Word，最大 50MB</view>
        </view>
        <!-- 已上传时 -->
        <view wx:else class="manuscript-file-card" bindtap="previewManuscript">
          <view class="manuscript-file-info">
            <view class="manuscript-file-icon">{{form.manuscript.fileType === 'pdf' ? '📕' : '📘'}}</view>
            <view class="manuscript-file-detail">
              <view class="manuscript-file-name">{{form.manuscript.fileName}}</view>
              <view class="manuscript-file-meta">{{form.manuscript.fileSizeText}}<text wx:if="{{form.manuscript.uploadTime}}"> · {{form.manuscript.uploadTime}}</text></view>
            </view>
          </view>
          <view class="manuscript-file-actions">
            <view class="manuscript-action-btn" catchtap="previewManuscript">预览</view>
            <view class="manuscript-action-btn manuscript-action-del" catchtap="removeManuscript">删除</view>
          </view>
        </view>
        <!-- 上传进度 -->
        <view wx:if="{{manuscriptUploading}}" class="manuscript-progress">
          <progress percent="{{manuscriptUploadPercent}}" stroke-width="4" activeColor="#2563EB" backgroundColor="#E5E7EB"/>
          <text class="manuscript-progress-text">上传中 {{manuscriptUploadPercent}}%</text>
        </view>
      </view>

      <view class="form-group">
        <view class="form-label-row">
          <view class="form-label"><text class="label-icon">💬</text> 审稿意见</view>
          <view class="decision-btns">
            <view class="template-btn ai-review-btn" bindtap="startAiReview" wx:if="{{!aiReviewLoading}}">
              <text class="template-btn-icon">🤖</text>
              <text class="template-btn-text">AI审稿</text>
            </view>
            <view class="template-btn" bindtap="showTemplateModal">
              <text class="template-btn-icon">📋</text>
              <text class="template-btn-text">模板</text>
            </view>
            <view class="template-btn view-note-btn" bindtap="showNotePreview">
              <text class="template-btn-icon">👁️</text>
              <text class="template-btn-text">全屏</text>
            </view>
            <view class="template-btn clear-note-btn" bindtap="clearNote">
              <text class="template-btn-icon">🗑️</text>
              <text class="template-btn-text">清空</text>
            </view>
          </view>
        </view>
        <!-- AI审稿进度 -->
        <view wx:if="{{aiReviewLoading}}" class="manuscript-progress">
          <view class="ai-review-loading">
            <view class="ai-review-spinner"></view>
            <text class="ai-review-loading-text">AI 正在分析稿件，请稍候...</text>
          </view>
        </view>
        <textarea class="form-textarea" placeholder="审稿意见..." bindinput="onFormInput" data-field="note" value="{{form.note}}" maxlength="-1"></textarea>
      </view>
    </view>
    <view class="form-footer">
      <button class="btn-cancel" bindtap="closeDecision">取消</button>
      <button class="btn-confirm" bindtap="submitDecision">提交决定</button>
    </view>
  </view>
</view>

<!-- 审稿模板弹窗 -->
<view class="form-overlay {{showTemplateModal ? 'active' : ''}}" bindtap="closeTemplateModal">
  <view class="form-sheet template-sheet" catchtap="doNothing">
    <view class="form-header">
      <view class="form-title">选择审稿模板</view>
      <view class="form-close" bindtap="closeTemplateModal">✕</view>
    </view>
    <scroll-view scroll-y class="form-body">

      <!-- 出版商筛选 -->
      <view class="publisher-filter">
        <view class="publisher-tag {{selectedPublisher === '' ? 'active' : ''}}" bindtap="filterByPublisher" data-publisher="">全部</view>
        <view class="publisher-tag {{selectedPublisher === item.id ? 'active' : ''}}"
          wx:for="{{templatePublishers}}" wx:key="id"
          bindtap="filterByPublisher" data-publisher="{{item.id}}">
          {{item.name}}
        </view>
      </view>

      <!-- 未选择模板时：显示模板列表 -->
      <view wx:if="{{!selectedTemplate}}" class="template-list">
        <view class="template-card" wx:for="{{filteredTemplates}}" wx:key="_index" bindtap="selectTemplate" data-idx="{{index}}">
          <view class="template-card-icon">{{item.icon}}</view>
          <view class="template-card-info">
            <view class="template-card-name">{{item.name}}</view>
            <view class="template-card-meta">
              <text class="template-card-publisher" style="color:{{publisherMap[item.publisher] ? publisherMap[item.publisher].color : '#6B7280'}}">
                {{publisherMap[item.publisher] ? publisherMap[item.publisher].name : item.publisher}}
              </text>
              <text class="template-card-count">{{item.items.length}} 项</text>
            </view>
          </view>
          <text class="template-card-arrow">›</text>
        </view>
        <view class="template-empty" wx:if="{{filteredTemplates.length === 0}}">
          <text>该出版商暂无模板</text>
        </view>
      </view>

      <!-- 已选择模板时：显示模板表单 -->
      <view wx:if="{{selectedTemplate}}" class="template-form">
        <view class="template-form-header">
          <view class="template-back" bindtap="backToTemplateList">
            <text>← 返回</text>
          </view>
          <view class="template-form-title">{{selectedTemplate.icon}} {{selectedTemplate.name}}</view>
        </view>

        <view class="template-items">
          <view class="template-item" wx:for="{{selectedTemplate.items}}" wx:key="index">
            <!-- 单选 -->
            <block wx:if="{{item.type === 'radio'}}">
              <view class="template-item-label">{{item.label}}</view>
              <radio-group class="template-radio-group" bindchange="onTemplateRadioChange" data-idx="{{index}}">
                <label class="template-radio-item" wx:for="{{item.options}}" wx:for-item="opt" wx:for-index="optIdx" wx:key="optIdx">
                  <radio class="tmpl-radio" value="{{optIdx}}" color="#2563EB"/>
                  <text class="template-radio-text">{{opt}}</text>
                </label>
              </radio-group>
            </block>
            <!-- 多选 -->
            <block wx:elif="{{item.type === 'checkbox'}}">
              <view class="template-item-label">{{item.label}}</view>
              <checkbox-group class="template-checkbox-group" bindchange="onTemplateCheckboxChange" data-idx="{{index}}">
                <label class="template-checkbox-item" wx:for="{{item.options}}" wx:for-item="opt" wx:for-index="optIdx" wx:key="optIdx">
                  <checkbox class="tmpl-checkbox" value="{{optIdx}}" color="#2563EB"/>
                  <text class="template-checkbox-text">{{opt}}</text>
                </label>
              </checkbox-group>
            </block>
            <!-- 文本 -->
            <block wx:elif="{{item.type === 'text'}}">
              <view class="template-item-label">{{item.label}}</view>
              <textarea class="template-textarea" placeholder="{{item.placeholder || '请输入...'}}" bindinput="onTemplateTextInput" data-idx="{{index}}" value="{{templateSelections[index] || ''}}"></textarea>
            </block>
          </view>
        </view>
      </view>

    </scroll-view>
    <view class="form-footer" wx:if="{{selectedTemplate}}">
      <button class="btn-cancel" bindtap="closeTemplateModal">取消</button>
      <button class="btn-confirm" bindtap="useTemplate">使用模板</button>
    </view>
  </view>
</view>

<!-- 审稿意见全屏编辑弹窗 -->
<view class="note-preview-overlay {{showNotePreview ? 'active' : ''}}" bindtap="closeNotePreview">
  <view class="note-preview-sheet" catchtap="doNothing">
    <view class="note-preview-header">
      <view class="note-preview-title">审稿意见</view>
      <view class="note-preview-close" bindtap="closeNotePreview">✕</view>
    </view>
    <textarea
      class="note-preview-textarea"
      placeholder="输入审稿意见..."
      value="{{notePreviewText}}"
      bindinput="onNotePreviewInput"
      maxlength="-1"
      show-confirm-bar="{{false}}"
      cursor-spacing="{{20}}"
    ></textarea>
    <view class="note-preview-footer">
      <view class="note-preview-copy" bindtap="copyNotePreview">复制全文</view>
      <view class="note-preview-save" bindtap="saveNotePreview">保存</view>
    </view>
  </view>
</view>

<!-- 智能识别 - 方式选择弹窗 -->
<view class="form-overlay {{showRecognizeModal ? 'active' : ''}}" bindtap="closeRecognizeModal">
  <view class="form-sheet recognize-method-sheet" catchtap="doNothing">
    <view class="form-header">
      <view class="form-title">智能识别</view>
      <view class="form-close" bindtap="closeRecognizeModal">✕</view>
    </view>
    <view class="form-body">
      <view class="recognize-hint">选择一种方式，AI 自动识别审稿邀请信息（消耗20积分）</view>
      <view class="recognize-options">
        <view class="recognize-option-card" bindtap="startRecognizeFromText">
          <view class="recognize-option-icon">📋</view>
          <view class="recognize-option-info">
            <view class="recognize-option-title">粘贴邮件内容</view>
            <view class="recognize-option-desc">复制邮件全文后粘贴，AI 解析关键字段</view>
          </view>
          <text class="recognize-option-arrow">›</text>
        </view>
        <view class="recognize-option-card" bindtap="startRecognizeFromImage">
          <view class="recognize-option-icon">📸</view>
          <view class="recognize-option-info">
            <view class="recognize-option-title">上传邮件截图</view>
            <view class="recognize-option-desc">拍摄或选择邮件截图，AI 自动识别</view>
          </view>
          <text class="recognize-option-arrow">›</text>
        </view>
        <view class="recognize-option-card" bindtap="startRecognizeFromFile">
          <view class="recognize-option-icon">📄</view>
          <view class="recognize-option-info">
            <view class="recognize-option-title">上传稿件文件</view>
            <view class="recognize-option-desc">上传 Word/PDF 稿件，AI 解析论文标题等字段</view>
          </view>
          <text class="recognize-option-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 智能识别 - 粘贴邮件内容弹窗 -->
<view class="form-overlay {{showPasteModal ? 'active' : ''}}" bindtap="closePasteModal">
  <view class="form-sheet paste-sheet" catchtap="doNothing">
    <view class="form-header">
      <view class="form-title">粘贴邮件内容</view>
      <view class="form-close" bindtap="closePasteModal">✕</view>
    </view>
    <view class="form-body">
      <view class="paste-hint">请将审稿邀请邮件的全文内容粘贴到下方，AI 将自动识别关键信息（消耗20积分）</view>
      <textarea class="paste-textarea" placeholder="在此粘贴邮件全文内容..." value="{{pastedEmailText}}" bindinput="onPasteTextInput" maxlength="5000"></textarea>
    </view>
    <view class="form-footer">
      <button class="btn-cancel" bindtap="closePasteModal">取消</button>
      <button class="btn-confirm {{emailRecognizing ? 'btn-disabled' : ''}}" bindtap="submitPastedText" disabled="{{emailRecognizing}}">{{emailRecognizing ? '识别中...' : '开始识别'}}</button>
    </view>
  </view>
</view>
