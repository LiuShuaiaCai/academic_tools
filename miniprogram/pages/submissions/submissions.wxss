/* pages/submissions/submissions.wxss */
page { background: #F6F6F6; }
.sub-page { padding-bottom: 120rpx; }

/* ========== 提示栏 + 高级筛选 ========== */
.filter-tips {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 24rpx; background: #fff;
  border-bottom: 1rpx solid #F3F4F6; box-sizing: border-box;
  flex-wrap: nowrap; overflow-x: auto;
}
.tip-btn {
  font-size: 24rpx; padding: 8rpx 14rpx; border-radius: 8rpx;
  flex-shrink: 0; font-weight: 500; white-space: nowrap;
}
.tip-all { color: #065F46; background: #ECFDF5; border: 1rpx solid #6EE7B7; }
.tip-btn.active { opacity: 1; font-weight: 700; box-shadow: 0 0 0 2rpx rgba(0,0,0,0.1); }
.tip-info { color: #1E40AF; background: #EFF6FF; border: 1rpx solid #BFDBFE; }
.tip-urgent { color: #92400E; background: #FEF3C7; border: 1rpx solid #FDE68A; }
.tip-warn { color: #991B1B; background: #FEE2E2; border: 1rpx solid #FCA5A5; }
.filter-tips .adv-toggle {
  font-size: 24rpx; padding: 8rpx 14rpx; border-radius: 8rpx;
  background: #F3F4F6; color: #374151; flex-shrink: 0; white-space: nowrap;
  display: flex; align-items: center; gap: 4rpx;
}
.filter-tips .adv-arrow { font-size: 20rpx; }

/* ========== 搜索栏 ========== */
.search-bar {
  background: #fff; padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB; box-sizing: border-box;
}
.search-input-wrap {
  display: flex; align-items: center; background: #F3F4F6;
  border-radius: 12rpx; padding: 0 20rpx; flex: 1;
  height: 72rpx; box-sizing: border-box;
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; color: #9CA3AF; }
.search-input { flex: 1; font-size: 28rpx; color: #111827; height: 72rpx; }
.search-bar {
  background: #fff; padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB; box-sizing: border-box;
}
.search-input-wrap {
  background: #F3F4F6; border-radius: 40rpx;
  padding: 12rpx 20rpx; display: flex;
  align-items: center; gap: 12rpx; box-sizing: border-box;
}
.search-icon { font-size: 28rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #374151; }

/* ========== 筛选Tab ========== */
.filter-scroll { background: #fff; border-bottom: 1rpx solid #E5E7EB; white-space: nowrap; }
.filter-tabs { display: flex; padding: 0 16rpx 16rpx; gap: 12rpx; }
.filter-tab { padding: 8rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; color: #6B7280; background: #F3F4F6; flex-shrink: 0; }
.filter-tab.active { background: #DBEAFE; color: #2563eb; font-weight: 500; }

/* ========== 投稿卡片 ========== */
.sub-list { padding: 16rpx; }
.paper-card {
  background: #fff; border-radius: 16rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08); overflow: hidden; position: relative;
}
.card-topbar { height: 8rpx; width: 100%; }
.card-round { position: absolute; top: 16rpx; right: 16rpx; background: rgba(0,0,0,0.06); padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 20rpx; color: #374151; font-weight: 500; }
.card-body { padding: 24rpx; }
.card-title { font-size: 30rpx; font-weight: 600; color: #111827; line-height: 1.5; margin-bottom: 12rpx;}
.card-journal-row { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.card-journal { font-size: 24rpx; color: #6B7280; flex: 1; }
.card-status { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 500; flex-shrink: 0; }
.card-role { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx; background: #F3F4F6; color: #6B7280; flex-shrink: 0; }
.card-stars { display: flex; gap: 4rpx; margin-bottom: 12rpx; }
.star { font-size: 28rpx; color: #E5E7EB; }
.star.filled { color: #F59E0B; }
.card-actions { display: flex; gap: 16rpx; padding: 12rpx 0; border-top: 1rpx solid #F3F4F6; border-bottom: 1rpx solid #F3F4F6; margin-bottom: 12rpx; }
.action-icon { display: flex; align-items: center; gap: 4rpx; padding: 8rpx 12rpx; border-radius: 8rpx; background: #F9FAFB; }
.action-icon-text { font-size: 24rpx; }
.action-count { font-size: 20rpx; color: #6B7280; }
.card-info-row { display: flex; gap: 16rpx; flex-wrap: wrap; margin-bottom: 8rpx; font-size: 22rpx; color: #9CA3AF; }
.card-overdue { padding: 8rpx 0; font-size: 22rpx; margin-bottom: 12rpx; display: flex; align-items: center; gap: 8rpx; justify-content: flex-start; }
.card-overdue.overdue { color: #DC2626; font-weight: 600; }
.card-overdue.urgent { color: #D97706; font-weight: 500; }
.card-overdue.urgent-critical { color: #EF4444; font-weight: 700; }
.card-overdue.normal { color: #9CA3AF; }
.card-overdue.completed { color: #6B7280; font-weight: 500; }
.card-link { font-size: 22rpx; color: #2563eb; margin-bottom: 12rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.link-text { font-size: 22rpx; }
.card-tags-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.card-related {
  display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 12rpx; margin-bottom: 12rpx;
  background: #F0F9FF; border-radius: 8rpx;
  border-left: 4rpx solid #3B82F6;
}
.related-icon { font-size: 22rpx; }
.related-text { font-size: 24rpx; color: #1E40AF; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tag { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx; background: #EFF6FF; color: #2563eb; }
.card-timeline { margin-bottom: 12rpx; }
.tl-row { display: flex; align-items: center; gap: 12rpx; padding: 8rpx 0; font-size: 22rpx; color: #6B7280; }
.tl-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.tl-text { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tl-more { font-size: 20rpx; color: #9CA3AF; padding-left: 24rpx; }
.card-footer { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 24rpx; border-top: 1rpx solid #F3F4F6; }
.footer-btn { font-size: 24rpx; color: #2563eb; padding: 8rpx 16rpx; }
.footer-del { font-size: 24rpx; color: #EF4444; padding: 8rpx 16rpx; }

/* ========== 空状态 ========== */
.empty-box { text-align: center; padding: 100rpx 40rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #9CA3AF; }
.btn-add-first { margin-top: 20rpx; background: #2563eb; color: #fff; font-size: 28rpx; border-radius: 40rpx; padding: 16rpx 48rpx; border: none; }

/* ========== FAB ========== */
.fab { position: fixed; right: 40rpx; bottom: 160rpx; width: 96rpx; height: 96rpx; border-radius: 50%; background: #2563eb; color: #fff; font-size: 60rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.4); z-index: 100; }

/* ========== 表单弹层 ========== */
.form-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: none; align-items: flex-end; justify-content: center; }
.form-overlay.active { display: flex; }
.form-sheet { background: #fff; border-radius: 32rpx 32rpx 0 0; width: 100%; max-width: 100vw; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; box-sizing: border-box; }
.form-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 32rpx 16rpx; border-bottom: 1rpx solid #E5E7EB; flex-shrink: 0; box-sizing: border-box; }
.form-title { font-size: 32rpx; font-weight: 700; color: #111827; }
.form-close { font-size: 36rpx; color: #6B7280; padding: 8rpx; }
.form-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; overflow-x: hidden; box-sizing: border-box; }

/* ========== 表单组 ========== */
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; font-weight: 500; color: #374151; margin-bottom: 12rpx; display: block; }
.required { color: #EF4444; }

/* 输入框 */
.form-input { display: block; width: 100%; min-height: 88rpx; padding: 20rpx; border: 1rpx solid #D1D5DB; border-radius: 12rpx; font-size: 28rpx; color: #111827; background: #fff; box-sizing: border-box; }

/* 选择器 */
.form-picker { display: flex; justify-content: space-between; align-items: center; width: 100%; min-height: 88rpx; padding: 20rpx; border: 1rpx solid #D1D5DB; border-radius: 12rpx; font-size: 28rpx; color: #9CA3AF; box-sizing: border-box; background: #fff; }

/* 文本域 */
.form-textarea { display: block; width: 100%; padding: 20rpx; border: 1rpx solid #D1D5DB; border-radius: 12rpx; font-size: 28rpx; color: #111827; min-height: 160rpx; box-sizing: border-box; background: #fff; }

.form-grid { display: flex; gap: 20rpx; }
.form-grid .form-group { flex: 1; min-width: 0; }

/* ========== 状态图标选择：每行4个 ========== */
.status-icon-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.status-icon-btn {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; padding: 12rpx 4rpx; border-radius: 12rpx;
  border: 2rpx solid #D1D5DB;
  width: calc(25% - 9rpx); box-sizing: border-box;
  transition: all 0.2s;
}
.status-icon-btn.active { border-color: #2563eb; background: #EFF6FF; }
.s-icon {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx;
}
.s-label { font-size: 20rpx; color: #374151; white-space: nowrap; }

/* 标签输入 */
.tag-input-area { display: flex; flex-direction: column; gap: 8rpx; }
.tag-chips { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 8rpx; width: 100%; }
.tag-chip { font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx; background: #EFF6FF; color: #2563eb; display: inline-flex; align-items: center; box-sizing: border-box; }
.tag-chip-field { background: #F3E8FF; color: #9333ea; }
.tag-chip-fund { background: #FEF3C7; color: #F59E0B; }
.chip-del { margin-left: 8rpx; font-size: 28rpx; color: #EF4444; }
.tag-input { border: 2rpx dashed #2563eb; border-radius: 20rpx; padding: 24rpx 20rpx; font-size: 24rpx; color: #2563eb; background: #fff; min-width: 0; max-width: 100%; box-sizing: border-box; flex: 1; min-height: 88rpx; }
.tag-input-field { border-color: #9333ea; color: #9333ea; }
.tag-input-fund { border-color: #F59E0B; color: #F59E0B; }

/* 关联作品 */
.form-label-icon { margin-right: 6rpx; font-size: 26rpx; }
.form-label-hint { font-weight: 400; color: #9CA3AF; font-size: 22rpx; }

/* 表单底部按钮 */
.form-footer { display: flex; gap: 16rpx; padding: 20rpx 32rpx 48rpx; border-top: 1rpx solid #E5E7EB; flex-shrink: 0; box-sizing: border-box; }
.btn-cancel { flex: 1; background: #F3F4F6; color: #374151; border-radius: 12rpx; font-size: 28rpx; padding: 24rpx 0; border: none; box-sizing: border-box; }
.btn-confirm { flex: 2; background: #2563eb; color: #fff; border-radius: 12rpx; font-size: 28rpx; padding: 24rpx 0; border: none; box-sizing: border-box; }

/* ========== 时间线 ========== */
.tl-add-row { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.tl-add-row picker { width: calc(50% - 6rpx); }
.tl-picker-box {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 16rpx; border: 1rpx solid #D1D5DB; border-radius: 12rpx;
  font-size: 26rpx; color: #111827; background: #F9FAFB; box-sizing: border-box;
  min-width: 0; width: 100%;
}
.tl-date-picker {}
.tl-event-picker {}
.tl-picker-box text { color: #6B7280 !important; }
.tl-placeholder { color: #9CA3AF !important; }
.tl-placeholder { color: #9CA3AF; }
.tl-arrow { font-size: 20rpx; color: #9CA3AF; margin-left: 8rpx; }
.tl-remark-row { display: flex; gap: 12rpx; align-items: center; margin-bottom: 16rpx; }
.tl-remark-input {
  flex: 1; padding: 24rpx 20rpx; border: 1rpx solid #D1D5DB; border-radius: 12rpx;
  font-size: 26rpx; color: #111827; background: #F9FAFB; box-sizing: border-box;
  min-width: 0; min-height: 88rpx;
}
.tl-add-btn {
  flex-shrink: 0; height: 88rpx; padding: 0 32rpx;
  background: #2563eb; color: #fff; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 500;
}
.tl-add-text { color: #fff; font-size: 28rpx; }
.tl-list { margin-top: 8rpx; }
.tl-item-card {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 20rpx; background: #F9FAFB; border-radius: 12rpx; margin-bottom: 12rpx;
  box-sizing: border-box; position: relative;
}
.tl-card-left { display: flex; flex-direction: column; align-items: center; padding-top: 6rpx; }
.tl-card-dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.tl-card-content { flex: 1; min-width: 0; }
.tl-card-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.tl-card-date { font-size: 24rpx; color: #374151; font-weight: 500; }
.tl-card-event { font-size: 24rpx; font-weight: 500; }
.tl-card-remark { font-size: 22rpx; color: #6B7280; margin-top: 4rpx; }
.tl-card-del {
  width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #9CA3AF; flex-shrink: 0; margin-top: 4rpx;
}

/* 日期选择器 - CSS日历图标 */
.cal-icon {
  width: 28rpx; height: 26rpx; margin-right: 10rpx; flex-shrink: 0;
  border: 2rpx solid #9CA3AF; border-radius: 4rpx; position: relative;
  border-top: 6rpx solid #9CA3AF;
}
.cal-icon::after {
  content: ''; position: absolute; top: -8rpx; left: 5rpx;
  width: 4rpx; height: 8rpx; background: #9CA3AF; border-radius: 1rpx;
  box-shadow: 8rpx 0 0 #9CA3AF;
}
.cal-icon-sm {
  width: 24rpx; height: 22rpx; margin-right: 8rpx;
  border-radius: 3rpx; border-top: 5rpx solid #9CA3AF;
}
.cal-icon-sm::after {
  top: -7rpx; left: 4rpx;
  width: 3rpx; height: 7rpx;
  box-shadow: 7rpx 0 0 #9CA3AF;
}

/* ========== 高级筛选 ========== */
.adv-toggle {
  display: flex; align-items: center; gap: 6rpx;
  padding: 0 20rpx; font-size: 24rpx; color: #2563eb; flex-shrink: 0;
}
.adv-arrow { font-size: 18rpx; }

.adv-panel {
  background: #fff; padding: 16rpx 24rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB;
}
.adv-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.adv-label { font-size: 26rpx; color: #374151; width: 150rpx; flex-shrink: 0; }
.adv-row .adv-picker-wrap { flex: 1; }
.adv-picker-text { font-size: 26rpx; color: #6B7280; flex: 1; padding: 8rpx 0; }
.adv-sep { font-size: 24rpx; color: #9CA3AF; }
.adv-reset { font-size: 22rpx; color: #EF4444; margin-left: 8rpx; flex-shrink: 0; }

.adv-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.adv-btn-reset {
  flex: 1; text-align: center; padding: 16rpx 0;
  background: #F3F4F6; color: #374151; border-radius: 12rpx; font-size: 26rpx;
}
.adv-btn-apply {
  flex: 1; text-align: center; padding: 16rpx 0;
  background: #2563eb; color: #fff; border-radius: 12rpx; font-size: 26rpx;
}

/* 加载更多提示 */
.load-more {
  text-align: center;
  padding: 32rpx 0 48rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}
