<!--pages/submissions/submissions.wxml-->
<view class="sub-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索标题、期刊、合作者、标签..." bindinput="onSearch" value="{{searchKeyword}}"/>
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</view>
    </view>
</view>

  <!-- 提示栏 + 高级筛选 -->
  <view class="filter-tips">
    <view class="tip-btn tip-all {{quickFilter === 'all' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="all">全部 {{totalCount}}</view>
    <view class="tip-btn tip-info {{quickFilter === 'incomplete' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="incomplete"> 未完成 {{incompleteCount}}</view>
    <view class="tip-btn tip-urgent {{quickFilter === 'near' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="near"> 急需处理 {{nearCount}}</view>
    <view class="tip-btn tip-warn {{quickFilter === 'urgent' ? 'active' : ''}}" bindtap="onTipFilter" data-filter="urgent"> 特别紧急 {{urgentCount}}</view>
    <view class="adv-toggle {{showAdvanced ? 'active' : ''}}" bindtap="toggleAdvanced">
      <text>高级筛选</text>
      <text class="adv-arrow">{{showAdvanced ? '▲' : '▼'}}</text>
    </view>
  </view>

  <!-- 高级筛选面板 -->
  <view class="adv-panel" wx:if="{{showAdvanced}}">
    <!-- 状态 -->
    <view class="adv-row">
      <text class="adv-label">状态</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advStatusOptions}}" range-key="label" value="{{advStatusIndex}}" bindchange="onAdvStatusChange">
          <view class="adv-picker-text">{{advStatusLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advStatus}}" bindtap="clearAdvStatus">✕</view>
      </view>
    </view>
    <!-- 身份 -->
    <view class="adv-row">
      <text class="adv-label">身份</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advRoleOptions}}" range-key="label" value="{{advRoleIndex}}" bindchange="onAdvRoleChange">
          <view class="adv-picker-text">{{advRoleLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advRole}}" bindtap="clearAdvRole">✕</view>
      </view>
    </view>
    <!-- 期刊 -->
    <view class="adv-row">
      <text class="adv-label">期刊</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advJournalOptions}}" range-key="label" value="{{advJournalIndex}}" bindchange="onAdvJournalChange">
          <view class="adv-picker-text">{{advJournalLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advJournal}}" bindtap="clearAdvJournal">✕</view>
      </view>
    </view>
    <!-- 优先级 -->
    <view class="adv-row">
      <text class="adv-label">优先级</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advPriorityOptions}}" range-key="label" value="{{advPriorityIndex}}" bindchange="onAdvPriorityChange">
          <view class="adv-picker-text">{{advPriorityLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advPriority}}" bindtap="clearAdvPriority">✕</view>
      </view>
    </view>
    <!-- 是否完成 -->
    <view class="adv-row">
      <text class="adv-label">完成状态</text>
      <view class="adv-field-wrap">
        <picker class="adv-picker-wrap" range="{{advCompletedOptions}}" range-key="label" value="{{advCompletedIndex}}" bindchange="onAdvCompletedChange">
          <view class="adv-picker-text">{{advCompletedLabel || '全部'}}</view>
        </picker>
        <view class="adv-clear" wx:if="{{advCompleted}}" bindtap="clearAdvCompleted">✕</view>
      </view>
    </view>
    <!-- 到期时间区间 -->
    <view class="adv-row">
      <text class="adv-label">到期时间</text>
      <view class="adv-date-wrap">
        <view class="adv-date-item">
          <picker class="adv-picker-wrap" mode="date" value="{{advDeadlineFrom}}" bindchange="onAdvDeadlineFromChange">
            <view class="adv-picker-text">{{advDeadlineFrom || '起始日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advDeadlineFrom}}" bindtap="clearAdvDeadlineFrom">✕</view>
        </view>
        <text class="adv-sep">~</text>
        <view class="adv-date-item">
          <picker class="adv-picker-wrap" mode="date" value="{{advDeadlineTo}}" bindchange="onAdvDeadlineToChange">
            <view class="adv-picker-text">{{advDeadlineTo || '截止日期'}}</view>
          </picker>
          <view class="adv-clear" wx:if="{{advDeadlineTo}}" bindtap="clearAdvDeadlineTo">✕</view>
        </view>
      </view>
    </view>
    <!-- 操作按钮 -->
    <view class="adv-actions">
      <view class="adv-btn-reset" bindtap="resetAdvanced">重置全部</view>
    </view>
  </view>



  <!-- 列表 -->
  <view class="sub-list">
    <view wx:if="{{!filteredList.length && !searchLoading}}" class="empty-box">
      <text class="empty-icon">📄</text>
      <text class="empty-text">暂无投稿记录</text>
      <!-- <button class="btn-add-first" bindtap="showAddForm">添加第一篇</button> -->
    </view>

    <view
      class="paper-card"
      wx:for="{{filteredList}}"
      wx:key="_id"
      bindtap="showEditForm"
      data-id="{{item._id}}"
    >
      <!-- 顶部彩色状态条 -->
      <view class="card-topbar" style="background:{{item.statusColor}}"></view>

      <!-- 轮次标签 -->
      <view class="card-round" wx:if="{{item.roundLabel}}">{{item.roundLabel}}</view>

      <view class="card-body">
        <!-- 标题 -->
        <view class="card-title" user-select="true">{{item.title}}</view>

        <!-- 期刊 + 状态 + 角色 -->
        <view class="card-journal-row">
          <text class="card-journal" user-select="true">{{item.journal || '未设置期刊'}}<text wx:if="{{item.manuscriptId}}"> #{{item.manuscriptId}}</text></text>
          <text class="card-status" style="background:{{item.statusBg}};color:{{item.statusColor}}">{{item.statusLabel}}</text>
          <text class="card-role" wx:if="{{item.roleLabel}}">{{item.roleLabel}}</text>
        </view>

        <!-- 截止日期提示 -->
        <view class="card-overdue {{item.overdueClass}}" wx:if="{{item.overdueLabel}}">
          <text user-select="true">{{item.overdueLabel}}</text>
        </view>

        <!-- 标签 -->
        <view class="card-tags-row" wx:if="{{item.allTags && item.allTags.length > 0}}">
          <text class="tag" wx:for="{{item.allTags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>

        <!-- 关联作品 -->
        <view class="card-related" wx:if="{{item.relatedWork}}" catchtap="onTapRelatedWork" data-id="{{item.relatedWork._id}}">
          <text class="related-icon">🔗</text>
          <text class="related-text" user-select="true">{{item.relatedWork.title}} → {{item.relatedWork.journal || '未设置期刊'}}</text>
        </view>

        <!-- 时间线预览 -->
        <!-- <view class="card-timeline" wx:if="{{item.recentTimeline && item.recentTimeline.length > 0}}">
          <view class="tl-row" wx:for="{{item.recentTimeline}}" wx:key="index">
            <view class="tl-dot" style="background:{{item.dotColor}}"></view>
            <text class="tl-text">{{item.date}} · {{item.event}}</text>
          </view>
          <view class="tl-more" wx:if="{{item.tlCount > 3}}">... 共{{item.tlCount}}条</view>
        </view> -->
      </view>

      <!-- 卡片底部操作 -->
      <view class="card-footer" catchtap="doNothing">
        <!-- 优先级星级 -->
        <view class="footer-btn" catchtap="viewCardStar" data-id="{{item._id}}">
          <view class="card-stars" wx:if="{{item.priorityStars > 0}}">
            <text class="star {{item.priorityStars >= 1 ? 'filled' : 'empty'}}">★</text>
            <text class="star {{item.priorityStars >= 2 ? 'filled' : 'empty'}}">★</text>
            <text class="star {{item.priorityStars >= 3 ? 'filled' : 'empty'}}">★</text>
            <text class="star {{item.priorityStars >= 4 ? 'filled' : 'empty'}}">★</text>
          </view>
        </view>

        <view class="footer-del footer-btn" catchtap="deleteItem" data-id="{{item._id}}">
          <text>🗑️ 删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more" wx:if="{{list.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{!searchKeyword && !hasMore}}">— 没有更多了 —</text>
  </view>

  <!-- 搜索 loading 浮动遮罩 -->
  <view class="search-loading-mask" wx:if="{{searchLoading}}" catchtouchmove="true">
    <view class="search-loading-box">
      <view class="search-loading-spinner"></view>
      <text class="search-loading-text">搜索中...</text>
    </view>
  </view>

  <!-- FAB 悬浮按钮 -->
  <view class="fab" bindtap="showAddForm">+</view>

  <!-- 表单组件 -->
  <submission-form
    show="{{showForm}}"
    is-edit="{{isEdit}}"
    edit-id="{{editId}}"
    bind:save="onFormSave"
    bind:cancel="onFormCancel"
  />
</view>
