<!--pages/submissions/submissions.wxml-->
<view class="sub-page">
  <!-- 搜索栏 + 高级筛选按钮 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索标题、期刊、合作者、标签..." bindinput="onSearch" value="{{searchKeyword}}"/>
    </view>
    <view class="adv-toggle" bindtap="toggleAdvanced">
      <text>高级筛选</text>
      <text class="adv-arrow">{{showAdvanced ? '▲' : '▼'}}</text>
    </view>
  </view>

  <!-- 高级筛选面板 -->
  <view class="adv-panel" wx:if="{{showAdvanced}}">
    <!-- 状态 -->
    <view class="adv-row">
      <text class="adv-label">状态</text>
      <picker range="{{advStatusOptions}}" range-key="label" value="{{advStatusIndex}}" bindchange="onAdvStatusChange">
        <view class="adv-picker-text">{{advStatusLabel || '全部'}}</view>
      </picker>
    </view>
    <!-- 身份 -->
    <view class="adv-row">
      <text class="adv-label">身份</text>
      <picker range="{{advRoleOptions}}" range-key="label" value="{{advRoleIndex}}" bindchange="onAdvRoleChange">
        <view class="adv-picker-text">{{advRoleLabel || '全部'}}</view>
      </picker>
    </view>
    <!-- 期刊 -->
    <view class="adv-row">
      <text class="adv-label">期刊</text>
      <picker range="{{advJournalOptions}}" range-key="label" value="{{advJournalIndex}}" bindchange="onAdvJournalChange">
        <view class="adv-picker-text">{{advJournalLabel || '全部'}}</view>
      </picker>
    </view>
    <!-- 优先级 -->
    <view class="adv-row">
      <text class="adv-label">优先级</text>
      <picker range="{{advPriorityOptions}}" range-key="label" value="{{advPriorityIndex}}" bindchange="onAdvPriorityChange">
        <view class="adv-picker-text">{{advPriorityLabel || '全部'}}</view>
      </picker>
    </view>
    <!-- 到期时间区间 -->
    <view class="adv-row">
      <text class="adv-label">到期时间</text>
      <picker mode="date" value="{{advDeadlineFrom}}" bindchange="onAdvDeadlineFromChange">
        <view class="adv-picker-text">{{advDeadlineFrom || '起始日期'}}</view>
      </picker>
      <text class="adv-sep">~</text>
      <picker mode="date" value="{{advDeadlineTo}}" bindchange="onAdvDeadlineToChange">
        <view class="adv-picker-text">{{advDeadlineTo || '截止日期'}}</view>
      </picker>
    </view>
    <!-- 操作按钮 -->
    <view class="adv-actions">
      <view class="adv-btn-reset" bindtap="resetAdvanced">重置全部</view>
      <view class="adv-btn-apply" bindtap="applyFilter">应用筛选</view>
    </view>
  </view>

  <!-- 筛选Tab -->
  <scroll-view scroll-x class="filter-scroll">
    <view class="filter-tabs">
      <view
        class="filter-tab {{filterGroup === tab.value ? 'active' : ''}}"
        wx:for="{{filterTabs}}"
        wx:key="value"
        data-group="{{tab.value}}"
        bindtap="setFilterGroup"
      >{{tab.label}}</view>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <view class="sub-list">
    <view wx:if="{{filteredList.length === 0}}" class="empty-box">
      <text class="empty-icon">📄</text>
      <text class="empty-text">暂无投稿记录</text>
      <button class="btn-add-first" bindtap="showAddForm">添加第一篇</button>
    </view>

    <view
      class="paper-card"
      wx:for="{{filteredList}}"
      wx:key="_id"
      bindtap="showEditForm"
      data-id="{{item._id}}"
    >
      <!-- 顶部彩色状态条 -->
      <view class="card-topbar" style="background:{{item.statusColor}}"></view>

      <!-- 轮次标签 -->
      <view class="card-round" wx:if="{{item.roundLabel}}">{{item.roundLabel}}</view>

      <view class="card-body">
        <!-- 标题 -->
        <view class="card-title">{{item.title}}</view>

        <!-- 期刊 + 状态 + 角色 -->
        <view class="card-journal-row">
          <text class="card-journal">{{item.journal || '未设置期刊'}}</text>
          <text class="card-status" style="background:{{item.statusBg}};color:{{item.statusColor}}">{{item.statusLabel}}</text>
          <text class="card-role" wx:if="{{item.roleLabel}}">{{item.roleLabel}}</text>
        </view>

        <!-- 优先级星级 -->
        <view class="card-stars" wx:if="{{item.priorityStars > 0}}">
          <text class="star {{index < item.priorityStars ? 'filled' : 'empty'}}" wx:for="{{3}}" wx:key="*this">★</text>
        </view>

        <!-- 图标操作栏 -->
        <view class="card-actions" catchtap="doNothing">
          <view class="action-icon" catchtap="showEditForm" data-id="{{item._id}}">
            <text class="action-icon-text">✏️</text>
          </view>
          <view class="action-icon" wx:if="{{item.attachCount > 0}}">
            <text class="action-icon-text">📎</text>
            <text class="action-count">{{item.attachCount}}</text>
          </view>
          <view class="action-icon" wx:if="{{item.tlCount > 0}}">
            <text class="action-icon-text">📅</text>
            <text class="action-count">{{item.tlCount}}</text>
          </view>
        </view>

        <!-- 投稿日期和天数 -->
        <view class="card-info-row">
          <text wx:if="{{item.createTime}}">投稿: {{item.createTimeFormatted}}</text>
          <text wx:if="{{item.daysLabel}}">已{{item.daysLabel}}</text>
          <text wx:if="{{item.manuscriptId}}">{{item.manuscriptId}}</text>
        </view>

        <!-- 截止日期提示 -->
        <view class="card-overdue {{item.overdueClass}}" wx:if="{{item.overdueLabel}}">
          <text>{{item.overdueLabel}}</text>
        </view>

        <!-- 网址链接 -->
        <view class="card-link" wx:if="{{item.url}}">
          <text class="link-text">🔗 {{item.url}}</text>
        </view>

        <!-- 标签 -->
        <view class="card-tags-row" wx:if="{{item.allTags.length > 0}}">
          <text class="tag" wx:for="{{item.allTags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>

        <!-- 时间线预览 -->
        <view class="card-timeline" wx:if="{{item.recentTimeline.length > 0}}">
          <view class="tl-row" wx:for="{{item.recentTimeline}}" wx:key="index">
            <view class="tl-dot" style="background:{{item.dotColor}}"></view>
            <text class="tl-text">{{item.date}} · {{item.event}}</text>
          </view>
          <view class="tl-more" wx:if="{{item.tlCount > 3}}">... 共{{item.tlCount}}条</view>
        </view>
      </view>

      <!-- 卡片底部操作 -->
      <view class="card-footer" catchtap="doNothing">
        <view class="footer-btn" catchtap="viewTimeline" data-id="{{item._id}}">
          <text>📅 时间线</text>
        </view>
        <view class="footer-del" catchtap="deleteItem" data-id="{{item._id}}">
          <text>🗑️ 删除</text>
        </view>
      </view>
    </view>
    </view>

    <!-- 加载状态 -->
    <view class="load-more" wx:if="{{list.length > 0}}">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:elif="{{!searchKeyword && !hasMore}}">— 没有更多了 —</text>
    </view>

  <!-- FAB 悬浮按钮 -->
  <view class="fab" bindtap="showAddForm">+</view>

  <!-- 表单弹层 -->
  <view class="form-overlay {{showForm ? 'active' : ''}}" bindtap="closeForm">
    <view class="form-sheet" catchtap="doNothing">
      <view class="form-header">
        <view class="form-title">{{isEdit ? '编辑投稿' : '新建投稿'}}</view>
        <view class="form-close" bindtap="closeForm">✕</view>
      </view>
      <scroll-view scroll-y class="form-body">
        <!-- 1. 论文标题 -->
        <view class="form-group">
          <view class="form-label">论文标题 <text class="required">*</text></view>
          <input class="form-input" placeholder="请输入论文标题" bindinput="onFormInput" data-field="title" value="{{form.title}}"/>
        </view>

        <!-- 2. 目标期刊/会议 -->
        <view class="form-group">
          <view class="form-label">目标期刊/会议 <text class="required">*</text></view>
          <input class="form-input" placeholder="期刊或会议名称" bindinput="onFormInput" data-field="journal" value="{{form.journal}}"/>
        </view>

        <!-- 3. 当前状态（图标选择） -->
        <view class="form-group">
          <view class="form-label">当前状态 <text class="required">*</text></view>
          <view class="status-icon-row">
            <view
              class="status-icon-btn {{form.status === item.value ? 'active' : ''}}"
              wx:for="{{statusOptions}}"
              wx:key="value"
              data-status="{{item.value}}"
              bindtap="onSelectStatus"
            >
              <view class="s-icon" style="background:{{item.bg}};color:{{item.color}}">
                <text>{{item.icon}}</text>
              </view>
              <text class="s-label">{{item.label}}</text>
            </view>
          </view>
        </view>

        <!-- 4. 截止日期（单列，在用户指定顺序第一位） -->
        <view class="form-group">
          <view class="form-label">截止日期 <text class="required">*</text></view>
          <picker mode="date" bindchange="onDeadlineChange">
            <view class="form-picker">
              <view class="cal-icon"></view>
              <text>{{form.deadline || '请选择日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 5. 优先级（单列，第二位） -->
        <view class="form-group">
          <view class="form-label">优先级 <text class="form-label-hint">（非紧急/普通/紧急）</text><text class="required">*</text></view>
          <picker mode="selector" range="{{priorityOptions}}" range-key="label" bindchange="onPriorityChange">
            <view class="form-picker">{{form.priorityLabel || '普通'}} <text class="picker-arrow">›</text></view>
          </picker>
        </view>

        <!-- 6. 关联作品 -->
        <view class="form-group">
          <view class="form-label"><text class="form-label-icon">🔗</text> 关联作品 <text class="form-label-hint">（同一论文的多轮投稿）</text></view>
          <picker mode="selector" range="{{relatedWorkOptions}}" range-key="title" bindchange="onRelatedWorkChange">
            <view class="form-picker">{{form.relatedWorkTitle || '不关联'}} <text class="picker-arrow">›</text></view>
          </picker>
        </view>

        <!-- 7. 作者身份（单列，第三位） -->
        <view class="form-group">
          <view class="form-label">作者身份 <text class="form-label-hint">（投稿时你的身份角色）</text></view>
          <picker mode="selector" range="{{roleOptions}}" range-key="label" bindchange="onRoleChange">
            <view class="form-picker">{{form.roleLabel || '请选择'}} <text class="picker-arrow">›</text></view>
          </picker>
        </view>

        <!-- 8. 通讯作者 -->
        <view class="form-group">
          <view class="form-label">通讯作者</view>
          <input class="form-input" placeholder="通讯作者姓名及邮箱" bindinput="onFormInput" data-field="corresponding" value="{{form.corresponding}}"/>
        </view>

        <!-- 9. 支付作者 -->
        <view class="form-group">
          <view class="form-label">支付作者</view>
          <input class="form-input" placeholder="负责支付APC/Open Access费用的作者" bindinput="onFormInput" data-field="payee" value="{{form.payee}}"/>
        </view>

        <!-- 10. 合作者 -->
        <view class="form-group">
          <view class="form-label">合作者</view>
          <input class="form-input" placeholder="其他合作者姓名，用逗号分隔" bindinput="onFormInput" data-field="coauthors" value="{{form.coauthors}}"/>
        </view>

        <!-- 11. 时间线 -->
        <view class="form-group">
          <view class="form-label"><text class="form-label-icon">📅</text> 时间线</view>

          <!-- 新增事件输入行：日期picker + 事件picker + 备注input + 加号按钮 -->
          <view class="tl-add-row">
            <picker mode="date" value="{{form.tlNewDate}}" data-field="tlNewDate" bindchange="onFormInput">
              <view class="tl-picker-box tl-date-picker">
                <view class="cal-icon cal-icon-sm"></view>
                <text class="{{form.tlNewDate ? '' : 'tl-placeholder'}}">{{form.tlNewDate || '选择日期'}}</text>
                <text class="tl-arrow">▼</text>
              </view>
            </picker>
            <picker range="{{tlEventOptions}}" range-key="label" value="{{form.tlNewEventIdx}}" data-field="tlNewEventIdx" bindchange="onFormInput">
              <view class="tl-picker-box tl-event-picker">
                <text class="{{form.tlNewEventIdx ? '' : 'tl-placeholder'}}">{{form.tlNewEventIdx>=0 ? tlEventOptions[form.tlNewEventIdx].label : '选择事件'}}</text>
                <text class="tl-arrow">▼</text>
              </view>
            </picker>
          </view>
          <view class="tl-remark-row">
            <input class="tl-remark-input" placeholder="备注（选填）" value="{{form.tlNewRemark}}" data-field="tlNewRemark" bindinput="onFormInput"/>
            <view class="tl-add-btn" bindtap="addTimelineItem">
              <text class="tl-add-text">添加</text>
            </view>
          </view>

          <!-- 已有时间线事件列表 -->
          <view class="tl-list" wx:if="{{form.timelineList.length > 0}}">
            <view class="tl-item-card" wx:for="{{form.timelineList}}" wx:key="index">
              <view class="tl-card-left">
                <view class="tl-card-dot" style="background:{{item.dotColor}}"></view>
              </view>
              <view class="tl-card-content">
                <view class="tl-card-top">
                  <text class="tl-card-date">{{item.date}}</text>
                  <text class="tl-card-event" style="color:{{item.dotColor}}">{{item.event}}</text>
                </view>
                <text class="tl-card-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
              </view>
              <view class="tl-card-del" data-i="{{index}}" catchtap="removeTimelineItem">
                <text>×</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 12. DOI（单列，第五位） -->
        <view class="form-group">
          <view class="form-label">DOI</view>
          <input class="form-input" placeholder="10.xxxx/xxxx" bindinput="onFormInput" data-field="doi" value="{{form.doi}}"/>
        </view>

        <!-- 13. 稿件编号（单列，第四位） -->
        <view class="form-group">
          <view class="form-label">稿件编号</view>
          <input class="form-input" placeholder="如 #2024-001" bindinput="onFormInput" data-field="manuscriptId" value="{{form.manuscriptId}}"/>
        </view>

        <!-- 14. 追踪网址 -->
        <view class="form-group">
          <view class="form-label">追踪网址</view>
          <input class="form-input" placeholder="https://... 投稿系统链接" bindinput="onFormInput" data-field="url" value="{{form.url}}"/>
        </view>

        <!-- 15. 论文类型（单列，第六位） -->
        <view class="form-group">
          <view class="form-label">论文类型</view>
          <picker mode="selector" range="{{typeOptions}}" range-key="label" bindchange="onTypeChange">
            <view class="form-picker">{{form.paperType || '请选择'}} <text class="picker-arrow">›</text></view>
          </picker>
        </view>

        <!-- 16. 学科领域（标签输入） -->
        <view class="form-group">
          <view class="form-label">学科领域</view>
          <view class="tag-input-area">
            <input class="tag-input tag-input-field" placeholder="输入领域后回车添加" confirm-type="done" bindconfirm="onTagConfirm" data-target="fields" value="{{form.fieldsInput}}" bindinput="onTagInput"/>
            <view class="tag-chips">
              <text class="tag-chip tag-chip-field" wx:for="{{form.fieldsList}}" wx:key="index">{{item}} <text class="chip-del" data-field="fields" data-i="{{index}}" catchtap="removeChip">×</text></text>
            </view>
          </view>
        </view>

        <!-- 17. 标签 -->
        <view class="form-group">
          <view class="form-label">标签</view>
          <view class="tag-input-area">
            <input class="tag-input" placeholder="输入标签后回车添加" confirm-type="done" bindconfirm="onTagConfirm" bindinput="onTagInput" data-target="tags" value="{{form.tagsInput}}"/>
            <view class="tag-chips">
              <text class="tag-chip" wx:for="{{form.tagsList}}" wx:key="index">{{item}} <text class="chip-del" data-field="tags" data-i="{{index}}" catchtap="removeChip">×</text></text>
            </view>
          </view>
        </view>

        <!-- 18. 基金项目 -->
        <view class="form-group">
          <view class="form-label">基金项目</view>
          <view class="tag-input-area">
            <input class="tag-input tag-input-fund" placeholder="输入基金后回车添加" confirm-type="done" bindconfirm="onTagConfirm" bindinput="onTagInput" data-target="funds" value="{{form.fundsInput}}"/>
            <view class="tag-chips">
              <text class="tag-chip tag-chip-fund" wx:for="{{form.fundsList}}" wx:key="index">{{item}} <text class="chip-del" data-field="funds" data-i="{{index}}" catchtap="removeChip">×</text></text>
            </view>
          </view>
        </view>

        <!-- 19. 备注 -->
        <view class="form-group">
          <view class="form-label">备注</view>
          <textarea class="form-textarea" placeholder="其他备注信息..." bindinput="onFormInput" data-field="note" value="{{form.note}}"></textarea>
        </view>

      </scroll-view>
      <view class="form-footer">
        <button class="btn-cancel" bindtap="closeForm">取消</button>
        <button class="btn-confirm" bindtap="saveForm">保存</button>
      </view>
    </view>
  </view>
</view>
