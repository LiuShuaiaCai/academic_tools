<!-- pages/calendar/daily-tasks/daily-tasks.wxml -->
<view class="daily-tasks-page">
  <!-- 顶部日期导航 -->
  <view class="date-header">
    <view class="date-nav">
      <view class="nav-btn" bindtap="prevDay">‹</view>
      <view class="date-info">
        <text class="date-label">{{selectedDateLabel}}</text>
        <text class="date-value">{{selectedDate}}</text>
      </view>
      <view class="nav-btn" bindtap="nextDay">›</view>
    </view>
    <view class="today-btn" bindtap="goToToday">今天</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <view class="stats-num">{{stats.completed}}</view>
      <view class="stats-label">已完成</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-num pending">{{stats.pending}}</view>
      <view class="stats-label">待完成</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-num">{{stats.completionRate}}%</view>
      <view class="stats-label">完成率</view>
    </view>
  </view>

  <!-- 任务列表 -->
  <scroll-view scroll-y class="task-list" bindscrolltolower="loadMore">
    <!-- 待完成区域 -->
    <view class="task-section" wx:if="{{pendingTasks.length > 0}}">
      <view class="section-header">
        <view class="section-title">
          <text class="dot pending"></text>
          <text>待完成 ({{pendingTasks.length}})</text>
        </view>
        <view class="section-actions">
          <view class="action-btn" bindtap="markAllComplete">全部完成</view>
        </view>
      </view>
      
      <view class="task-items">
        <view 
          class="task-item {{item.priority}}" 
          wx:for="{{pendingTasks}}" 
          wx:key="_id"
          data-id="{{item._id}}"
          bindtap="goToTaskEditor"
        >
          <view class="task-checkbox" bindtap="toggleTaskComplete" data-id="{{item._id}}">
            <view class="checkbox-circle"></view>
          </view>
          <view class="task-content">
            <view class="task-title">{{item.title}}</view>
            <view class="task-meta">
              <text class="task-category">{{getCategoryIcon(item.category)}}</text>
              <text class="task-time" wx:if="{{item.time && !item.isAllDay}}">{{item.time}}</text>
              <view class="task-priority {{item.priority}}">{{item.priority === 'high' ? '紧急' : item.priority === 'medium' ? '普通' : '低优'}}</view>
            </view>
          </view>
          <view class="task-actions">
            <view class="delete-btn" catchtap="deleteTask" data-id="{{item._id}}">×</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 已完成区域 -->
    <view class="task-section completed-section" wx:if="{{completedTasks.length > 0}}">
      <view class="section-header">
        <view class="section-title">
          <text class="dot completed"></text>
          <text>已完成 ({{completedTasks.length}})</text>
        </view>
        <view class="section-actions">
          <view class="action-btn danger" bindtap="clearCompleted">清除</view>
        </view>
      </view>
      
      <view class="task-items">
        <view 
          class="task-item completed {{item.priority}}" 
          wx:for="{{completedTasks}}" 
          wx:key="_id"
          data-id="{{item._id}}"
        >
          <view class="task-checkbox checked" bindtap="toggleTaskComplete" data-id="{{item._id}}">
            <view class="checkbox-circle checked">✓</view>
          </view>
          <view class="task-content">
            <view class="task-title">{{item.title}}</view>
            <view class="task-meta">
              <text class="task-time">{{getCategoryIcon(item.category)}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{tasks.length === 0 && !loading}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">今天没有任务</view>
      <view class="empty-hint">点击下方按钮添加今日任务</view>
    </view>

    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- 底部添加按钮 -->
  <view class="bottom-bar">
    <button class="add-btn" bindtap="showAddTask">
      <text class="add-icon">+</text>
      <text>添加任务</text>
    </button>
  </view>

  <!-- 添加任务弹窗 -->
  <view class="add-sheet {{showAddSheet ? 'show' : ''}}">
    <view class="sheet-mask" bindtap="hideAddTask"></view>
    <view class="sheet-content">
      <view class="sheet-header">
        <text class="sheet-title">添加任务</text>
        <view class="sheet-close" bindtap="hideAddTask">×</view>
      </view>
      
      <!-- 快速输入 -->
      <view class="quick-input">
        <input 
          class="input-field" 
          placeholder="输入任务名称..." 
          value="{{quickAddTitle}}"
          bindinput="onQuickAddInput"
        />
        <button class="confirm-btn" bindtap="confirmAddTask">添加</button>
      </view>
      
      <!-- 学术模板 -->
      <view class="template-section">
        <view class="template-title">学术任务模板</view>
        <view class="template-grid">
          <view 
            class="template-item" 
            wx:for="{{academicTemplates}}" 
            wx:key="index"
            bindtap="addFromTemplate"
            data-index="{{index}}"
          >
            <view class="template-icon">{{item.icon}}</view>
            <view class="template-name">{{item.title}}</view>
          </view>
        </view>
      </view>
      
      <!-- 完整编辑器入口 -->
      <view class="full-editor-btn" bindtap="createFullTask">
        <text>使用完整编辑器</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
