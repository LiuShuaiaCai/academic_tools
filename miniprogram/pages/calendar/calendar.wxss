/* pages/calendar/calendar.wxss */
page { background: #F6F6F6; }
.calendar-page { padding-bottom: 120rpx; }

.cal-header {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.cal-nav-btn {
  font-size: 48rpx;
  color: #6B7280;
  padding: 0 20rpx;
}

.cal-month-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
  text-align: center;
}

.today-btn {
  font-size: 24rpx;
  color: #2563eb;
  padding: 8rpx 20rpx;
  border: 1rpx solid #DBEAFE;
  border-radius: 20rpx;
  background: #EFF6FF;
}

.weekday-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E5E7EB;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #6B7280;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  background: #fff;
  margin-bottom: 16rpx;
}

.day-cell {
  min-height: 88rpx;
  padding: 12rpx 8rpx;
  border-bottom: 1rpx solid #F3F4F6;
  border-right: 1rpx solid #F3F4F6;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.day-cell.empty {
  visibility: hidden;
}

.day-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.day-cell.today .day-num {
  background: #EF4444;
  color: #fff;
  border-radius: 50%;
}

.day-cell.selected .day-num {
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
}

.day-cell.today.selected .day-num {
  background: #EF4444;
  color: #fff;
}

.week-day-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.week-day-cell.today .week-day-num {
  background: #EF4444;
  color: #fff;
  border-radius: 50%;
}

.week-day-cell.selected .week-day-num {
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
}

.week-day-cell.today.selected .week-day-num {
  background: #EF4444;
  color: #fff;
}

.event-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
  margin-top: 4rpx;
  height: 10rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.dot.submission { background: #2563eb; }
.dot.review { background: #EF4444; }
.dot.conference { background: #10B981; }
.dot.task { background: #8B5CF6; }

/* 月视图事件指示点：单事件红点，多事件扁平 */
.event-indicator {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #EF4444;
}

.event-indicator.multi {
  width: 20rpx;
  height: 8rpx;
  border-radius: 4rpx;
}

/* ========== 事件区域（月视图/周视图底部） ========== */
.events-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.section-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #F3F4F6;
  color: #6B7280;
}

.action-btn.primary {
  background: #2563EB;
  color: #fff;
}

.event-list {
  display: flex;
  flex-direction: column;
}

/* 空状态 */
.events-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
}

.events-empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.events-empty .empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-bottom: 20rpx;
}

.events-empty .empty-action {
  padding: 12rpx 32rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

/* ========== 筛选栏 ========== */
.filter-bar {
  background: #fff;
  padding: 20rpx 32rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.filter-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  border: 1rpx solid #E5E7EB;
}

.filter-tag.active {
  color: #fff;
  border-color: transparent;
}

.filter-tag.active.type-blue { background: #2563eb; }
.filter-tag.active.type-red { background: #EF4444; }
.filter-tag.active.type-green { background: #10B981; }
.filter-tag.active.type-purple { background: #8B5CF6; }

.filter-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.filter-status {
  display: flex;
  gap: 12rpx;
}

.filter-status view {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
}

.filter-status view.active {
  background: #111827;
  color: #fff;
}

/* ========== 顶部标题 ========== */
.cal-header {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.header-btn.add-task {
  font-size: 40rpx;
  font-weight: 700;
}

/* ========== 视图切换 ========== */
.view-switcher {
  display: flex;
  background: #fff;
  padding: 16rpx 32rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.view-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  border: 1rpx solid #E5E7EB;
}

.view-btn.active {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

/* ========== 月份导航 ========== */
.cal-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
}

.cal-nav-btn {
  font-size: 48rpx;
  color: #6B7280;
  padding: 0 20rpx;
}

.cal-month {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
  text-align: center;
}

/* ========== 周视图 ========== */
.week-view {
  background: #fff;
  margin-bottom: 16rpx;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-day-cell {
  min-height: 88rpx;
  padding: 12rpx 8rpx;
  border-bottom: 1rpx solid #F3F4F6;
  border-right: 1rpx solid #F3F4F6;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}



.week-day-name {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

/* ========== 列表视图 ========== */
.list-view {
  padding: 16rpx;
}

.list-group {
  margin-bottom: 24rpx;
}

.list-group-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 12rpx 16rpx;
}

.list-group-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.list-group-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

.list-group-events {
  display: flex;
  flex-direction: column;
}

/* ========== 统一事件卡片样式 ========== */
.event-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
}

.event-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.event-card.type-blue::before { background: #2563eb; }
.event-card.type-red::before { background: #EF4444; }
.event-card.type-green::before { background: #10B981; }
.event-card.type-purple::before { background: #8B5CF6; }

.event-card.completed {
  opacity: 0.55;
}

.event-card.completed .event-title-text {
  text-decoration: line-through;
  color: #9CA3AF;
}

.event-card.completed .event-meta-row {
  color: #9CA3AF;
}

.event-icon {
  font-size: 44rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.event-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.event-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  overflow: hidden;
}

.event-type-label {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: #F3F4F6;
  color: #6B7280;
  flex-shrink: 0;
}

.event-title-text {
  color: #111827;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.event-date {
  color: #6B7280;
}

.event-status {
  font-weight: 600;
}

.event-status.urgent {
  color: #EF4444;
}

.event-status.normal {
  color: #6B7280;
}

.event-check {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.event-check-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 50%;
  box-sizing: border-box;
}

.event-check-circle.checked {
  background: #10B981;
  border-color: #10B981;
}

/* ========== 选中日期事件分区列表（daily-tasks 风格） ========== */

/* 统计卡片 */
.day-stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.day-stats-item {
  text-align: center;
  flex: 1;
}

.day-stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #10B981;
}

.day-stats-num.pending {
  color: #F59E0B;
}

.day-stats-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.day-stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E7EB;
}

/* 分区 */
.day-task-section {
  margin-bottom: 32rpx;
}

.day-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.day-section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.day-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.day-dot.pending { background: #F59E0B; }
.day-dot.completed { background: #10B981; }

.day-section-actions {
  display: flex;
  gap: 12rpx;
}

.day-action-btn {
  font-size: 24rpx;
  color: #2563EB;
  padding: 8rpx 16rpx;
  background: #EFF6FF;
  border-radius: 8rpx;
}

.day-action-btn.danger {
  color: #EF4444;
  background: #FEE2E2;
}

/* 任务项 */
.day-task-items {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.day-task-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
  border-left: 4rpx solid transparent;
  position: relative;
}

.day-task-item:last-child {
  border-bottom: none;
}

.day-task-item.type-blue { border-left-color: #2563eb; }
.day-task-item.type-red { border-left-color: #EF4444; }
.day-task-item.type-green { border-left-color: #10B981; }
.day-task-item.type-purple { border-left-color: #8B5CF6; }
.day-task-item.high { border-left-color: #EF4444; }
.day-task-item.medium { border-left-color: #F59E0B; }
.day-task-item.low { border-left-color: #10B981; }

.day-task-item.completed {
  opacity: 0.55;
}

.day-task-item.completed .day-task-title {
  text-decoration: line-through;
  color: #9CA3AF;
}

.day-task-item.completed .day-task-meta {
  color: #9CA3AF;
}

/* 复选框 */
.day-task-check {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.day-check-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: transparent;
  box-sizing: border-box;
}

.day-check-circle.checked {
  background: #10B981;
  border-color: #10B981;
  color: #fff;
}

/* 内容区 */
.day-task-content {
  flex: 1;
  min-width: 0;
}

.day-task-title {
  font-size: 28rpx;
  color: #111827;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-task-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  font-size: 24rpx;
}

.day-task-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: #F3F4F6;
  color: #6B7280;
  flex-shrink: 0;
}

.day-task-date {
  color: #9CA3AF;
}

.day-task-status {
  font-weight: 600;
}

.day-task-status.urgent {
  color: #EF4444;
}

.day-task-status.normal {
  color: #6B7280;
}

/* 删除按钮 */
.day-task-actions {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.day-delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #9CA3AF;
}

.list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
  margin-bottom: 20rpx;
}

.empty-action {
  padding: 12rpx 32rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

/* ========== 添加任务弹窗 ========== */
.add-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
  align-items: flex-end;
}

.add-sheet.show {
  display: flex;
}

.sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.sheet-content {
  position: relative;
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #9CA3AF;
}

.quick-input {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.input-field {
  flex: 1;
  padding: 24rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.confirm-btn {
  padding: 0 40rpx;
  background: #2563EB;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.template-section {
  margin-bottom: 24rpx;
}

.template-title {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.template-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.template-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.template-name {
  font-size: 22rpx;
  color: #374151;
  text-align: center;
}

.full-editor-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
}

.full-editor-btn .arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

.form-row {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label .required {
  color: #EF4444;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 140rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.datetime-row {
  display: flex;
  gap: 16rpx;
}

.datetime-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #111827;
}

.datetime-icon {
  font-size: 28rpx;
}

.reminder-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.reminder-item {
  padding: 16rpx 24rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #6B7280;
  border: 2rpx solid transparent;
}

.reminder-item.active {
  background: #EFF6FF;
  color: #2563EB;
  border-color: #2563EB;
}

.sheet-confirm-btn {
  width: 100%;
  padding: 28rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 16rpx;
  box-sizing: border-box;
}












