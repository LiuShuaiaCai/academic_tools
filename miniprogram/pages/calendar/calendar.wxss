/* pages/calendar/calendar.wxss */
page { background: #F6F6F6; }
.calendar-page { padding-bottom: 120rpx; }

.cal-header {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.cal-nav-btn {
  font-size: 48rpx;
  color: #6B7280;
  padding: 0 20rpx;
}

.cal-month-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
  text-align: center;
}

.today-btn {
  font-size: 24rpx;
  color: #2563eb;
  padding: 8rpx 20rpx;
  border: 1rpx solid #DBEAFE;
  border-radius: 20rpx;
  background: #EFF6FF;
}

.weekday-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E5E7EB;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #6B7280;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  background: #fff;
  margin-bottom: 16rpx;
}

.day-cell {
  min-height: 88rpx;
  padding: 12rpx 8rpx;
  border-bottom: 1rpx solid #F3F4F6;
  border-right: 1rpx solid #F3F4F6;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.day-cell.empty {
  visibility: hidden;
}

.day-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.day-cell.today .day-num {
  background: #EF4444;
  color: #fff;
  border-radius: 50%;
}

.day-cell.selected .day-num {
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
}

.day-cell.today.selected .day-num {
  background: #EF4444;
  color: #fff;
}

.week-day-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.week-day-cell.today .week-day-num {
  background: #EF4444;
  color: #fff;
  border-radius: 50%;
}

.week-day-cell.selected .week-day-num {
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
}

.week-day-cell.today.selected .week-day-num {
  background: #EF4444;
  color: #fff;
}

.event-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
  margin-top: 4rpx;
  height: 10rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.dot.submission { background: #2563eb; }
.dot.review { background: #EF4444; }
.dot.conference { background: #10B981; }
.dot.task { background: #8B5CF6; }

/* 月视图事件指示点：单事件红点，多事件扁平 */
.event-indicator {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #EF4444;
}

.event-indicator.multi {
  width: 20rpx;
  height: 8rpx;
  border-radius: 4rpx;
}

/* ========== 事件区域（月视图/周视图底部） ========== */
.events-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.section-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #F3F4F6;
  color: #6B7280;
}

.action-btn.primary {
  background: #2563EB;
  color: #fff;
}

.event-list {
  display: flex;
  flex-direction: column;
}

/* 空状态 */
.events-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
}

.events-empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.events-empty .empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-bottom: 20rpx;
}

.events-empty .empty-action {
  padding: 12rpx 32rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

/* ========== 筛选栏 ========== */
.filter-bar {
  background: #fff;
  padding: 20rpx 32rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.filter-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  border: 1rpx solid #E5E7EB;
}

.filter-tag.active {
  color: #fff;
  border-color: transparent;
}

.filter-tag.active.type-blue { background: #2563eb; }
.filter-tag.active.type-red { background: #EF4444; }
.filter-tag.active.type-green { background: #10B981; }
.filter-tag.active.type-purple { background: #8B5CF6; }

.filter-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.filter-status {
  display: flex;
  gap: 12rpx;
}

.filter-status view {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
}

.filter-status view.active {
  background: #111827;
  color: #fff;
}

/* ========== 顶部标题 ========== */
.cal-header {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  padding: 100rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.header-btn.add-task {
  font-size: 40rpx;
  font-weight: 700;
}

/* ========== 视图切换 ========== */
.view-switcher {
  display: flex;
  background: #fff;
  padding: 16rpx 32rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.view-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  border: 1rpx solid #E5E7EB;
}

.view-btn.active {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

/* ========== 月份导航 ========== */
.cal-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
}

.cal-nav-btn {
  font-size: 48rpx;
  color: #6B7280;
  padding: 0 20rpx;
}

.cal-month {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
  text-align: center;
}

/* ========== 周视图 ========== */
.week-view {
  background: #fff;
  margin-bottom: 16rpx;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-day-cell {
  min-height: 88rpx;
  padding: 12rpx 8rpx;
  border-bottom: 1rpx solid #F3F4F6;
  border-right: 1rpx solid #F3F4F6;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}



.week-day-name {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

/* ========== 列表视图 ========== */
.list-view {
  padding: 16rpx;
}

.list-group {
  margin-bottom: 24rpx;
}

.list-group-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 12rpx 16rpx;
}

.list-group-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.list-group-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

.list-group-events {
  display: flex;
  flex-direction: column;
}

/* 列表视图中的 upcoming-item 已完成状态 */
.list-group-events .upcoming-item.completed .upcoming-title {
  text-decoration: line-through;
  color: #9CA3AF;
}

.list-group-events .upcoming-item.completed .upcoming-meta .date,
.list-group-events .upcoming-item.completed .upcoming-meta .countdown {
  color: #9CA3AF;
}

.list-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: auto;
}

.checkbox-inner.checked {
  width: 24rpx;
  height: 24rpx;
  background: #10B981;
  border-radius: 50%;
}

.list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
  margin-bottom: 20rpx;
}

.empty-action {
  padding: 12rpx 32rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}


