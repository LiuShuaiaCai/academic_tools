<!--pages/calendar/calendar.wxml-->
<view class="calendar-page">
  <!-- 顶部 -->
  <view class="cal-header">
    <view class="cal-title">学术日历</view>
    <view class="header-actions">
      <view class="header-btn add-task" bindtap="showAddTaskModal">+</view>
      <view class="header-btn" bindtap="goToToday">今</view>
    </view>
  </view>

  <!-- 视图切换 -->
  <view class="view-switcher">
    <view
      class="view-btn {{currentView === 'month' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="month"
    >月视图</view>
    <view
      class="view-btn {{currentView === 'week' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="week"
    >周视图</view>
    <view
      class="view-btn {{currentView === 'list' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="list"
    >列表</view>
  </view>

  <!-- 月份/周导航 -->
  <view class="cal-nav" wx:if="{{currentView !== 'list'}}">
    <view class="cal-nav-btn" bindtap="prevMonth">‹</view>
    <view class="cal-month" wx:if="{{currentView === 'month'}}">{{currentYear}}年{{currentMonth}}月</view>
    <view class="cal-month" wx:if="{{currentView === 'week'}}">{{weekRangeLabel}}</view>
    <view class="cal-nav-btn" bindtap="nextMonth">›</view>
  </view>

  <!-- 星期标题 -->
  <view class="weekday-row" wx:if="{{currentView !== 'list'}}">
    <view class="weekday" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</view>
  </view>

  <!-- 月视图 -->
  <view class="calendar-grid" wx:if="{{currentView === 'month'}}">
    <view
      wx:for="{{calendarDays}}"
      wx:key="index"
      class="day-cell {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
      bindtap="selectDate"
      data-date="{{item.dateStr}}"
    >
      <block wx:if="{{!item.empty}}">
        <view class="day-num">{{item.day}}</view>
        <view class="event-dots">
          <view class="event-indicator {{item.eventCount > 1 ? 'multi' : ''}}" wx:if="{{item.eventCount > 0}}"></view>
        </view>
      </block>
    </view>
  </view>

  <!-- 周视图 -->
  <view class="week-view" wx:if="{{currentView === 'week'}}">
    <view class="week-grid">
      <view
        wx:for="{{weekDays}}"
        wx:key="dateStr"
        class="week-day-cell {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        bindtap="selectDate"
        data-date="{{item.dateStr}}"
      >
        <view class="week-day-num">{{item.day}}</view>
        <view class="event-dots">
          <view class="event-indicator {{item.eventCount > 1 ? 'multi' : ''}}" wx:if="{{item.eventCount > 0}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 列表视图 -->
  <view class="list-view" wx:if="{{currentView === 'list'}}">
    <!-- 当月统计 -->
    <view class="list-stats-card" wx:if="{{listMonthStats.total > 0}}">
      <view class="list-stats-item">
        <view class="list-stats-num">{{listMonthStats.completed}}</view>
        <view class="list-stats-label">已完成</view>
      </view>
      <view class="list-stats-divider"></view>
      <view class="list-stats-item">
        <view class="list-stats-num pending">{{listMonthStats.pending}}</view>
        <view class="list-stats-label">待完成</view>
      </view>
      <view class="list-stats-divider"></view>
      <view class="list-stats-item">
        <view class="list-stats-num">{{listMonthStats.completionRate}}%</view>
        <view class="list-stats-label">完成率</view>
      </view>
    </view>

    <block wx:for="{{listGroups}}" wx:key="dateStr" wx:for-item="group">
      <view class="list-group">
        <view class="list-group-header">
          <text class="list-group-label">{{group.dateLabel}}</text>
          <text class="list-group-sub">{{group.dateSub}}</text>
        </view>
        <view class="list-group-events">
          <view
            class="event-card {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}} {{item.completed ? 'completed' : ''}}"
            wx:for="{{group.events}}"
            wx:key="index"
            bindtap="goToItem"
            data-page="{{item.pagePath}}"
            data-id="{{item._id}}"
            data-title="{{item.title || item.name || item.paperTitle || ''}}"
            data-type="{{item.type}}"
          >
            <view class="event-icon">{{item.iconEmoji}}</view>
            <view class="event-info">
              <view class="event-title-row">
                <text class="event-type-label">{{item.typeLabel}}</text>
                <text class="event-title-text">{{item.title || item.name || item.paperTitle || '未命名'}}</text>
              </view>
              <view class="event-meta-row">
                <text class="event-date">{{item.deadlineLabel}}</text>
                <text class="event-status {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
              </view>
            </view>
            <view class="event-check" data-id="{{item._id}}" data-type="{{item.type}}" catchtap="toggleTaskComplete">
              <view class="event-check-circle {{item.completed ? 'checked' : ''}}"></view>
            </view>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{listGroups.length === 0}}" class="list-empty">
      <view class="empty-icon">📅</view>
      <view class="empty-text">暂无事件</view>
      <view class="empty-action" bindtap="showAddTaskModal">添加任务</view>
    </view>
  </view>



  <!-- 选中日期的事件（月视图/周视图显示） -->
  <view class="events-section" wx:if="{{currentView !== 'list'}}">
    <view class="section-header">
      <view class="section-title">📅 {{selectedDateLabel}} 的事件</view>
      <view class="section-actions">
        <view class="action-btn primary" bindtap="showAddTaskModal">添加任务</view>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="day-stats-card" wx:if="{{selectedEvents.length > 0}}">
      <view class="day-stats-item">
        <view class="day-stats-num">{{dayStats.completed}}</view>
        <view class="day-stats-label">已完成</view>
      </view>
      <view class="day-stats-divider"></view>
      <view class="day-stats-item">
        <view class="day-stats-num pending">{{dayStats.pending}}</view>
        <view class="day-stats-label">待完成</view>
      </view>
      <view class="day-stats-divider"></view>
      <view class="day-stats-item">
        <view class="day-stats-num">{{dayStats.completionRate}}%</view>
        <view class="day-stats-label">完成率</view>
      </view>
    </view>

    <!-- 待完成 -->
    <view class="day-task-section" wx:if="{{pendingEvents.length > 0}}">
      <view class="day-section-header">
        <view class="day-section-title">
          <text class="day-dot pending"></text>
          <text>待完成 ({{pendingEvents.length}})</text>
        </view>
      </view>
      <view class="day-task-items">
        <view
          class="event-card {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}}"
          wx:for="{{pendingEvents}}"
          wx:key="index"
          data-page="{{item.pagePath}}"
          data-id="{{item._id}}"
          data-title="{{item.title || item.name || item.paperTitle || ''}}"
          data-type="{{item.type}}"
          bindtap="goToItem"
        >
          <view class="event-icon">{{item.iconEmoji}}</view>
          <view class="event-info">
            <view class="event-title-row">
              <text class="event-type-label">{{item.typeLabel}}</text>
              <text class="event-title-text">{{item.title || item.name || item.paperTitle || '未命名'}}</text>
            </view>
            <view class="event-meta-row">
              <text class="event-date">{{item.deadlineLabel}}</text>
              <text class="event-status {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
            </view>
          </view>
          <view class="event-actions-col">
            <view class="event-check" data-id="{{item._id}}" data-type="{{item.type}}" catchtap="toggleTaskComplete">
              <view class="event-check-circle"></view>
            </view>
            <view class="event-delete" wx:if="{{item.type === 'task'}}" catchtap="deleteTask" data-id="{{item._id}}">×</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 已完成 -->
    <view class="day-task-section completed-section" wx:if="{{completedEvents.length > 0}}">
      <view class="day-section-header">
        <view class="day-section-title">
          <text class="day-dot completed"></text>
          <text>已完成 ({{completedEvents.length}})</text>
        </view>
      </view>
      <view class="day-task-items">
        <view
          class="event-card completed {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}}"
          wx:for="{{completedEvents}}"
          wx:key="index"
          data-page="{{item.pagePath}}"
          data-id="{{item._id}}"
          data-title="{{item.title || item.name || item.paperTitle || ''}}"
          data-type="{{item.type}}"
          bindtap="goToItem"
        >
          <view class="event-icon">{{item.iconEmoji}}</view>
          <view class="event-info">
            <view class="event-title-row">
              <text class="event-type-label">{{item.typeLabel}}</text>
              <text class="event-title-text">{{item.title || item.name || item.paperTitle || '未命名'}}</text>
            </view>
            <view class="event-meta-row">
              <text class="event-date">{{item.deadlineLabel}}</text>
              <text class="event-status {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
            </view>
          </view>
          <view class="event-actions-col">
            <view class="event-check" data-id="{{item._id}}" data-type="{{item.type}}" catchtap="toggleTaskComplete">
              <view class="event-check-circle checked"></view>
            </view>
            <view class="event-delete" wx:if="{{item.type === 'task'}}" catchtap="deleteTask" data-id="{{item._id}}">×</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{selectedEvents.length === 0}}" class="events-empty">
      <text class="empty-icon">📭</text>
      <text class="empty-text">这天没有安排</text>
    </view>
  </view>

  <!-- 添加任务弹窗 -->
  <view class="add-sheet {{showTaskModal ? 'show' : ''}}">
    <view class="sheet-mask" bindtap="hideAddTaskModal"></view>
    <view class="sheet-content">
      <view class="sheet-header">
        <text class="sheet-title">{{modalMode === 'edit' ? '编辑任务' : '添加任务'}}</text>
        <view class="sheet-close" bindtap="hideAddTaskModal">×</view>
      </view>
      <!-- 标题 -->
      <view class="form-row">
        <view class="form-label">任务标题 <text class="required">*</text></view>
        <input class="form-input" placeholder="请输入任务标题" value="{{modalTitle}}" bindinput="onModalTitleInput" maxlength="100"/>
      </view>

      <!-- 描述 -->
      <view class="form-row">
        <view class="form-label">任务描述</view>
        <textarea class="form-textarea" placeholder="添加任务详细说明（可选）" value="{{modalDesc}}" bindinput="onModalDescInput" maxlength="500"/>
      </view>

      <!-- 日期时间 -->
      <view class="form-row">
        <view class="form-label">日期和时间</view>
        <view class="datetime-row">
          <picker mode="date" value="{{modalDate}}" bindchange="onModalDateChange">
            <view class="datetime-picker">
              <text class="datetime-icon">📅</text>
              <text>{{modalDate}}</text>
            </view>
          </picker>
          <picker mode="time" value="{{modalTime}}" bindchange="onModalTimeChange">
            <view class="datetime-picker">
              <text class="datetime-icon">🕐</text>
              <text>{{modalTime}}</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 提醒设置 -->
      <view class="form-row">
        <view class="form-label">提醒设置</view>
        <view class="reminder-options">
          <view class="reminder-item {{modalReminder === null ? 'active' : ''}}" bindtap="onModalReminderChange" data-value="null">不提醒</view>
          <view class="reminder-item {{modalReminder === 1 ? 'active' : ''}}" bindtap="onModalReminderChange" data-value="1">提前1小时</view>
          <view class="reminder-item {{modalReminder === 2 ? 'active' : ''}}" bindtap="onModalReminderChange" data-value="2">提前2小时</view>
          <view class="reminder-item {{modalReminder === 3 ? 'active' : ''}}" bindtap="onModalReminderChange" data-value="3">提前3小时</view>
        </view>
      </view>

      <view class="sheet-confirm-btn" bindtap="confirmAddTask">{{modalMode === 'edit' ? '保存修改' : '确认添加'}}</view>
    </view>
  </view>
</view>
