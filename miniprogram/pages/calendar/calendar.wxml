<!--pages/calendar/calendar.wxml-->
<view class="calendar-page">
  <!-- 顶部 -->
  <view class="cal-header">
    <view class="cal-title">学术日历</view>
    <view class="header-actions">
      <view class="header-btn add-task" bindtap="goToTaskEditor">+</view>
      <view class="header-btn" bindtap="goToToday">今</view>
    </view>
  </view>

  <!-- 视图切换 -->
  <view class="view-switcher">
    <view
      class="view-btn {{currentView === 'month' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="month"
    >月视图</view>
    <view
      class="view-btn {{currentView === 'week' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="week"
    >周视图</view>
    <view
      class="view-btn {{currentView === 'list' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="list"
    >列表</view>
  </view>

  <!-- 月份/周导航 -->
  <view class="cal-nav" wx:if="{{currentView !== 'list'}}">
    <view class="cal-nav-btn" bindtap="prevMonth">‹</view>
    <view class="cal-month" wx:if="{{currentView === 'month'}}">{{currentYear}}年{{currentMonth}}月</view>
    <view class="cal-month" wx:if="{{currentView === 'week'}}">{{weekRangeLabel}}</view>
    <view class="cal-nav-btn" bindtap="nextMonth">›</view>
  </view>

  <!-- 星期标题 -->
  <view class="weekday-row" wx:if="{{currentView !== 'list'}}">
    <view class="weekday" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</view>
  </view>

  <!-- 月视图 -->
  <view class="calendar-grid" wx:if="{{currentView === 'month'}}">
    <view
      wx:for="{{calendarDays}}"
      wx:key="index"
      class="day-cell {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
      bindtap="selectDate"
      data-date="{{item.dateStr}}"
    >
      <block wx:if="{{!item.empty}}">
        <view class="day-num">{{item.day}}</view>
        <view class="event-dots">
          <view class="event-indicator {{item.eventCount > 1 ? 'multi' : ''}}" wx:if="{{item.eventCount > 0}}"></view>
        </view>
      </block>
    </view>
  </view>

  <!-- 周视图 -->
  <view class="week-view" wx:if="{{currentView === 'week'}}">
    <view class="week-grid">
      <view
        wx:for="{{weekDays}}"
        wx:key="dateStr"
        class="week-day-cell {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        bindtap="selectDate"
        data-date="{{item.dateStr}}"
      >
        <view class="week-day-num">{{item.day}}</view>
        <view class="event-dots">
          <view class="event-indicator {{item.eventCount > 1 ? 'multi' : ''}}" wx:if="{{item.eventCount > 0}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 列表视图 -->
  <view class="list-view" wx:if="{{currentView === 'list'}}">
    <block wx:for="{{listGroups}}" wx:key="dateStr" wx:for-item="group">
      <view class="list-group">
        <view class="list-group-header">
          <text class="list-group-label">{{group.dateLabel}}</text>
          <text class="list-group-sub">{{group.dateSub}}</text>
        </view>
        <view class="list-group-events">
          <view
            class="upcoming-item {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}} {{item.urgent ? 'urgent' : ''}} {{item.completed ? 'completed' : ''}}"
            wx:for="{{group.events}}"
            wx:key="index"
            bindtap="goToItem"
            data-page="{{item.pagePath}}"
            data-id="{{item._id}}"
            data-title="{{item.title || item.name || item.paperTitle || ''}}"
            data-type="{{item.type}}"
          >
            <view class="upcoming-icon">{{item.iconEmoji}}</view>
            <view class="upcoming-info">
              <view class="upcoming-title">
                <text class="type-label">{{item.typeLabel}}</text>
                <text>{{item.title || item.name || item.paperTitle || '未命名'}}</text>
              </view>
              <view class="upcoming-meta">
                <text class="date">{{item.deadlineLabel}}</text>
                <text class="countdown {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
              </view>
            </view>
            <view class="list-checkbox" wx:if="{{item.type === 'task'}}" data-id="{{item._id}}" catchtap="toggleTaskComplete">
              <view class="checkbox-inner {{item.completed ? 'checked' : ''}}"></view>
            </view>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{listGroups.length === 0}}" class="list-empty">
      <view class="empty-icon">📅</view>
      <view class="empty-text">暂无事件</view>
      <view class="empty-action" bindtap="goToTaskEditor">添加任务</view>
    </view>
  </view>

  <!-- 选中日期的事件（月视图/周视图显示） -->
  <view class="events-section" wx:if="{{currentView !== 'list'}}">
    <view class="section-header">
      <view class="section-title">📅 {{selectedDateLabel}} 的事件</view>
      <view class="section-actions">
        <view class="action-btn primary" bindtap="goToDailyTasks">每日任务</view>
      </view>
    </view>

    <view wx:if="{{selectedEvents.length > 0}}" class="event-list">
      <view
        class="upcoming-item {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}} {{item.urgent ? 'urgent' : ''}}"
        wx:for="{{selectedEvents}}"
        wx:key="index"
        bindtap="goToItem"
        data-page="{{item.pagePath}}"
        data-id="{{item._id}}"
        data-title="{{item.title || item.name || item.paperTitle || ''}}"
        data-type="{{item.type}}"
      >
        <view class="upcoming-icon">{{item.iconEmoji}}</view>
        <view class="upcoming-info">
          <view class="upcoming-title">
            <text class="type-label">{{item.typeLabel}}</text>
            <text>{{item.title || item.name || item.paperTitle || '未命名'}}</text>
          </view>
          <view class="upcoming-meta">
            <text class="date">{{item.deadlineLabel}}</text>
            <text class="countdown {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{selectedEvents.length === 0}}" class="events-empty">
      <text class="empty-icon">📭</text>
      <text class="empty-text">这天没有安排</text>
      <view class="empty-action" bindtap="goToTaskEditor">添加任务</view>
    </view>
  </view>

  <!-- 列表视图的筛选栏 -->
  <view class="filter-bar" wx:if="{{currentView === 'list'}}">
    <view class="filter-group">
      <view class="filter-tag {{filterTypeStates.submission ? 'active type-blue' : ''}}" bindtap="toggleFilterType" data-type="submission"><view class="filter-dot"></view>投稿</view>
      <view class="filter-tag {{filterTypeStates.review ? 'active type-red' : ''}}" bindtap="toggleFilterType" data-type="review"><view class="filter-dot"></view>审稿</view>
      <view class="filter-tag {{filterTypeStates.conference ? 'active type-green' : ''}}" bindtap="toggleFilterType" data-type="conference"><view class="filter-dot"></view>会议</view>
      <view class="filter-tag {{filterTypeStates.task ? 'active type-purple' : ''}}" bindtap="toggleFilterType" data-type="task"><view class="filter-dot"></view>任务</view>
    </view>
    <view class="filter-status">
      <view class="{{filterCompleted === 'all' ? 'active' : ''}}" bindtap="setFilterCompleted" data-status="all">全部</view>
      <view class="{{filterCompleted === 'undone' ? 'active' : ''}}" bindtap="setFilterCompleted" data-status="undone">未完成</view>
      <view class="{{filterCompleted === 'done' ? 'active' : ''}}" bindtap="setFilterCompleted" data-status="done">已完成</view>
    </view>
  </view>

  <!-- 列表视图 -->
  <view class="list-view" wx:if="{{currentView === 'list'}}">
    <block wx:for="{{listGroups}}" wx:key="dateStr" wx:for-item="group">
      <view class="list-group">
        <view class="list-group-header">
          <text class="list-group-label">{{group.dateLabel}}</text>
          <text class="list-group-sub">{{group.dateSub}}</text>
        </view>
        <view class="list-group-events">
          <view
            class="upcoming-item {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}} {{item.urgent ? 'urgent' : ''}} {{item.completed ? 'completed' : ''}}"
            wx:for="{{group.events}}"
            wx:key="index"
            bindtap="goToItem"
            data-page="{{item.pagePath}}"
            data-id="{{item._id}}"
            data-title="{{item.title || item.name || item.paperTitle || ''}}"
            data-type="{{item.type}}"
          >
            <view class="upcoming-icon">{{item.iconEmoji}}</view>
            <view class="upcoming-info">
              <view class="upcoming-title">
                <text class="type-label">{{item.typeLabel}}</text>
                <text>{{item.title || item.name || item.paperTitle || '未命名'}}</text>
              </view>
              <view class="upcoming-meta">
                <text class="date">{{item.deadlineLabel}}</text>
                <text class="countdown {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
              </view>
            </view>
            <view class="list-checkbox" wx:if="{{item.type === 'task'}}" data-id="{{item._id}}" catchtap="toggleTaskComplete">
              <view class="checkbox-inner {{item.completed ? 'checked' : ''}}"></view>
            </view>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{listGroups.length === 0}}" class="list-empty">
      <view class="empty-icon">📅</view>
      <view class="empty-text">暂无事件</view>
      <view class="empty-action" bindtap="goToTaskEditor">添加任务</view>
    </view>
  </view>

  <!-- 月视图/周视图的筛选栏 -->
  <view class="filter-bar" wx:if="{{currentView !== 'list'}}">
    <view class="filter-group">
      <view class="filter-tag {{filterTypeStates.submission ? 'active type-blue' : ''}}" bindtap="toggleFilterType" data-type="submission"><view class="filter-dot"></view>投稿</view>
      <view class="filter-tag {{filterTypeStates.review ? 'active type-red' : ''}}" bindtap="toggleFilterType" data-type="review"><view class="filter-dot"></view>审稿</view>
      <view class="filter-tag {{filterTypeStates.conference ? 'active type-green' : ''}}" bindtap="toggleFilterType" data-type="conference"><view class="filter-dot"></view>会议</view>
      <view class="filter-tag {{filterTypeStates.task ? 'active type-purple' : ''}}" bindtap="toggleFilterType" data-type="task"><view class="filter-dot"></view>任务</view>
    </view>
    <view class="filter-status">
      <view class="{{filterCompleted === 'all' ? 'active' : ''}}" bindtap="setFilterCompleted" data-status="all">全部</view>
      <view class="{{filterCompleted === 'undone' ? 'active' : ''}}" bindtap="setFilterCompleted" data-status="undone">未完成</view>
      <view class="{{filterCompleted === 'done' ? 'active' : ''}}" bindtap="setFilterCompleted" data-status="done">已完成</view>
    </view>
  </view>

  <!-- 选中日期的事件（月视图/周视图显示） -->
  <view class="events-section" wx:if="{{currentView !== 'list'}}">
    <view class="section-header">
      <view class="section-title">📅 {{selectedDateLabel}} 的事件</view>
      <view class="section-actions">
        <view class="action-btn primary" bindtap="goToDailyTasks">每日任务</view>
      </view>
    </view>

    <view wx:if="{{selectedEvents.length > 0}}" class="event-list">
      <view
        class="upcoming-item {{item.type === 'submission' ? 'type-blue' : item.type === 'review' ? 'type-red' : item.type === 'conference' ? 'type-green' : 'type-purple'}} {{item.urgent ? 'urgent' : ''}}"
        wx:for="{{selectedEvents}}"
        wx:key="index"
        bindtap="goToItem"
        data-page="{{item.pagePath}}"
        data-id="{{item._id}}"
        data-title="{{item.title || item.name || item.paperTitle || ''}}"
        data-type="{{item.type}}"
      >
        <view class="upcoming-icon">{{item.iconEmoji}}</view>
        <view class="upcoming-info">
          <view class="upcoming-title">
            <text class="type-label">{{item.typeLabel}}</text>
            <text>{{item.title || item.name || item.paperTitle || '未命名'}}</text>
          </view>
          <view class="upcoming-meta">
            <text class="date">{{item.deadlineLabel}}</text>
            <text class="countdown {{item.urgent ? 'urgent' : 'normal'}}">{{item.countdownLabel}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{selectedEvents.length === 0}}" class="events-empty">
      <text class="empty-icon">📭</text>
      <text class="empty-text">这天没有安排</text>
      <view class="empty-action" bindtap="goToTaskEditor">添加任务</view>
    </view>
  </view>

</view>
