<!--pages/calendar/calendar.wxml-->
<view class="calendar-page">
  <!-- 顶部 -->
  <view class="cal-header">
    <view class="cal-title">学术日历</view>
    <view class="header-actions">
      <view class="header-btn add-task" bindtap="goToTaskEditor">+</view>
      <view class="header-btn" bindtap="goToToday">今</view>
    </view>
  </view>

  <!-- 视图切换 -->
  <view class="view-switcher">
    <view
      class="view-btn {{currentView === 'month' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="month"
    >月视图</view>
    <view
      class="view-btn {{currentView === 'week' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="week"
    >周视图</view>
    <view
      class="view-btn {{currentView === 'list' ? 'active' : ''}}"
      bindtap="switchView"
      data-view="list"
    >列表</view>
  </view>

  <!-- 月份/周导航 -->
  <view class="cal-nav" wx:if="{{currentView !== 'list'}}">
    <view class="cal-nav-btn" bindtap="prevMonth">‹</view>
    <view class="cal-month" wx:if="{{currentView === 'month'}}">{{currentYear}}年{{currentMonth}}月</view>
    <view class="cal-month" wx:if="{{currentView === 'week'}}">{{weekRangeLabel}}</view>
    <view class="cal-nav-btn" bindtap="nextMonth">›</view>
  </view>

  <!-- 星期标题 -->
  <view class="weekday-row" wx:if="{{currentView !== 'list'}}">
    <view class="weekday" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</view>
  </view>

  <!-- 月视图 -->
  <view class="calendar-grid" wx:if="{{currentView === 'month'}}">
    <view
      wx:for="{{calendarDays}}"
      wx:key="index"
      class="day-cell {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
      bindtap="selectDate"
      data-date="{{item.dateStr}}"
    >
      <block wx:if="{{!item.empty}}">
        <view class="day-num">{{item.day}}</view>
        <view class="event-dots" wx:if="{{item.eventCount > 0}}">
          <view class="event-indicator {{item.eventCount > 1 ? 'multi' : ''}}"></view>
        </view>
      </block>
    </view>
  </view>

  <!-- 周视图 -->
  <view class="week-view" wx:if="{{currentView === 'week'}}">
    <view class="week-grid">
      <view
        wx:for="{{weekDays}}"
        wx:key="dateStr"
        class="week-day-cell {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        bindtap="selectDate"
        data-date="{{item.dateStr}}"
      >
        <view class="week-day-num">{{item.day}}</view>
        <view class="event-dots" wx:if="{{item.events.length > 0}}">
          <view class="dot {{dot}}" wx:for="{{item.events}}" wx:for-item="dot" wx:key="*this"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 列表视图 -->
  <view class="list-view" wx:if="{{currentView === 'list'}}">
    <view class="list-item" wx:for="{{listEvents}}" wx:key="index">
      <view class="list-date">{{item.dateLabel}}</view>
      <view class="list-content">
        <view class="list-title">{{item.title || item.name || item.paperTitle}}</view>
        <view class="list-type {{item.type}}">{{item.typeLabel}}</view>
      </view>
    </view>
    <view wx:if="{{listEvents.length === 0}}" class="list-empty">暂无本月事件</view>
  </view>

  <!-- 图例 -->
  <view class="legend" wx:if="{{currentView !== 'list'}}">
    <view class="legend-item"><view class="legend-dot submission"></view>投稿</view>
    <view class="legend-item"><view class="legend-dot review"></view>审稿</view>
    <view class="legend-item"><view class="legend-dot conference"></view>会议</view>
    <view class="legend-item"><view class="legend-dot task"></view>任务</view>
  </view>

  <!-- 选中日期的事件 -->
  <view class="events-section">
    <view class="section-header">
      <view class="section-title">📅 {{selectedDateLabel}} 的事件</view>
      <view class="section-actions">
        <view class="action-btn primary" bindtap="goToDailyTasks">每日任务</view>
      </view>
    </view>
    
    <view wx:if="{{selectedEvents.length > 0}}" class="event-list">
      <view class="event-item {{item.type}}" wx:for="{{selectedEvents}}" wx:key="index">
        <view class="event-dot {{item.type}}"></view>
        <view class="event-content">
          <view class="event-title">{{item.title || item.name || item.paperTitle || '未命名'}}</view>
          <view class="event-meta">
            <text class="event-type">{{item.typeLabel}}</text>
            <text class="event-time" wx:if="{{item.time}}">{{item.time}}</text>
            <text class="event-priority {{item.priority}}" wx:if="{{item.type === 'task' && item.priority}}">
              {{item.priority === 'high' ? '紧急' : item.priority === 'medium' ? '普通' : '低优'}}
            </text>
          </view>
        </view>
      </view>
    </view>
    
    <view wx:if="{{selectedEvents.length === 0}}" class="events-empty">
      <text class="empty-icon">📭</text>
      <text class="empty-text">这天没有安排</text>
      <view class="empty-action" bindtap="goToTaskEditor">添加任务</view>
    </view>
  </view>
</view>
