/* pages/calendar/task-editor/task-editor.wxss */
page {
  background: #F6F6F6;
}

.task-editor-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.form-scroll {
  padding: 24rpx;
}

/* 表单区块 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

/* 输入框 */
.form-input {
  font-size: 30rpx;
  color: #111827;
  border-bottom: 1rpx solid #E5E7EB;
  padding: 12rpx 0;
}

.form-textarea {
  font-size: 28rpx;
  color: #111827;
  min-height: 160rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  width: 100%;
  box-sizing: border-box;
}

/* 日期时间 */
.datetime-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.date-picker, .time-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  flex: 1;
}

.date-picker .icon, .time-picker .icon {
  font-size: 32rpx;
}

.date-picker text:last-child, .time-picker text:last-child {
  font-size: 28rpx;
  color: #111827;
}

.all-day-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.all-day-toggle text {
  font-size: 26rpx;
  color: #6B7280;
}

/* 开关 */
.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  background: #D1D5DB;
  border-radius: 24rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-switch.active {
  background: #2563EB;
}

.toggle-dot {
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.toggle-switch.active .toggle-dot {
  transform: translateX(40rpx);
}

/* 优先级选择 */
.priority-selector {
  display: flex;
  gap: 16rpx;
}

.priority-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.priority-btn text {
  font-size: 26rpx;
  color: #6B7280;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-dot.low { background: #10B981; }
.priority-dot.medium { background: #F59E0B; }
.priority-dot.high { background: #EF4444; }

.priority-btn.active {
  border-color: currentColor;
}

.priority-btn.active.low { border-color: #10B981; background: #D1FAE5; }
.priority-btn.active.medium { border-color: #F59E0B; background: #FEF3C7; }
.priority-btn.active.high { border-color: #EF4444; background: #FEE2E2; }

/* 分类选择 */
.category-picker, .repeat-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.category-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.category-icon.study::before { content: '📚'; }
.category-icon.research::before { content: '🔬'; }
.category-icon.meeting::before { content: '👥'; }
.category-icon.custom::before { content: '📝'; }
.category-icon.other::before { content: '📋'; }

.category-name {
  font-size: 28rpx;
  color: #111827;
  flex: 1;
}

.arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

/* 提醒选项 */
.reminder-options {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 8rpx 0;
}

.reminder-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.reminder-item text {
  font-size: 28rpx;
  color: #374151;
}

/* 重复结束日期 */
.repeat-end-picker {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.repeat-end-picker .label {
  font-size: 26rpx;
  color: #6B7280;
}

.repeat-end-picker .value {
  font-size: 28rpx;
  color: #111827;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.delete-btn {
  padding: 24rpx 40rpx;
  background: #FEE2E2;
  color: #EF4444;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.save-btn {
  flex: 1;
  padding: 24rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.save-btn[loading] {
  opacity: 0.7;
}

/* 删除确认弹窗 */
.delete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
}

.delete-modal.show {
  display: flex;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  z-index: 1001;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #6B7280;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.modal-btn.cancel {
  background: #F3F4F6;
  color: #374151;
}

.modal-btn.confirm {
  background: #EF4444;
  color: #fff;
}
