/* pages/archive/archive.wxss */
page { background: #F6F6F6; }
.page-container { padding-bottom: 120rpx; }
.search-bar { background: #fff; padding: 16rpx 24rpx; display: flex; gap: 16rpx; align-items: center; border-bottom: 1rpx solid #E5E7EB; }
.search-input-wrap { flex: 1; background: #F3F4F6; border-radius: 40rpx; padding: 12rpx 20rpx; display: flex; align-items: center; gap: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.upload-btn { background: #F59E0B; color: #fff; padding: 12rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; flex-shrink: 0; }
.filter-scroll { background: #fff; }
.filter-tabs { display: flex; padding: 0 16rpx 16rpx; gap: 12rpx; white-space: nowrap; }
.filter-tab { padding: 8rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; color: #6B7280; background: #F3F4F6; flex-shrink: 0; }
.filter-tab.active { background: #FEF3C7; color: #F59E0B; font-weight: 500; }
.archive-list { padding: 16rpx; }
.file-card { background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 12rpx; display: flex; align-items: center; gap: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.file-icon { width: 72rpx; height: 72rpx; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0; }
.file-icon.pdf { background: #FEE2E2; }
.file-icon.doc { background: #DBEAFE; }
.file-icon.other { background: #F3F4F6; }
.file-info { flex: 1; }
.file-name { font-size: 26rpx; font-weight: 500; color: #111827; }
.file-meta { font-size: 22rpx; color: #9CA3AF; margin-top: 4rpx; }
.file-del { font-size: 32rpx; padding: 8rpx; }
.fab { position: fixed; right: 40rpx; bottom: 160rpx; width: 96rpx; height: 96rpx; border-radius: 50%; background: #F59E0B; color: #fff; font-size: 60rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(245,158,11,0.4); }
.empty-box { text-align: center; padding: 100rpx 40rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; background: #fff; border-radius: 16rpx; }
.empty-box text:first-child { font-size: 80rpx; }
.btn-add-first { margin-top: 20rpx; background: #F59E0B; color: #fff; font-size: 28rpx; border-radius: 40rpx; padding: 16rpx 48rpx; }
