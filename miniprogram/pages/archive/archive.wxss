/* pages/archive/archive.wxss */
.page-container { background: #F6F6F6; padding-bottom: 160rpx; }

/* 搜索栏 */
.search-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.search-input-wrap {
  flex: 1;
  background: #F3F4F6;
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.search-input-wrap .icon { font-size: 28rpx; }
.search-input { flex: 1; font-size: 28rpx; }

/* 分类选项卡 */
.filter-scroll { background: #fff; border-bottom: 1rpx solid #E5E7EB; }
.filter-tabs { display: flex; padding: 0 16rpx 16rpx; gap: 12rpx; white-space: nowrap; }
.filter-tab {
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.filter-tab.active { background: #0F766E; color: #fff; font-weight: 500; }
.filter-tab .count { font-size: 20rpx; opacity: 0.7; }

/* 文件列表 */
.archive-list { padding: 16rpx; }
.file-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.file-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.file-icon.pdf { background: #FEE2E2; }
.file-icon.doc { background: #DBEAFE; }
.file-icon.image-icon { background: #D1FAE5; }
.file-icon.other { background: #F3F4F6; }
.file-info { flex: 1; min-width: 0; }
.file-name { font-size: 26rpx; font-weight: 500; color: #111827; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.file-meta { font-size: 22rpx; color: #9CA3AF; margin-top: 4rpx; }
.file-del { font-size: 32rpx; padding: 8rpx; flex-shrink: 0; }

/* 空状态 */
.empty-box {
  text-align: center;
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 16rpx;
}
.empty-box .icon { font-size: 80rpx; }
.empty-box .tip { font-size: 28rpx; color: #374151; font-weight: 500; }
.empty-box .sub-tip { font-size: 24rpx; color: #9CA3AF; }

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0F766E;
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(15,118,110,0.4);
}
