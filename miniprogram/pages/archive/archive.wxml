<!--pages/archive/archive.wxml-->
<view class="page-container" style="--primary-color:{{theme.primary}};--primary-dark:{{theme.primaryDark}};--primary-light:{{theme.primaryLight}};--primary-light-text:{{theme.primaryLightText}};--primary-shadow:{{theme.primaryShadow}}">
  <!-- 分享卡片打开时的自动下载遮罩 -->
  <view class="auto-open-mask" wx:if="{{autoOpening}}">
    <view class="auto-open-box">
      <text class="auto-open-icon">📄</text>
      <text class="auto-open-name">{{autoOpenFileName || '文件'}}</text>
      <text class="auto-open-tip">{{autoOpenTip || '正在准备文件...'}}</text>
    </view>
  </view>
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="icon">🔍</text>
      <input class="search-input" placeholder="搜索文件名..." bindinput="onSearch" value="{{searchKw}}"/>
    </view>
  </view>

  <!-- 分类选项卡（从数据库读取） -->
  <scroll-view scroll-x class="filter-scroll">
    <view class="filter-tabs">
      <view class="filter-tab {{filterCategory==='all'?'active':''}}" bindtap="setFilter" data-cat="all">全部 <text class="count">{{counts.all}}</text></view>
      <view class="filter-tab {{filterCategory===item._id?'active':''}}" wx:for="{{categoryList}}" wx:key="_id" bindtap="setFilter" data-cat="{{item._id}}">{{item.name}} <text class="count">{{counts[item._id] || 0}}</text></view>
    </view>
  </scroll-view>

  <!-- 文件列表 -->
  <view class="archive-list">
    <view wx:if="{{list.length === 0}}" class="empty-box">
      <text class="icon">📁</text>
      <text class="tip">暂无归档文件</text>
      <text class="sub-tip">点击右下角按钮上传文件</text>
    </view>
    <view class="file-card" wx:for="{{list}}" wx:key="_id" bindtap="previewFile" data-id="{{item._id}}">
      <view class="file-icon pdf" wx:if="{{item.ext === 'pdf'}}">📄</view>
      <view class="file-icon doc" wx:elif="{{item.ext === 'doc' || item.ext === 'docx'}}">📝</view>
      <view class="file-icon image-icon" wx:elif="{{item.ext === 'png' || item.ext === 'jpg' || item.ext === 'jpeg'}}">🖼️</view>
      <view class="file-icon other" wx:else>📎</view>
      <view class="file-info">
        <view class="file-name">{{item.name}}</view>
        <view class="file-meta">{{item.categoryName}} · {{item.extLabel}} · {{item.sizeLabel}} · {{item.createTime}}</view>
      </view>
      <view class="file-actions">
        <image class="action-icon" src="../../images/icons/download.svg" catchtap="downloadFile" data-id="{{item._id}}"></image>
        <image class="action-icon" src="../../images/icons/trash.svg" catchtap="deleteItem" data-id="{{item._id}}" data-fileid="{{item.fileID}}"></image>
        <image class="action-icon" src="../../images/icons/share.svg" catchtap="shareFile" data-id="{{item._id}}"></image>
      </view>
    </view>
  </view>

  <!-- FAB：打开上传弹窗 -->
  <view class="fab" bindtap="openUploadModal">+</view>

  <!-- 上传弹窗组件 -->
  <upload-form
    visible="{{showUpload}}"
    bind:close="onUploadClose"
    bind:uploadSuccess="onUploadSuccess"
  />
</view>
