/* pages/archive/stats/stats.wxss */
.stats-page {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.stats-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; color: #9CA3AF; font-size: 28rpx; }

.stats-overview { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.overview-card { flex: 0 0 calc(50% - 8rpx); background: #fff; border-radius: 16rpx; padding: 28rpx 24rpx; box-sizing: border-box; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.overview-num { display: block; font-size: 48rpx; font-weight: 700; line-height: 1.1; }
.overview-card.total .overview-num { color: #3B82F6; }
.overview-card.size .overview-num { color: #10B981; }
.size-num { font-size: 36rpx !important; }
.overview-label { display: block; font-size: 24rpx; color: #6B7280; margin-top: 8rpx; }

.stats-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1F2937; }

.status-row { margin-bottom: 20rpx; }
.status-row:last-child { margin-bottom: 0; }
.status-label-row { display: flex; align-items: center; margin-bottom: 8rpx; }
.status-label { flex: 1; font-size: 26rpx; color: #374151; }
.status-count { font-size: 26rpx; font-weight: 600; color: #1F2937; }
.status-bar-wrap { height: 12rpx; background: #F3F4F6; border-radius: 6rpx; overflow: hidden; }
.status-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.5s ease; min-width: 2rpx; }

/* 文件类型网格 */
.type-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.type-card {
  flex: 0 0 calc(33.33% - 12rpx);
  text-align: center;
  padding: 24rpx 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
  box-sizing: border-box;
}
.type-name { display: block; font-size: 24rpx; font-weight: 600; margin-bottom: 6rpx; }
.type-count { display: block; font-size: 22rpx; color: #6B7280; }

.goto-section { margin-top: 8rpx; }
.goto-btn { display: flex; justify-content: center; align-items: center; padding: 28rpx; background: #fff; border-radius: 16rpx; font-size: 28rpx; color: #3B82F6; font-weight: 500; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.goto-arrow { margin-left: 8rpx; font-size: 32rpx; }
