/* pages/citation/citation.wxss */
.page {
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #f6f6f6;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 自定义 Toast */
.custom-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 9999;
  white-space: nowrap;
  max-width: 80%;
  text-align: center;
}

/* 搜索区域 */
.search-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.search-type-switch {
  display: flex;
  margin-bottom: 20rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 4rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
}

.type-btn.active {
  background: #fff;
  color: var(--primary-color, #2563eb);
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.search-btn {
  background: var(--primary-color, #2563eb);
  color: #fff;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.scan-btn {
  text-align: center;
  color: var(--primary-color, #2563eb);
  font-size: 28rpx;
  padding: 12rpx 0;
}

/* 错误信息 */
.error-msg {
  background: #fee2e2;
  color: #dc2626;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

/* 查询/OCR 加载弹窗 */
.loading-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  position: relative;
  min-width: 360rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.loading-modal-icon {
  font-size: 64rpx;
}

.loading-modal-text {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: bold;
}

.loading-modal-hint {
  font-size: 24rpx;
  color: #9ca3af;
}

.loading-modal-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
  line-height: 1;
}

/* 结果区域 */
.result-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 20rpx;
}

/* 标签导航 */
.tab-nav {
  display: flex;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 4rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #6b7280;
  border-radius: 10rpx;
}

.tab-item.active {
  background: #fff;
  color: var(--primary-color, #2563eb);
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 标签内容 */
.tab-content {
  margin-bottom: 20rpx;
  height: 560rpx;
  overflow-x: hidden;
  overflow-y: auto;
  position: relative;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

/* 文献详情 */
.detail-section {
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.detail-row {
  display: flex;
  align-items: stretch;
  border-bottom: 1rpx solid #e5e7eb;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  width: 180rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #4b5563;
  background: #f3f4f6;
  padding: 20rpx 16rpx;
  border-right: 1rpx solid #e5e7eb;
  box-sizing: border-box;
  line-height: 1.4;
}

.detail-value {
  flex: 1;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
  padding: 20rpx 16rpx;
  word-break: break-all;
  box-sizing: border-box;
}

.detail-abstract {
  display: block;
  text-align: justify;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  background: var(--primary-light, #dbeafe);
  color: var(--primary-dark, #1d4ed8);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

/* 列表通用 */
.list-loading {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #6b7280;
}

.list-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
}

.list-section {
  margin-top: 20rpx;
}

.list-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16rpx;
}

/* 统计卡片 */
.stat-section {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  isolation: isolate;
}

.stat-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.pie-wrap {
  display: flex;
  align-items: center;
}

.pie-chart {
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.pie-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-height: 240rpx;
  overflow-y: auto;
}

.pie-legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  padding: 4rpx 0;
}

.pie-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.pie-legend-name {
  color: #4b5563;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

.pie-legend-count {
  color: #1f2937;
  font-weight: bold;
  min-width: 36rpx;
  text-align: right;
}

/* 饼图汇总信息 */
.pie-summary {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: #f3f4f6;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.pie-summary-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
}

.pie-summary-detail {
  font-size: 26rpx;
  color: #6b7280;
}

/* 饼图名称横向列表 */
.pie-names-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.pie-names-row text {
  font-size: 26rpx;
  color: #374151;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e5e7eb;
}

.pie-legend-percent {
  color: #9ca3af;
  font-size: 22rpx;
  margin-left: 8rpx;
  min-width: 48rpx;
  text-align: right;
}

/* 文献列表 */
.ref-list {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
}

.ref-list-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e5e7eb;
}

.ref-list-item:last-child {
  border-bottom: none;
}

.ref-list-index {
  width: 60rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
  padding-top: 4rpx;
}

.ref-list-content {
  flex: 1;
}

.ref-list-title {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.5;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.ref-list-meta {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  word-break: break-all;
}

.ref-list-doi {
  font-size: 24rpx;
  color: var(--primary-color, #2563eb);
  margin-top: 4rpx;
  word-break: break-all;
}

/* 可复制文本样式 */
.copyable {
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background: #eff6ff;
  transition: background 0.2s;
}

.copyable:active {
  background: var(--primary-light, #dbeafe);
}

/* 柱状图 */
.chart-section {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  isolation: isolate;
}

.chart-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.chart-vert-wrap {
  position: relative;
  height: 340rpx;
  padding-top: 20rpx;
}

.chart-vert-line {
  position: absolute;
  top: 40rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 60rpx;
  pointer-events: none;
  z-index: 2;
}

.chart-vert-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding: 20rpx 20rpx 40rpx;
  box-sizing: border-box;
}

.chart-vert-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  margin: 0 8rpx;
}

.chart-vert-bar-wrap {
  width: 100%;
  max-width: 60rpx;
  height: 220rpx;
  background: #f3f4f6;
  border-radius: 6rpx 6rpx 0 0;
  position: relative;
  overflow: hidden;
}

.chart-vert-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--primary-color, #2563eb);
  border-radius: 6rpx 6rpx 0 0;
  transition: height 0.5s ease;
}

.chart-vert-count {
  font-size: 24rpx;
  color: #1f2937;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.chart-vert-year {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* ucharts 图表容器 */
.uchart-box {
  height: 400rpx;
  width: 100%;
  position: relative;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

/* 确保 ucharts 的 canvas 被正确包含，不浮动 */
.uchart-box canvas,
.uchart-box > view {
  position: relative !important;
}

.uchart-pie {
  height: 500rpx;
  width: 100%;
  position: relative;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

/* 确保饼图 canvas 也在正确层级 */
.uchart-pie canvas,
.uchart-pie > view {
  position: relative !important;
}

/* 饼图容器：饼图 + 图例左右布局 */
.pie-chart-wrap {
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 1;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

/* 确保图表组件内的 canvas 被正确限制 */
.pie-chart-wrap canvas,
.pie-chart-wrap > view {
  position: relative !important;
}

.pie-canvas {
  width: 100%;
  flex-shrink: 0;
}

.pie-legend-list {
  flex: 1;
  padding-left: 16rpx;
}

.pie-legend-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.pie-legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.pie-legend-name {
  flex: 1;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pie-legend-count {
  color: #1f2937;
  font-weight: bold;
  margin-left: 12rpx;
  min-width: 50rpx;
  text-align: right;
}

/* 引用格式区域 */
.citation-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 格式选择 */
.style-select {
  margin-bottom: 20rpx;
}

.style-picker {
  background: #f3f4f6;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--primary-color, #2563eb);
  text-align: center;
}

/* 引用块 */
.citation-block {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.citation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.citation-label {
  font-size: 24rpx;
  color: #6b7280;
}

.citation-content {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
  word-break: break-all;
}

.copy-btn {
  background: var(--primary-color, #2563eb);
  color: #fff;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 保存按钮 */
.save-btn {
  background: #10b981;
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

/* 文献库 */
.library-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.library-section .section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.toggle-icon {
  font-size: 24rpx;
  color: #6b7280;
}

.empty-tip {
  text-align: center;
  color: #9ca3af;
  padding: 40rpx 0;
  font-size: 28rpx;
}

/* 文献库项目 */
.library-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f3f4f6;
}

.library-item:last-child {
  border-bottom: none;
}

.lib-item-content {
  flex: 1;
}

.lib-item-title {
  font-size: 28rpx;
  color: #1f2937;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.lib-item-meta {
  font-size: 24rpx;
  color: #6b7280;
}

.lib-item-delete {
  padding: 16rpx;
  color: #ef4444;
  font-size: 32rpx;
}

/* 饼图展开按钮 */
.expand-btn {
  text-align: center;
  padding: 16rpx 0;
  color: var(--primary-color, #2563eb);
  font-size: 28rpx;
  background: #f0f4ff;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

/* 饼图完整列表 */
.pie-full-list {
  margin-top: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.pie-full-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.pie-full-item:last-child {
  border-bottom: none;
}

.pie-full-name {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.pie-full-count {
  font-size: 26rpx;
  font-weight: bold;
  color: #1f2937;
  min-width: 60rpx;
  text-align: right;
}

.pie-full-percent {
  font-size: 24rpx;
  color: #6b7280;
  min-width: 90rpx;
  text-align: right;
}

/* 表格弹窗 - 居中显示 */
.table-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.table-content {
  width: 90%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #e5e7eb;
}

.table-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.table-close {
  font-size: 40rpx;
  color: #9ca3af;
  padding: 0 16rpx;
}

.table-body {
  max-height: calc(70vh - 100rpx);
  padding-bottom: 30rpx;
}

.table-row {
  display: flex;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.table-head {
  background: #f9fafb;
  font-weight: bold;
}

.table-cell {
  font-size: 28rpx;
  color: #374151;
}

.col-name {
  flex: 1;
  overflow: hidden;
  text-overflow: normal;
  white-space: normal;
  word-break: break-all;
}

.col-count {
  width: 120rpx;
  text-align: center;
}

.col-percent {
  width: 140rpx;
  text-align: right;
  color: #6b7280;
}

/* 饼图汇总信息 */
.pie-summary {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: #f3f4f6;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.pie-summary-total {
  font-size: 28rpx;
  color: var(--primary-color, #2563eb);
}

.pie-summary-main {
  font-size: 28rpx;
  color: #374151;
}

/* OpenAlex 不可用提示 */
.openalex-tip {
  background: #fef3c7;
  border: 1rpx solid #f59e0b;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.5;
}

/* 被引文献滚动区域（保留兼容） */
.citing-works-scroll {
  height: 600rpx;
}

/* 加载更多提示 */
.load-more-tip {
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
}

.load-more-tip text {
  background: var(--primary-color, #2563eb);
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  display: inline-block;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

/* 没有更多数据提示 */
.no-more-tip {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 被引文献列表 - 带序号 */
.citing-works-scroll .ref-list-item,
.citing-modal-scroll .ref-list-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e5e7eb;
}

.citing-works-scroll .ref-list-item:last-child,
.citing-modal-scroll .ref-list-item:last-child {
  border-bottom: none;
}

.citing-works-scroll .ref-list-index,
.citing-modal-scroll .ref-list-index {
  width: 60rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
  padding-top: 4rpx;
}

.citing-works-scroll .ref-list-content,
.citing-modal-scroll .ref-list-content {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

/* ==================== 图片裁剪器（全屏） ==================== */

.cropper-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1000;
}

.cropper-toolbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 200;
  padding: 16rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, rgba(0,0,0,0.7) 30%, rgba(0,0,0,0.85));
}

.cropper-ratio-tabs {
  display: flex;
  flex-wrap: nowrap;
  gap: 10rpx;
  overflow-x: auto;
  margin-bottom: 16rpx;
  -webkit-overflow-scrolling: touch;
}

.cropper-ratio-tab {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.1);
  border: 2rpx solid rgba(255,255,255,0.15);
}

.cropper-ratio-tab.active {
  color: #fff;
  background: var(--primary-color, #2563eb);
  border-color: var(--primary-color, #2563eb);
}

.cropper-actions {
  display: flex;
  gap: 20rpx;
}

.cropper-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.cropper-btn-cancel {
  background: rgba(255,255,255,0.15);
  color: #fff;
}

.cropper-btn-confirm {
  background: var(--primary-color, #2563eb);
  color: #fff;
}

/* ==================== 以下旧裁剪预览样式（已废弃，保留以防引用） ==================== */


/* 被引文献弹窗 */
.citing-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.citing-modal-content {
  width: 95%;
  height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.citing-modal-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #e5e7eb;
  flex-shrink: 0;
}

.citing-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.citing-modal-count {
  font-size: 26rpx;
  color: #6b7280;
  margin-left: 16rpx;
  flex: 1;
}

.citing-modal-close {
  font-size: 40rpx;
  color: #9ca3af;
  padding: 0 16rpx;
}

.citing-modal-scroll {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 20rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

/* 弹窗底部固定区域 */
.modal-footer {
  padding: 20rpx;
  border-top: 1rpx solid #e5e7eb;
  flex-shrink: 0;
}

/* 加载更多按钮 */
.load-more-btn {
  text-align: center;
  background: var(--primary-color, #2563eb);
  color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

/* 弹窗内加载状态 */
.modal-loading {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #6b7280;
}

/* 弹窗内空状态 */
.modal-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
}

/* 被引文献入口按钮 */
.citing-entry {
  display: flex;
  align-items: center;
  background: #f0f9ff;
  border: 2rpx solid var(--primary-color, #2563eb);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.citing-entry-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.citing-entry-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.citing-entry-title {
  font-size: 30rpx;
  color: var(--primary-color, #2563eb);
  font-weight: bold;
}

.citing-entry-count {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.citing-entry-arrow {
  font-size: 48rpx;
  color: var(--primary-color, #2563eb);
  font-weight: bold;
}
