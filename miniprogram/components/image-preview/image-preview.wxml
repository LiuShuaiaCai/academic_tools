<view wx:if="{{visible}}" class="preview-mask" bindtap="onClose" catchtouchmove="preventTouchMove">
  <view class="preview-content">
    <image
      src="{{imageUrl}}"
      mode="aspectFit"
      class="preview-image"
      bindtap="onImageTap"
    />
  </view>
  <view class="preview-actions">
    <view class="action-btn" bindtap="onSave">保存到相册</view>
    <view class="action-btn close-btn" bindtap="onClose">关闭</view>
  </view>
</view>
