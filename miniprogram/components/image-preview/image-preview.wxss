.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.preview-content {
  width: 90%;
  max-height: 75vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.preview-image {
  width: 100%;
  max-width: 100%;
  max-height: 75vh;
}

.preview-actions {
  position: fixed;
  bottom: 50rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx;
}

.action-btn {
  padding: 16rpx 50rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
}

.close-btn {
  background: rgba(255, 255, 255, 0.1);
}
